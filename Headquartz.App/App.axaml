<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.App"
             xmlns:local="using:Headquartz.App"
             RequestedThemeVariant="Dark">

	<Application.DataTemplates>
		<local:ViewLocator/>
	</Application.DataTemplates>

	<Application.Styles>
		<!-- 1. Avalonia Fluent base theme -->
		<FluentTheme />

		<!-- 2. Shared control styles (reference DynamicResource tokens) -->
		<StyleInclude Source="avares://Headquartz.App/Assets/Styles/StyleResources.axaml"/>
	</Application.Styles>

	<!--
        3. Active token dictionary — swapped at runtime by App.SetTheme().
           Starts on Dark. ThemeService replaces this entry in
           Application.Resources.MergedDictionaries at runtime.
    -->
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="avares://Headquartz.App/Assets/Themes/DarkTheme.axaml"/>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Application.Resources>

</Application>