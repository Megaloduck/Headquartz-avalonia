<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.App"
             xmlns:local="using:Headquartz.App"
             RequestedThemeVariant="Dark">

	<Application.DataTemplates>
		<local:ViewLocator/>
	</Application.DataTemplates>

	<Application.Styles>
		<!-- 1. Avalonia Fluent base -->
		<FluentTheme />

		<!-- 2. Shared control styles (uses {DynamicResource} tokens) -->
		<StyleInclude Source="avares://Headquartz.App/Assets/Styles/StyleResources.axaml"/>
	</Application.Styles>

	<!-- 3. Active token dictionary â€” change Source here to switch theme -->
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="avares://Headquartz.App/Assets/Themes/DarkTheme.axaml"/>
				<!-- To use light theme, swap the line above to:           -->
				<ResourceInclude Source="avares://Headquartz.App/Assets/Themes/LightTheme.axaml"/>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Application.Resources>

</Application>