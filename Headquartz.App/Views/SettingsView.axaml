<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.SettingsView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<TextBlock FontSize="34" FontWeight="Bold" Text="Settings"/>

			<!-- ════════════════════════════════════════════ -->
			<!-- SIMULATION STATUS                           -->
			<!-- ════════════════════════════════════════════ -->
			<Border Padding="20"
                    Background="{DynamicResource BrushBgCard}"
                    CornerRadius="{DynamicResource RadiusLg}"
                    BorderBrush="{DynamicResource BrushBorderSubtle}"
                    BorderThickness="1">
				<Grid ColumnDefinitions="*,*,*">

					<StackPanel Grid.Column="0">
						<TextBlock FontSize="12"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   Text="CURRENT TICK"/>
						<TextBlock FontSize="26" FontWeight="Bold"
                                   Text="{Binding CurrentTick}"/>
					</StackPanel>

					<StackPanel Grid.Column="1">
						<TextBlock FontSize="12"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   Text="WORLD TIME"/>
						<TextBlock FontSize="18" FontWeight="Bold"
                                   Text="{Binding WorldTime}"/>
					</StackPanel>

					<StackPanel Grid.Column="2">
						<TextBlock FontSize="12"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   Text="SPEED"/>
						<TextBlock FontSize="22" FontWeight="Bold"
                                   Text="{Binding SpeedLabel}"/>
					</StackPanel>

				</Grid>
			</Border>

			<!-- ════════════════════════════════════════════ -->
			<!-- SIMULATION SPEED                            -->
			<!-- ════════════════════════════════════════════ -->
			<Border Padding="24"
                    Background="{DynamicResource BrushBgCard}"
                    CornerRadius="{DynamicResource RadiusLg}"
                    BorderBrush="{DynamicResource BrushBorderSubtle}"
                    BorderThickness="1">
				<StackPanel Spacing="16">

					<TextBlock FontSize="20" FontWeight="Bold"
                               Text="Simulation Speed"/>
					<TextBlock FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               Text="Controls how fast simulation ticks advance."/>

					<WrapPanel>

						<Button Width="140" Padding="16,12" Margin="0,0,8,8"
                                CornerRadius="10"
                                Background="{DynamicResource BrushBgElevated}"
                                Command="{Binding SetHalfSpeedCommand}">
							<StackPanel HorizontalAlignment="Center" Spacing="4">
								<TextBlock Text="½×" FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
								<TextBlock Text="Slow" FontSize="11"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           HorizontalAlignment="Center"/>
								<TextBlock Text="2s / tick" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}"
                                           HorizontalAlignment="Center"/>
							</StackPanel>
						</Button>

						<Button Width="140" Padding="16,12" Margin="0,0,8,8"
                                CornerRadius="10"
                                Background="{DynamicResource BrushBorderStrong}"
                                Command="{Binding SetNormalSpeedCommand}">
							<StackPanel HorizontalAlignment="Center" Spacing="4">
								<TextBlock Text="1×" FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
								<TextBlock Text="Normal" FontSize="11"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           HorizontalAlignment="Center"/>
								<TextBlock Text="1s / tick" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}"
                                           HorizontalAlignment="Center"/>
							</StackPanel>
						</Button>

						<Button Width="140" Padding="16,12" Margin="0,0,8,8"
                                CornerRadius="10"
                                Background="{DynamicResource BrushBgElevated}"
                                Command="{Binding SetDoubleSpeedCommand}">
							<StackPanel HorizontalAlignment="Center" Spacing="4">
								<TextBlock Text="2×" FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
								<TextBlock Text="Fast" FontSize="11"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           HorizontalAlignment="Center"/>
								<TextBlock Text="0.5s / tick" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}"
                                           HorizontalAlignment="Center"/>
							</StackPanel>
						</Button>

						<Button Width="140" Padding="16,12" Margin="0,0,8,8"
                                CornerRadius="10"
                                Background="{DynamicResource BrushBgElevated}"
                                Command="{Binding SetTripleSpeedCommand}">
							<StackPanel HorizontalAlignment="Center" Spacing="4">
								<TextBlock Text="3×" FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
								<TextBlock Text="Turbo" FontSize="11"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           HorizontalAlignment="Center"/>
								<TextBlock Text="0.33s / tick" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}"
                                           HorizontalAlignment="Center"/>
							</StackPanel>
						</Button>

					</WrapPanel>

				</StackPanel>
			</Border>

			<!-- ════════════════════════════════════════════ -->
			<!-- APPEARANCE — live theme toggle              -->
			<!-- ════════════════════════════════════════════ -->
			<Border Padding="24"
                    Background="{DynamicResource BrushBgCard}"
                    CornerRadius="{DynamicResource RadiusLg}"
                    BorderBrush="{DynamicResource BrushBorderSubtle}"
                    BorderThickness="1">
				<StackPanel Spacing="20">

					<StackPanel Spacing="4">
						<TextBlock FontSize="20" FontWeight="Bold" Text="Appearance"/>
						<TextBlock FontSize="13"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   Text="Switch between Dark and Light themes. Changes apply instantly."/>
					</StackPanel>

					<Grid ColumnDefinitions="Auto,*">

						<!-- Toggle button -->
						<Button Grid.Column="0"
                                Padding="20,14"
                                CornerRadius="{DynamicResource RadiusLg}"
                                Background="{DynamicResource BrushAccentPrimary}"
                                BorderThickness="0"
                                Command="{Binding ToggleThemeCommand}">
							<StackPanel Orientation="Horizontal" Spacing="12">

								<!-- Icon changes with theme -->
								<Border Width="36" Height="36"
                                        CornerRadius="18"
                                        Background="#FFFFFF20">
									<TextBlock
                                        FontSize="18"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text="{Binding IsDarkTheme,
                                            FallbackValue='🌙',
                                            TargetNullValue='🌙'}"/>
								</Border>

								<StackPanel VerticalAlignment="Center">
									<TextBlock
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="{Binding ToggleThemeLabel}"/>
									<TextBlock
                                        FontSize="11"
                                        Foreground="#C7D2FE"
                                        Text="Click to switch"/>
								</StackPanel>

							</StackPanel>
						</Button>

						<!-- Active theme indicator -->
						<Border Grid.Column="1"
                                Margin="16,0,0,0"
                                Padding="20,14"
                                CornerRadius="{DynamicResource RadiusLg}"
                                Background="{DynamicResource BrushBgElevated}"
                                BorderBrush="{DynamicResource BrushBorderDefault}"
                                BorderThickness="1"
                                VerticalAlignment="Stretch">
							<StackPanel VerticalAlignment="Center" Spacing="4">
								<TextBlock FontSize="11"
                                           Foreground="{DynamicResource BrushTextMuted}"
                                           Text="ACTIVE THEME"/>
								<TextBlock FontSize="20"
                                           FontWeight="Bold"
                                           Text="{Binding ActiveThemeLabel}"/>
							</StackPanel>
						</Border>

					</Grid>

				</StackPanel>
			</Border>

			<!-- ════════════════════════════════════════════ -->
			<!-- COMPANY NAME                                -->
			<!-- ════════════════════════════════════════════ -->
			<Border Padding="24"
                    Background="{DynamicResource BrushBgCard}"
                    CornerRadius="{DynamicResource RadiusLg}"
                    BorderBrush="{DynamicResource BrushBorderSubtle}"
                    BorderThickness="1">
				<StackPanel Spacing="16">

					<TextBlock FontSize="20" FontWeight="Bold" Text="Company"/>

					<StackPanel Spacing="8">
						<TextBlock FontSize="13"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   Text="COMPANY NAME"/>
						<StackPanel Orientation="Horizontal" Spacing="12">
							<TextBox Text="{Binding CompanyName}"
                                     Watermark="Company name..."
                                     MinWidth="300"
                                     Padding="10,8"
                                     Background="{DynamicResource BrushBgInput}"
                                     BorderThickness="1"
                                     BorderBrush="{DynamicResource BrushBorderDefault}"
                                     CornerRadius="8"/>
							<Button Padding="14,8"
                                    Background="{DynamicResource BrushAccentPrimary}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    CornerRadius="8"
                                    Command="{Binding ApplyCompanyNameCommand}"
                                    Content="Apply"/>
						</StackPanel>
					</StackPanel>

					<Border IsVisible="{Binding StatusMessage,
                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Padding="14,10"
                            Background="{DynamicResource BrushBgElevated}"
                            BorderBrush="{DynamicResource BrushBorderDefault}"
                            BorderThickness="1"
                            CornerRadius="8">
						<TextBlock Text="{Binding StatusMessage}"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
					</Border>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>

</UserControl>