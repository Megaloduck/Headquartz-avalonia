<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.SettingsView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<TextBlock FontSize="34" FontWeight="Bold" Text="Settings"/>

			<!-- SIMULATION STATUS -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<Grid ColumnDefinitions="*,*,*">
					<StackPanel Grid.Column="0">
						<TextBlock FontSize="12" Foreground="#6B7280" Text="CURRENT TICK"/>
						<TextBlock FontSize="26" FontWeight="Bold" Text="{Binding CurrentTick}"/>
					</StackPanel>
					<StackPanel Grid.Column="1">
						<TextBlock FontSize="12" Foreground="#6B7280" Text="WORLD TIME"/>
						<TextBlock FontSize="18" FontWeight="Bold" Text="{Binding WorldTime}"/>
					</StackPanel>
					<StackPanel Grid.Column="2">
						<TextBlock FontSize="12" Foreground="#6B7280" Text="SPEED"/>
						<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding SpeedLabel}"/>
					</StackPanel>
				</Grid>
			</Border>

			<!-- SIMULATION SPEED -->
			<Border Padding="24" Background="#202633" CornerRadius="12">
				<StackPanel Spacing="16">
					<TextBlock FontSize="20" FontWeight="Bold" Text="Simulation Speed"/>
					<TextBlock FontSize="13" Foreground="#6B7280"
                        Text="Controls how fast simulation ticks advance. Useful for testing or slowing down for analysis."/>

					<WrapPanel>

						<Button
                            Width="140" Padding="16,12" CornerRadius="10"
                            Background="#1F2937"
                            Command="{Binding SetHalfSpeedCommand}">
							<StackPanel HorizontalAlignment="Center" Spacing="4">
								<TextBlock Text="½×" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
								<TextBlock Text="Slow" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
								<TextBlock Text="2s / tick" FontSize="10" Foreground="#4B5563" HorizontalAlignment="Center"/>
							</StackPanel>
						</Button>

						<Button
                            Width="140" Padding="16,12" CornerRadius="10"
                            Background="#374151"
                            Command="{Binding SetNormalSpeedCommand}">
							<StackPanel HorizontalAlignment="Center" Spacing="4">
								<TextBlock Text="1×" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
								<TextBlock Text="Normal" FontSize="11" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
								<TextBlock Text="1s / tick" FontSize="10" Foreground="#6B7280" HorizontalAlignment="Center"/>
							</StackPanel>
						</Button>

						<Button
                            Width="140" Padding="16,12" CornerRadius="10"
                            Background="#1F2937"
                            Command="{Binding SetDoubleSpeedCommand}">
							<StackPanel HorizontalAlignment="Center" Spacing="4">
								<TextBlock Text="2×" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
								<TextBlock Text="Fast" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
								<TextBlock Text="0.5s / tick" FontSize="10" Foreground="#4B5563" HorizontalAlignment="Center"/>
							</StackPanel>
						</Button>

						<Button
                            Width="140" Padding="16,12" CornerRadius="10"
                            Background="#1F2937"
                            Command="{Binding SetTripleSpeedCommand}">
							<StackPanel HorizontalAlignment="Center" Spacing="4">
								<TextBlock Text="3×" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
								<TextBlock Text="Turbo" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
								<TextBlock Text="0.33s / tick" FontSize="10" Foreground="#4B5563" HorizontalAlignment="Center"/>
							</StackPanel>
						</Button>

					</WrapPanel>
				</StackPanel>
			</Border>

			<!-- COMPANY NAME -->
			<Border Padding="24" Background="#202633" CornerRadius="12">
				<StackPanel Spacing="16">
					<TextBlock FontSize="20" FontWeight="Bold" Text="Company"/>
					<StackPanel Spacing="8">
						<TextBlock FontSize="13" Foreground="#9CA3AF" Text="COMPANY NAME"/>
						<StackPanel Orientation="Horizontal" Spacing="12">
							<TextBox
                                Text="{Binding CompanyName}"
                                Watermark="Company name..."
                                MinWidth="300"
                                Padding="10,8"
                                Background="#2B3242"
                                BorderThickness="1"
                                BorderBrush="#374151"
                                CornerRadius="8"/>
							<Button
                                Padding="14,8"
                                Background="#6366F1"
                                CornerRadius="8"
                                Command="{Binding ApplyCompanyNameCommand}"
                                Content="Apply"/>
						</StackPanel>
					</StackPanel>

					<Border
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Padding="14,10" Background="#2B3242" CornerRadius="8">
						<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
					</Border>
				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>