<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.ForecastView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<TextBlock FontSize="34" FontWeight="Bold" Text="Forecast"/>
			<TextBlock FontSize="13" Foreground="#6B7280" Text="30-tick cash flow projection based on current revenue and spending rate."/>

			<!-- CRITICAL RUNWAY BANNER -->
			<Border IsVisible="{Binding IsCritical}" Background="#7F1D1D" CornerRadius="12" Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="ðŸš¨" FontSize="22" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock
                            Text="BANKRUPTCY WARNING"
                            FontSize="16" FontWeight="Bold" Foreground="#FCA5A5"/>
						<TextBlock
                            Text="{Binding RunwayLabel}"
                            Foreground="#FCA5A5"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="10" Padding="20" Background="#202633" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="#9CA3AF" Text="{Binding Title}"/>
								<TextBlock FontSize="20" FontWeight="Bold" Text="{Binding Value}" TextWrapping="Wrap"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- PROJECTION TABLE -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="30-Tick Projection" Margin="0,0,0,16"/>

					<!-- Header -->
					<Border Padding="12,8" Background="#374151" CornerRadius="6" Margin="0,0,0,4">
						<Grid ColumnDefinitions="60,120,*,100,100">
							<TextBlock Grid.Column="0" Text="Tick"       FontSize="11" FontWeight="Bold" Foreground="#9CA3AF"/>
							<TextBlock Grid.Column="1" Text="World Time" FontSize="11" FontWeight="Bold" Foreground="#9CA3AF"/>
							<TextBlock Grid.Column="2" Text="Cash Balance" FontSize="11" FontWeight="Bold" Foreground="#9CA3AF"/>
							<TextBlock Grid.Column="3" Text="Revenue"    FontSize="11" FontWeight="Bold" Foreground="#9CA3AF"/>
							<TextBlock Grid.Column="4" Text="Expenses"   FontSize="11" FontWeight="Bold" Foreground="#9CA3AF"/>
						</Grid>
					</Border>

					<ItemsControl ItemsSource="{Binding Projection}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border
                                    Margin="0,2"
                                    Padding="12,10"
                                    CornerRadius="6"
                                    Background="#2B3242">
									<Grid ColumnDefinitions="60,120,*,100,100">

										<!-- Tick -->
										<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
											<TextBlock
                                                FontSize="12"
                                                Foreground="#6B7280"
                                                Text="{Binding Tick}"
                                                VerticalAlignment="Center"/>
											<!-- Payroll indicator -->
											<Border
                                                IsVisible="{Binding IsPayrollTick}"
                                                Background="#1E3A5F"
                                                CornerRadius="4"
                                                Padding="4,1"
                                                VerticalAlignment="Center">
												<TextBlock
                                                    Text="PAY"
                                                    FontSize="8"
                                                    FontWeight="Bold"
                                                    Foreground="#93C5FD"/>
											</Border>
										</StackPanel>

										<!-- World Time -->
										<TextBlock
                                            Grid.Column="1"
                                            FontSize="12"
                                            Foreground="#6B7280"
                                            Text="{Binding WorldTime}"
                                            VerticalAlignment="Center"/>

										<!-- Projected Cash -->
										<Panel Grid.Column="2" VerticalAlignment="Center">
											<TextBlock
                                                FontSize="13"
                                                FontWeight="Bold"
                                                Foreground="#EF4444"
                                                IsVisible="{Binding IsNegative}"
                                                Text="{Binding CashDisplay}"/>
											<TextBlock
                                                FontSize="13"
                                                FontWeight="Bold"
                                                Foreground="#D1D5DB"
                                                IsVisible="{Binding !IsNegative}"
                                                Text="{Binding CashDisplay}"/>
										</Panel>

										<!-- Revenue -->
										<TextBlock
                                            Grid.Column="3"
                                            FontSize="12"
                                            Foreground="#10B981"
                                            Text="{Binding Revenue, StringFormat='+${0:N0}'}"
                                            VerticalAlignment="Center"/>

										<!-- Expenses -->
										<TextBlock
                                            Grid.Column="4"
                                            FontSize="12"
                                            Foreground="#EF4444"
                                            Text="{Binding Expenses, StringFormat='-${0:N0}'}"
                                            VerticalAlignment="Center"/>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>