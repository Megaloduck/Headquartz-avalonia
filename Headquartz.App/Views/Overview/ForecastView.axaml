<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Headquartz.App.ViewModels"
             xmlns:conv="clr-namespace:Headquartz.App.Converters"
             x:Class="Headquartz.App.ForecastView"
             x:DataType="vm:ForecastViewModel">

    <UserControl.Resources>
        <conv:EventColorTagConverter x:Key="EventColorTagConverter"/>
        <conv:BoolToHighlightBrushConverter x:Key="BoolToHighlightBrushConverter"/>
        <conv:BoolToThicknessConverter x:Key="BoolToThicknessConverter"/>
        <conv:StringNotNullOrEmptyConverter x:Key="StringNotNullOrEmptyConverter"/>
        <conv:IntToBoolConverter x:Key="IntToBoolConverter"/>
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Margin="30" Spacing="20">

            <!-- HEADER -->
            <StackPanel Spacing="4">
                <TextBlock FontSize="34" FontWeight="Bold" Text="Forecast Overview"/>
                <TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Future event projection and calendar."/>
            </StackPanel>

            <!-- TOP STAT CARDS -->
            <Grid ColumnDefinitions="*,*,*,*" Margin="0,0,0,8">
                <!-- Upcoming Event -->
                <Border Grid.Column="0" Margin="4" Padding="16" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
                    <StackPanel Spacing="4">
                        <TextBlock FontSize="12" Foreground="{DynamicResource BrushTextMuted}" FontWeight="SemiBold" Text="Upcoming Event"/>
                        <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding UpcomingEventTitle}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                <!-- Item 2 placeholder (ticks) -->
                <Border Grid.Column="1" Margin="4" Padding="16" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
                    <StackPanel Spacing="4">
                        <TextBlock FontSize="12" Foreground="{DynamicResource BrushTextMuted}" FontWeight="SemiBold" Text="Ticks Elapsed"/>
                        <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding TicksElapsed, StringFormat='{}{0} Ticks'}"/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}" Text="5 seconds per tick"/>
                    </StackPanel>
                </Border>
                <!-- Item 3 placeholder (simulation time) -->
                <Border Grid.Column="2" Margin="4" Padding="16" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
                    <StackPanel Spacing="4">
                        <TextBlock FontSize="12" Foreground="{DynamicResource BrushTextMuted}" FontWeight="SemiBold" Text="Simulation Elapsed"/>
                        <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding SimulationElapsedDisplay}"/>
                    </StackPanel>
                </Border>
                <!-- Current Cash -->
                <Border Grid.Column="3" Margin="4" Padding="16" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
                    <StackPanel Spacing="4">
                        <TextBlock FontSize="12" Foreground="{DynamicResource BrushTextMuted}" FontWeight="SemiBold" Text="Current Cash"/>
                        <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding CurrentCash, StringFormat='${0:N0}'}"/>
                    </StackPanel>
                </Border>
            </Grid> 

            <!-- EVENT CALENDAR -->
            <Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
                <StackPanel Spacing="16">
                    <!-- Calendar Header -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock FontSize="22" FontWeight="Bold" Text="Event Calendar"/>
                            <TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Scheduled events and holidays"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Classes="ghost" Command="{Binding PreviousMonthCommand}" Padding="8,4">
                                <TextBlock Text="◀" FontSize="14"/>
                            </Button>
                            <Border Background="{DynamicResource BrushBgNested}" CornerRadius="8" Padding="12,6">
                                <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding CurrentMonth, StringFormat='{}{0:dd MMMM yyyy}'}"/>
                            </Border>
                            <Button Classes="ghost" Command="{Binding NextMonthCommand}" Padding="8,4">
                                <TextBlock Text="▶" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Day-of-week headers -->
                    <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                        <TextBlock Grid.Column="0" Text="SUN" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="MON" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="TUE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="WED" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="THU" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="FRI" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="SAT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Calendar Grid -->
                    <ItemsControl ItemsSource="{Binding CalendarDays}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7" Rows="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="2"
                                    Padding="6"
                                    Background="{DynamicResource BrushBgNested}"
                                    CornerRadius="8"
                                    MinHeight="80"
                                    IsVisible="{Binding IsCurrentMonth}"
                                    BorderBrush="{Binding IsToday, Converter={StaticResource BoolToHighlightBrushConverter}, ConverterParameter=BrushAccentPrimary}"
                                    BorderThickness="{Binding IsToday, Converter={StaticResource BoolToThicknessConverter}, ConverterParameter=2}">
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            Text="{Binding DayNumber}"
                                            FontSize="14"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource BrushTextPrimary}"/>
                                        <ItemsControl ItemsSource="{Binding Events}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Margin="0,2"
                                                        Padding="4,3"
                                                        CornerRadius="4"
                                                        Background="{Binding ColorTag, Converter={StaticResource EventColorTagConverter}}"
                                                        Opacity="0.85">
                                                        <StackPanel>
                                                            <TextBlock
                                                                Text="{Binding Title}"
                                                                FontSize="10"
                                                                FontWeight="SemiBold"
                                                                Foreground="White"
                                                                TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock
                                                                Text="{Binding EffectSummary}"
                                                                FontSize="9"
                                                                Foreground="#E2E8F0"
                                                                TextTrimming="CharacterEllipsis"
                                                                IsVisible="{Binding EffectSummary, Converter={StaticResource StringNotNullOrEmptyConverter}}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- TODAY'S EVENT -->
            <Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="18" FontWeight="Bold" Text="Today's Event"/>
                    <ItemsControl ItemsSource="{Binding TodayEvents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,4"
                                    Padding="14"
                                    Background="{DynamicResource BrushBgNested}"
                                    CornerRadius="10"
                                    BorderThickness="2"
                                    BorderBrush="{Binding ColorTag, Converter={StaticResource EventColorTagConverter}}">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Border
                                            Grid.Column="0"
                                            Width="8"
                                            Height="8"
                                            CornerRadius="4"
                                            Background="{Binding ColorTag, Converter={StaticResource EventColorTagConverter}}"
                                            VerticalAlignment="Center"
                                            Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock FontSize="15" FontWeight="Bold" Text="{Binding Title}"/>
                                            <TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Subtitle}"/>
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource BrushTextMuted}"
                                                Text="{Binding EffectSummary}"
                                                IsVisible="{Binding EffectSummary, Converter={StaticResource StringNotNullOrEmptyConverter}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock
                        IsVisible="{Binding HasNoTodayEvents}"
                        FontSize="13"
                        Foreground="{DynamicResource BrushTextMuted}"
                        Text="No events scheduled for today."
                        Margin="0,8"/>
                </StackPanel>
            </Border>


		</StackPanel>
	</ScrollViewer>
</UserControl>