    <UserControl
    Name="ShellRoot"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Headquartz.App.ViewModels"
    xmlns:conv="using:Headquartz.App.Converters"
    xmlns:controls="using:Headquartz.App.Controls"
    x:Class="Headquartz.App.ShellView"
    x:DataType="vm:ShellViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- ═══════════════════════════════════════════════ -->
        <!-- TOP BAR                                         -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border
            Grid.Row="0"
            Height="48"
            Background="{DynamicResource BrushBgSurface}"
            BorderBrush="{DynamicResource BrushBorderSubtle}"
            BorderThickness="0,0,0,1"
            ZIndex="10">

            <Grid ColumnDefinitions="260,*,Auto">

                <!-- Left: Logo block (aligns with sidebar width) -->
                <Border
                    Grid.Column="0"
                    Padding="16,0"
                    BorderBrush="{DynamicResource BrushBorderSubtle}"
                    BorderThickness="0,0,1,0">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Border Width="28" Height="28" CornerRadius="7">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#4338CA" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock
                                Text="H"
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="White"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock
                            Text="Headquartz"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource BrushTextPrimary}"
                            VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Center: Breadcrumb + Company Name -->
                <Grid Grid.Column="1" ColumnDefinitions="*,Auto,*">

                    <!-- Breadcrumb (left-aligned in center column) -->
                    <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center"
                        Margin="20,0,0,0">
                        <TextBlock
                            Text="{Binding SectionLabel}"
                            FontSize="13"
                            Foreground="{DynamicResource BrushTextMuted}"/>
                        <Path
                            Data="M9 18l6-6-6-6"
                            Stroke="{DynamicResource BrushTextMuted}"
                            StrokeThickness="1.5"
                            Width="12" Height="12"
                            Stretch="Uniform"
                            VerticalAlignment="Center"/>
                        <TextBlock
                            Text="{Binding PageTitle}"
                            FontSize="13"
                            FontWeight="Medium"
                            Foreground="{DynamicResource BrushTextPrimary}"/>
                    </StackPanel>

                    <!-- Company Name (centered) -->
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding CompanyName}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource BrushTextSecondary}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Grid>

                <!-- Right: Role chip + Theme toggle + Window controls -->
                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0">

                    <!-- Role chip -->
                    <Border
                        Padding="10,5"
                        Background="{DynamicResource BrushBgElevated}"
                        BorderBrush="{DynamicResource BrushBorderDefault}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Path
                                Data="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2M12 11a4 4 0 100-8 4 4 0 000 8z"
                                Stroke="{DynamicResource BrushTextMuted}"
                                StrokeThickness="1.5"
                                Fill="Transparent"
                                Width="13" Height="13"
                                Stretch="Uniform"
                                VerticalAlignment="Center"/>
                            <TextBlock
                                Text="{Binding RoleName}"
                                FontSize="12"
                                Foreground="{DynamicResource BrushTextSecondary}"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Theme toggle -->
                    <Button
                        Width="32" Height="32"
                        Padding="0"
                        Background="{DynamicResource BrushBgElevated}"
                        BorderBrush="{DynamicResource BrushBorderDefault}"
                        BorderThickness="1"
                        CornerRadius="6"
                        ToolTip.Tip="Toggle Theme"
                        Command="{Binding ToggleThemeCommand}">
                        <!-- Sun icon (visible in dark mode) -->
                        <Path
                            Data="M12 17a5 5 0 100-10 5 5 0 000 10zm0-13v2m0 12v2M5 12H3m18 0h-2m-2.05-7.07L17.3 6.28M6.7 17.72l-1.35 1.35M4.93 4.93L6.28 6.28M17.72 17.72l1.35 1.35"
                            Stroke="{DynamicResource BrushTextSecondary}"
                            StrokeThickness="1.5"
                            Fill="Transparent"
                            Width="14" Height="14"
                            Stretch="Uniform"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Button>

                </StackPanel>

            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- BODY: SIDEBAR + CONTENT                         -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="260,*">

            <!-- ─────────────────────────────────────────── -->
            <!-- SIDEBAR                                      -->
            <!-- ─────────────────────────────────────────── -->
            <Border
                Grid.Column="0"
                Background="{DynamicResource BrushBgSurface}"
                BorderBrush="{DynamicResource BrushBorderSubtle}"
                BorderThickness="0,0,1,0">

                <DockPanel>

                    <!-- ── Tick Status Card ──────────────── -->
                    <controls:TickStatusCard
                        DockPanel.Dock="Bottom"
                        Margin="8,0,8,8"
                        DateLabel="{Binding DateLabel}"
                        TicksPerWorkHour="{Binding TicksPerWorkHour}"
                        TicksElapsedInWorkHour="{Binding TicksElapsedInWorkHour}"
                        WorkHoursElapsedInDay="{Binding WorkHoursElapsedInDay}"/>

                    <!-- ── Bottom: Settings + Log out ────── -->
                    <StackPanel
                        DockPanel.Dock="Bottom"
                        Margin="8,0,8,4"
                        Spacing="1">
                        <Border
                            Height="1"
                            Background="{DynamicResource BrushBorderSubtle}"
                            Margin="4,4,4,4"/>

                        <!-- Settings -->
                        <Button
                            Padding="10,7"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="6"
                            Command="{Binding NavigateSettingsCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Path
                                    Data="M12 15a3 3 0 100-6 3 3 0 000 6zm6.93-3c.04-.32.07-.65.07-1s-.03-.68-.07-1l2.16-1.68a.5.5 0 00.12-.64l-2.05-3.55a.5.5 0 00-.61-.22l-2.55 1.03A7.47 7.47 0 0014.5 3.5l-.38-2.71A.49.49 0 0013.63.5h-4.1a.49.49 0 00-.49.43L8.66 3.65a7.47 7.47 0 00-1.9.83L4.21 3.45a.5.5 0 00-.61.22L1.55 7.22a.49.49 0 00.12.64L3.83 9.54A7.76 7.76 0 003.76 11c0 .35.03.68.07 1L1.67 13.68a.5.5 0 00-.12.64l2.05 3.55a.5.5 0 00.61.22l2.55-1.03c.59.32 1.22.59 1.9.83l.38 2.71c.06.25.28.43.54.43h4.1c.26 0 .48-.18.54-.43l.38-2.71a7.47 7.47 0 001.9-.83l2.55 1.03a.5.5 0 00.61-.22l2.05-3.55a.5.5 0 00-.12-.64L18.93 12z"
                                    Stroke="{DynamicResource BrushTextMuted}"
                                    StrokeThickness="1"
                                    Fill="Transparent"
                                    Width="15" Height="15"
                                    Stretch="Uniform"
                                    VerticalAlignment="Center"/>
                                <TextBlock
                                    Text="Settings"
                                    FontSize="13"
                                    Foreground="{DynamicResource BrushTextSecondary}"
                                    VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Log out -->
                        <Button
                            Padding="10,7"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="6">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Path
                                    Data="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"
                                    Stroke="{DynamicResource BrushTextMuted}"
                                    StrokeThickness="1.5"
                                    Fill="Transparent"
                                    Width="15" Height="15"
                                    Stretch="Uniform"
                                    VerticalAlignment="Center"/>
                                <TextBlock
                                    Text="Log out"
                                    FontSize="13"
                                    Foreground="{DynamicResource BrushTextSecondary}"
                                    VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- ── Nav sections ───────────────────── -->
                    <ScrollViewer
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">

                        <ItemsControl
                            Margin="8,8,8,0"
                            ItemsSource="{Binding SidebarSections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,4">

                                        <!-- Section label -->
                                        <TextBlock
                                            Text="{Binding Title}"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource BrushTextMuted}"
                                            Margin="10,10,10,3"
                                            LetterSpacing="0.5"/>

                                        <!-- Nav items -->
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button
                                                        Padding="10,7"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        CornerRadius="6"
                                                        Margin="0,1"
                                                        Command="{Binding #ShellRoot.DataContext.NavigateCommand}"
                                                        CommandParameter="{Binding}">

                                                        <Grid ColumnDefinitions="18,*,Auto">

                                                            <!-- Icon via Path -->
                                                            <Path
                                                                Grid.Column="0"
                                                                Data="{Binding Icon,
                                                                    Converter={x:Static conv:IconPathConverter.Instance}}"
                                                                Stroke="{DynamicResource BrushTextMuted}"
                                                                StrokeThickness="1.5"
                                                                Fill="Transparent"
                                                                Width="15" Height="15"
                                                                Stretch="Uniform"
                                                                VerticalAlignment="Center"/>

                                                            <!-- Label -->
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                Text="{Binding Title}"
                                                                FontSize="13"
                                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                                VerticalAlignment="Center"
                                                                Margin="10,0,0,0"/>

                                                            <!-- Notification badge -->
                                                            <Border
                                                                Grid.Column="2"
                                                                IsVisible="{Binding HasNotification}"
                                                                MinWidth="18"
                                                                Height="18"
                                                                Padding="4,0"
                                                                Background="#EF4444"
                                                                CornerRadius="9"
                                                                VerticalAlignment="Center">
                                                                <TextBlock
                                                                    Text="{Binding NotificationCount}"
                                                                    FontSize="10"
                                                                    FontWeight="Bold"
                                                                    Foreground="White"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                            </Border>

                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </ScrollViewer>

                </DockPanel>
            </Border>

            <!-- ─────────────────────────────────────────── -->
            <!-- CONTENT AREA                                 -->
            <!-- ─────────────────────────────────────────── -->
            <ContentControl
                Grid.Column="1"
                Content="{Binding CurrentView}"/>

        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- NOTIFICATION OVERLAY (bubble toasts, top-right) -->
        <!-- ═══════════════════════════════════════════════ -->
        <ItemsControl
            Grid.Row="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,12,16,0"
            Width="320"
            IsHitTestVisible="True"
            ItemsSource="{Binding Notifications}"
            ZIndex="100">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border
                        Margin="0,0,0,8"
                        Padding="14,12"
                        Background="{Binding BackgroundColor}"
                        BorderBrush="{Binding BorderColor}"
                        BorderThickness="1"
                        CornerRadius="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock
                                    FontSize="13" FontWeight="Bold"
                                    Text="{Binding Title}"
                                    Foreground="White"
                                    TextWrapping="Wrap"/>
                                <TextBlock
                                    FontSize="12" Foreground="#D1D5DB"
                                    Text="{Binding Message}"
                                    TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="6,4"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Top"
                                Command="{Binding #ShellRoot.DataContext.DismissNotificationCommand}"
                                CommandParameter="{Binding}">
                                <Path
                                    Data="M18 6L6 18M6 6l12 12"
                                    Stroke="#9CA3AF"
                                    StrokeThickness="1.5"
                                    Fill="Transparent"
                                    Width="10" Height="10"
                                    Stretch="Uniform"/>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>

</UserControl>