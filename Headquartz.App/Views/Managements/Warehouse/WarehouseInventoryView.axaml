<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.WarehouseInventoryView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Inventory Management"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Stock levels, SKU management, reorder points, and inventory valuation."/>
			</StackPanel>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- ACTIONS -->
			<WrapPanel ItemSpacing="10">
				<Button
                    Padding="14" Margin="0,5"
                    Command="{Binding RestockAllCommand}"
                    Content="📥  Restock All Low Items"/>
			</WrapPanel>

			<!-- INVENTORY TABLE -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Stock Levels" Margin="0,0,0,16"/>

					<ItemsControl ItemsSource="{Binding Inventory}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,6" Padding="18" Background="{DynamicResource BrushBgNested}" CornerRadius="10">
									<StackPanel Spacing="12">

										<!-- Name + qty + restock button -->
										<Grid ColumnDefinitions="*,Auto,Auto">

											<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
												<TextBlock
                                                    FontSize="16"
                                                    FontWeight="Bold"
                                                    Text="{Binding Name}"
                                                    VerticalAlignment="Center"/>
												<Border
                                                    IsVisible="{Binding IsLow}"
                                                    Background="{DynamicResource BrushAlertCriticalBg}"
                                                    CornerRadius="6"
                                                    Padding="7,2"
                                                    VerticalAlignment="Center">
													<TextBlock
                                                        Text="LOW STOCK"
                                                        FontSize="9"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource BrushBadgeDangerFg}"/>
												</Border>
											</StackPanel>

											<!-- Quantity badge -->
											<StackPanel
                                                Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="4"
                                                VerticalAlignment="Center"
                                                Margin="0,0,16,0">
												<TextBlock
                                                    FontSize="22"
                                                    FontWeight="Bold"
                                                    Text="{Binding Quantity}"/>
												<TextBlock
                                                    FontSize="12"
                                                    Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="units"
                                                    VerticalAlignment="Bottom"
                                                    Margin="0,0,0,3"/>
											</StackPanel>

											<!-- Restock button -->
											<Button
                                                Grid.Column="2"
                                                Padding="12,7"
                                                Background="{DynamicResource BrushBgInput}"
                                                CornerRadius="7"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].DataContext.RestockItemCommand}"
                                                CommandParameter="{Binding}"
                                                Content="＋50 Restock"/>

										</Grid>

										<!-- Fill bar -->
										<StackPanel Orientation="Horizontal" Spacing="10">
											<ProgressBar
                                                Value="{Binding FillPercent}"
                                                Maximum="1.0"
                                                Height="10"
                                                Width="340"
                                                Foreground="{DynamicResource BrushDeptWarehouse}"
                                                VerticalAlignment="Center"/>
											<TextBlock
                                                FontSize="12"
                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding FillPercent, StringFormat='{}{0:P0}'}"
                                                VerticalAlignment="Center"/>
										</StackPanel>

										<!-- Stock info row -->
										<StackPanel Orientation="Horizontal" Spacing="24">
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding MinimumStock, StringFormat='Min: {0}'}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding MaximumStock, StringFormat='Max: {0}'}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding UnitCost, StringFormat='${0}/unit'}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Quantity, StringFormat='Restock cost: {0}×'}"/>
										</StackPanel>

									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>