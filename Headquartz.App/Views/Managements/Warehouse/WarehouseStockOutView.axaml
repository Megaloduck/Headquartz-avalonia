<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.WarehouseStockOutView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<TextBlock FontSize="34" FontWeight="Bold" Text="Stock Out"/>
			<TextBlock FontSize="13" Foreground="#6B7280"
                Text="Issue and log inventory dispatched to production or other departments."/>

			<!-- KPIs -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="10" Padding="20" Background="#202633" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="#9CA3AF" Text="{Binding Title}"/>
								<TextBlock FontSize="26" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- ISSUE FORM -->
			<Border Padding="24" Background="#202633" CornerRadius="12">
				<StackPanel Spacing="16">

					<TextBlock FontSize="20" FontWeight="Bold" Text="Issue Stock"/>

					<Grid ColumnDefinitions="*,16,140,16,180,16,Auto">

						<StackPanel Grid.Column="0" Spacing="6">
							<TextBlock FontSize="12" Foreground="#9CA3AF" Text="ITEM"/>
							<ComboBox
                                ItemsSource="{Binding AvailableItems}"
                                SelectedItem="{Binding SelectedItem}"
                                HorizontalAlignment="Stretch"
                                Padding="10,8"
                                Background="#2B3242"
                                BorderBrush="#374151"/>
						</StackPanel>

						<StackPanel Grid.Column="2" Spacing="6">
							<TextBlock FontSize="12" Foreground="#9CA3AF" Text="QUANTITY"/>
							<TextBox
                                Text="{Binding IssueQuantity}"
                                Padding="10,8"
                                Background="#2B3242"
                                BorderBrush="#374151"
                                BorderThickness="1"
                                CornerRadius="8"/>
						</StackPanel>

						<StackPanel Grid.Column="4" Spacing="6">
							<TextBlock FontSize="12" Foreground="#9CA3AF" Text="REASON"/>
							<ComboBox
                                ItemsSource="{Binding IssueReasons}"
                                SelectedItem="{Binding IssueReason}"
                                HorizontalAlignment="Stretch"
                                Padding="10,8"
                                Background="#2B3242"
                                BorderBrush="#374151"/>
						</StackPanel>

						<Button Grid.Column="6"
                            Padding="18,12"
                            Background="#F97316" CornerRadius="8"
                            VerticalAlignment="Bottom"
                            Command="{Binding IssueStockCommand}"
                            Content="📤  Issue"/>

					</Grid>

					<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Padding="14,10" Background="#2B3242" CornerRadius="8">
						<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
					</Border>

				</StackPanel>
			</Border>

			<!-- CURRENT STOCK -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Available Stock" Margin="0,0,0,16"/>

					<ItemsControl ItemsSource="{Binding CurrentStock}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="14" Background="#2B3242" CornerRadius="8">
									<Grid ColumnDefinitions="*,Auto">
										<StackPanel Grid.Column="0" Spacing="5">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock FontWeight="Bold" FontSize="14"
                                                    Text="{Binding Name}" VerticalAlignment="Center"/>
												<Border IsVisible="{Binding IsLow}"
                                                        Background="#7F1D1D" CornerRadius="4" Padding="6,2">
													<TextBlock Text="LOW" FontSize="9"
                                                        FontWeight="Bold" Foreground="#FCA5A5"/>
												</Border>
											</StackPanel>
											<StackPanel Orientation="Horizontal" Spacing="8">
												<ProgressBar Value="{Binding FillPercent}" Maximum="1.0"
                                                    Height="6" Width="260" Foreground="#F97316"
                                                    VerticalAlignment="Center"/>
												<TextBlock FontSize="11" Foreground="#6B7280"
                                                    Text="{Binding FillPercent, StringFormat='{}{0:P0}'}"/>
											</StackPanel>
										</StackPanel>
										<TextBlock Grid.Column="1" FontSize="24" FontWeight="Bold"
                                            Text="{Binding Quantity}" VerticalAlignment="Center"
                                            Margin="16,0,0,0"/>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

			<!-- ISSUE HISTORY -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Issue History" Margin="0,0,0,16"/>

					<TextBlock IsVisible="{Binding !History.Count}"
                        Text="No issues recorded yet." Foreground="#6B7280"/>

					<Grid ColumnDefinitions="*,100,80,120,110" Margin="14,0,14,8">
						<TextBlock Grid.Column="0" Text="ITEM" FontSize="11"
                            FontWeight="Bold" Foreground="#6B7280"/>
						<TextBlock Grid.Column="1" Text="ISSUED TO" FontSize="11"
                            FontWeight="Bold" Foreground="#6B7280"/>
						<TextBlock Grid.Column="2" Text="QTY" FontSize="11"
                            FontWeight="Bold" Foreground="#6B7280"/>
						<TextBlock Grid.Column="3" Text="REASON" FontSize="11"
                            FontWeight="Bold" Foreground="#6B7280"/>
						<TextBlock Grid.Column="4" Text="ISSUED AT" FontSize="11"
                            FontWeight="Bold" Foreground="#6B7280"/>
					</Grid>

					<ItemsControl ItemsSource="{Binding History}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,3" Padding="14,10" Background="#2B3242" CornerRadius="8">
									<Grid ColumnDefinitions="*,100,80,120,110">
										<TextBlock Grid.Column="0" FontWeight="SemiBold"
                                            Text="{Binding ItemName}" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="1" FontSize="12" Foreground="#6B7280"
                                            Text="{Binding IssuedTo}" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="2" FontSize="14" FontWeight="Bold"
                                            Text="{Binding Quantity}" VerticalAlignment="Center"/>
										<Border Grid.Column="3" Padding="7,2" CornerRadius="4"
                                                Background="#1F2937" VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
											<TextBlock FontSize="11" Foreground="#9CA3AF"
                                                Text="{Binding Reason}"/>
										</Border>
										<TextBlock Grid.Column="4" FontSize="11" Foreground="#6B7280"
                                            Text="{Binding IssuedAt}" VerticalAlignment="Center"/>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>