<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.WarehouseFlowView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Flow Management"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Warehouse layout optimization, cross-docking coordination, and movement history tracking."/>
			</StackPanel>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- DEPT HEALTH -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel Spacing="10">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Warehouse Health"/>
					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Efficiency" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Width="80" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding DeptEfficiency}" Maximum="100"
                            Height="10" Width="280" Foreground="{DynamicResource BrushDeptWarehouse}" VerticalAlignment="Center"/>
						<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Text="{Binding DeptEfficiency, StringFormat='{}{0}%'}"
                            VerticalAlignment="Center"/>
					</StackPanel>
					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Stress" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Width="80" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding DeptStress}" Maximum="100"
                            Height="10" Width="280" Foreground="{DynamicResource BrushDanger}" VerticalAlignment="Center"/>
						<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Text="{Binding DeptStress, StringFormat='{}{0}%'}"
                            VerticalAlignment="Center"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- ACTIONS -->
			<WrapPanel ItemSpacing="10">
				<Button Padding="14" Margin="0,5" Background="{DynamicResource BrushDeptWarehouse}" CornerRadius="8"
                    Command="{Binding OptimizeFlowCommand}"
                    Content="⚡  Optimize Flow (+10 Eff, −10 Stress)"/>
				<Button Padding="14" Margin="0,5" Background="{DynamicResource BrushBorderStrong}" CornerRadius="8"
                    Command="{Binding ClearBottlenecksCommand}"
                    Content="🔓  Clear Bottlenecks"/>
			</WrapPanel>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- INVENTORY FLOW OVERVIEW -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Inventory Flow" Margin="0,0,0,16"/>

					<ItemsControl ItemsSource="{Binding Inventory}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="14" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,100,100,80">

										<StackPanel Grid.Column="0" Spacing="4">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock FontWeight="Bold" FontSize="14"
                                                    Text="{Binding Name}" VerticalAlignment="Center"/>
												<Border IsVisible="{Binding IsLow}"
                                                        Background="{DynamicResource BrushAlertCriticalBg}" CornerRadius="4" Padding="6,2">
													<TextBlock Text="LOW" FontSize="9"
                                                        FontWeight="Bold" Foreground="{DynamicResource BrushBadgeDangerFg}"/>
												</Border>
											</StackPanel>
											<StackPanel Orientation="Horizontal" Spacing="8">
												<ProgressBar Value="{Binding FillPercent}" Maximum="1.0"
                                                    Height="6" Width="200" Foreground="{DynamicResource BrushDeptWarehouse}"
                                                    VerticalAlignment="Center"/>
												<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding FillPercent, StringFormat='{}{0:P0}'}"/>
											</StackPanel>
										</StackPanel>

										<StackPanel Grid.Column="1" VerticalAlignment="Center">
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Text="In Stock"/>
											<TextBlock FontSize="18" FontWeight="Bold"
                                                Text="{Binding Quantity}"/>
										</StackPanel>

										<StackPanel Grid.Column="2" VerticalAlignment="Center">
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Text="Min"/>
											<TextBlock FontSize="18" FontWeight="Bold"
                                                Text="{Binding MinimumStock}" Foreground="{DynamicResource BrushTextSecondary}"/>
										</StackPanel>

										<StackPanel Grid.Column="3" VerticalAlignment="Center">
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Text="Max"/>
											<TextBlock FontSize="18" FontWeight="Bold"
                                                Text="{Binding MaximumStock}" Foreground="{DynamicResource BrushTextSecondary}"/>
										</StackPanel>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

			<!-- FLOW LOG -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Movement Log" Margin="0,0,0,12"/>

					<TextBlock IsVisible="{Binding !FlowLog.Count}"
                        Text="No flow events recorded yet." Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding FlowLog}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,3" Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="80,*,100,100,100">
										<Border Grid.Column="0" Padding="7,2" CornerRadius="4"
                                                Background="{DynamicResource BrushBgInput}" VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
											<TextBlock FontSize="11" FontWeight="Bold"
                                                Foreground="{DynamicResource BrushDeptWarehouse}" Text="{Binding Direction}"/>
										</Border>
										<TextBlock Grid.Column="1" FontWeight="SemiBold"
                                            Text="{Binding ItemName}" VerticalAlignment="Center"
                                            Margin="8,0"/>
										<TextBlock Grid.Column="2" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                            Text="{Binding Source}" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="3" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                            Text="{Binding Destination}" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="4" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"
                                            Text="{Binding Timestamp}" VerticalAlignment="Center"
                                            HorizontalAlignment="Right"/>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>