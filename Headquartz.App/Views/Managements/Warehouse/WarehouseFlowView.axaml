<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.WarehouseFlowView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<TextBlock FontSize="34" FontWeight="Bold" Text="Flow Management"/>
			<TextBlock FontSize="13" Foreground="#6B7280"
                Text="Monitor the movement of goods through the warehouse and resolve bottlenecks."/>

			<!-- KPIs -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="180" Margin="8" Padding="18" Background="#202633" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="#9CA3AF" Text="{Binding Title}"/>
								<TextBlock FontSize="26" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- DEPT HEALTH -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel Spacing="10">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Warehouse Health"/>
					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Efficiency" FontSize="12" Foreground="#9CA3AF"
                            Width="80" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding DeptEfficiency}" Maximum="100"
                            Height="10" Width="280" Foreground="#F97316" VerticalAlignment="Center"/>
						<TextBlock FontSize="12" Foreground="#9CA3AF"
                            Text="{Binding DeptEfficiency, StringFormat='{}{0}%'}"
                            VerticalAlignment="Center"/>
					</StackPanel>
					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Stress" FontSize="12" Foreground="#9CA3AF"
                            Width="80" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding DeptStress}" Maximum="100"
                            Height="10" Width="280" Foreground="#EF4444" VerticalAlignment="Center"/>
						<TextBlock FontSize="12" Foreground="#9CA3AF"
                            Text="{Binding DeptStress, StringFormat='{}{0}%'}"
                            VerticalAlignment="Center"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- ACTIONS -->
			<WrapPanel>
				<Button Padding="14" Margin="10" Background="#F97316" CornerRadius="8"
                    Command="{Binding OptimizeFlowCommand}"
                    Content="⚡  Optimize Flow (+10 Eff, −10 Stress)"/>
				<Button Padding="14" Margin="10" Background="#374151" CornerRadius="8"
                    Command="{Binding ClearBottlenecksCommand}"
                    Content="🔓  Clear Bottlenecks"/>
			</WrapPanel>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="#2B3242" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- INVENTORY FLOW OVERVIEW -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Inventory Flow" Margin="0,0,0,16"/>

					<ItemsControl ItemsSource="{Binding Inventory}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="14" Background="#2B3242" CornerRadius="8">
									<Grid ColumnDefinitions="*,100,100,80">

										<StackPanel Grid.Column="0" Spacing="4">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock FontWeight="Bold" FontSize="14"
                                                    Text="{Binding Name}" VerticalAlignment="Center"/>
												<Border IsVisible="{Binding IsLow}"
                                                        Background="#7F1D1D" CornerRadius="4" Padding="6,2">
													<TextBlock Text="LOW" FontSize="9"
                                                        FontWeight="Bold" Foreground="#FCA5A5"/>
												</Border>
											</StackPanel>
											<StackPanel Orientation="Horizontal" Spacing="8">
												<ProgressBar Value="{Binding FillPercent}" Maximum="1.0"
                                                    Height="6" Width="200" Foreground="#F97316"
                                                    VerticalAlignment="Center"/>
												<TextBlock FontSize="11" Foreground="#6B7280"
                                                    Text="{Binding FillPercent, StringFormat='{}{0:P0}'}"/>
											</StackPanel>
										</StackPanel>

										<StackPanel Grid.Column="1" VerticalAlignment="Center">
											<TextBlock FontSize="11" Foreground="#6B7280" Text="In Stock"/>
											<TextBlock FontSize="18" FontWeight="Bold"
                                                Text="{Binding Quantity}"/>
										</StackPanel>

										<StackPanel Grid.Column="2" VerticalAlignment="Center">
											<TextBlock FontSize="11" Foreground="#6B7280" Text="Min"/>
											<TextBlock FontSize="18" FontWeight="Bold"
                                                Text="{Binding MinimumStock}" Foreground="#9CA3AF"/>
										</StackPanel>

										<StackPanel Grid.Column="3" VerticalAlignment="Center">
											<TextBlock FontSize="11" Foreground="#6B7280" Text="Max"/>
											<TextBlock FontSize="18" FontWeight="Bold"
                                                Text="{Binding MaximumStock}" Foreground="#9CA3AF"/>
										</StackPanel>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

			<!-- FLOW LOG -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Movement Log" Margin="0,0,0,12"/>

					<TextBlock IsVisible="{Binding !FlowLog.Count}"
                        Text="No flow events recorded yet." Foreground="#6B7280"/>

					<ItemsControl ItemsSource="{Binding FlowLog}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,3" Padding="14,10" Background="#2B3242" CornerRadius="8">
									<Grid ColumnDefinitions="80,*,100,100,100">
										<Border Grid.Column="0" Padding="7,2" CornerRadius="4"
                                                Background="#1F2937" VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
											<TextBlock FontSize="11" FontWeight="Bold"
                                                Foreground="#F97316" Text="{Binding Direction}"/>
										</Border>
										<TextBlock Grid.Column="1" FontWeight="SemiBold"
                                            Text="{Binding ItemName}" VerticalAlignment="Center"
                                            Margin="8,0"/>
										<TextBlock Grid.Column="2" FontSize="12" Foreground="#6B7280"
                                            Text="{Binding Source}" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="3" FontSize="12" Foreground="#6B7280"
                                            Text="{Binding Destination}" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="4" FontSize="11" Foreground="#4B5563"
                                            Text="{Binding Timestamp}" VerticalAlignment="Center"
                                            HorizontalAlignment="Right"/>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>