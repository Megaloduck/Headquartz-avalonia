<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.WarehouseDashboardView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Warehouse Dashboard"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Warehouse department overview, Inventory inbound/outbound status, and warehouse utilization."/>
			</StackPanel>

			<!-- LOW STOCK BANNER -->
			<Border IsVisible="{Binding HasLowStock}" Background="{DynamicResource BrushWarning}" CornerRadius="12" Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="📦" FontSize="22" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock
                            Text="{Binding LowStockCount, StringFormat={}{0} ITEM(S) BELOW MINIMUM STOCK}"
                            FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrushWarning}"/>
						<TextBlock Text="Production and logistics may be blocked. Emergency restock recommended." Foreground="{DynamicResource BrushWarning}"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- ACTIONS -->
			<WrapPanel ItemSpacing="10">
				<Button Padding="14" Margin="0,5" Command="{Binding EmergencyRestockCommand}"    Content="📥  Emergency Restock"/>
				<Button Padding="14" Margin="0,5" Command="{Binding ReorganizeWarehouseCommand}" Content="🔄  Reorganize (−15% Stress)"/>
			</WrapPanel>

			<!-- INVENTORY LIST -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Inventory" Margin="0,0,0,16"/>
					<ItemsControl ItemsSource="{Binding Inventory}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,6" Padding="16" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<StackPanel Spacing="10">

										<Grid ColumnDefinitions="*,Auto,Auto">
											<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
												<TextBlock FontSize="16" FontWeight="Bold" Text="{Binding Name}" VerticalAlignment="Center"/>
												<!-- Low stock warning -->
												<Border
                                                    IsVisible="{Binding IsLow}"
                                                    Background="{DynamicResource BrushAlertCriticalBg}"
                                                    CornerRadius="6"
                                                    Padding="6,2"
                                                    VerticalAlignment="Center">
													<TextBlock Text="LOW" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrushBadgeDangerFg}"/>
												</Border>
											</StackPanel>
											<TextBlock
                                                Grid.Column="1"
                                                Margin="16,0,0,0"
                                                FontSize="20"
                                                FontWeight="Bold"
                                                Text="{Binding Quantity}"
                                                VerticalAlignment="Center"/>
											<TextBlock
                                                Grid.Column="2"
                                                Margin="8,0,0,0"
                                                FontSize="12"
                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="units"
                                                VerticalAlignment="Center"/>
										</Grid>

										<!-- Stock level bar -->
										<StackPanel Orientation="Horizontal" Spacing="8">
											<ProgressBar
                                                Value="{Binding FillPercent}"
                                                Maximum="1.0"
                                                Height="8"
                                                Width="320"
                                                Foreground="{DynamicResource BrushDeptWarehouse}"
                                                VerticalAlignment="Center"/>
											<TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding FillPercent, StringFormat={}{0:P0}}"
                                                VerticalAlignment="Center"/>
										</StackPanel>

										<!-- Min / Max / Cost -->
										<StackPanel Orientation="Horizontal" Spacing="20">
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding MinimumStock, StringFormat='Min: {0}'}"/>
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding MaximumStock, StringFormat='Max: {0}'}"/>
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding UnitCost, StringFormat='Cost: ${0}/unit'}"/>
										</StackPanel>

									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

			<!-- EVENTS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Warehouse Alerts" Margin="0,0,0,12"/>
					<TextBlock IsVisible="{Binding !Events.Count}" Text="No active alerts." Foreground="{DynamicResource BrushTextSecondary}"/>
					<ItemsControl ItemsSource="{Binding Events}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,6" Padding="14" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<StackPanel>
										<TextBlock FontSize="15" FontWeight="Bold" Text="{Binding Title}"/>
										<TextBlock Margin="0,4" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Description}" TextWrapping="Wrap"/>
										<StackPanel Orientation="Horizontal" Spacing="16" Margin="0,6,0,0">
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushDeptWarehouse}"
                                                Text="{Binding Severity, StringFormat='Severity: {0}'}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding RemainingTicks, StringFormat='Ticks left: {0}'}"/>
										</StackPanel>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>
