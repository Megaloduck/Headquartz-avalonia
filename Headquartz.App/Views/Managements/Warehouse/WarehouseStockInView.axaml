<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.WarehouseStockInView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Stock In"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Receive goods, quality checks, put-away management, and supplier receipts."/>
			</StackPanel>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- RECEIVE FORM -->
			<Border Padding="24" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel Spacing="16">

					<TextBlock FontSize="20" FontWeight="Bold" Text="Receive Shipment"/>

					<Grid ColumnDefinitions="*,20,160,20,Auto">

						<StackPanel Grid.Column="0" Spacing="6">
							<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="ITEM"/>
							<ComboBox
                                ItemsSource="{Binding AvailableItems}"
                                SelectedItem="{Binding SelectedItem}"
                                HorizontalAlignment="Stretch"
                                Padding="10,8"
                                Background="{DynamicResource BrushBgNested}"
                                BorderBrush="{DynamicResource BrushBorderStrong}"/>
						</StackPanel>

						<StackPanel Grid.Column="2" Spacing="6">
							<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="QUANTITY"/>
							<TextBox
                                Text="{Binding OrderQuantity}"
                                Padding="10,8"
                                Background="{DynamicResource BrushBgNested}"
                                BorderBrush="{DynamicResource BrushBorderStrong}"
                                BorderThickness="1"
                                CornerRadius="8"/>
						</StackPanel>

						<Button Grid.Column="4"
                            Padding="18,12"
                            Background="{DynamicResource BrushSuccess}" CornerRadius="8"
                            VerticalAlignment="Bottom"
                            Command="{Binding ReceiveStockCommand}"
                            Content="📥  Receive"/>

					</Grid>

					<Button Padding="14,9" Background="{DynamicResource BrushBorderStrong}" CornerRadius="8"
                        HorizontalAlignment="Left"
                        Command="{Binding RestockAllCommand}"
                        Content="🔄  Restock All Low Items"/>

					<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
						<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
					</Border>

				</StackPanel>
			</Border>

			<!-- CURRENT STOCK LEVELS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Current Stock" Margin="0,0,0,16"/>

					<ItemsControl ItemsSource="{Binding CurrentStock}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="14" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,Auto">

										<StackPanel Grid.Column="0" Spacing="6">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock FontWeight="Bold" FontSize="14"
                                                    Text="{Binding Name}" VerticalAlignment="Center"/>
												<Border IsVisible="{Binding IsLow}"
                                                        Background="{DynamicResource BrushAlertCriticalBg}" CornerRadius="4" Padding="6,2">
													<TextBlock Text="LOW" FontSize="9"
                                                        FontWeight="Bold" Foreground="{DynamicResource BrushBadgeDangerFg}"/>
												</Border>
											</StackPanel>
											<StackPanel Orientation="Horizontal" Spacing="8">
												<ProgressBar Value="{Binding FillPercent}" Maximum="1.0"
                                                    Height="6" Width="260" Foreground="{DynamicResource BrushDeptWarehouse}"
                                                    VerticalAlignment="Center"/>
												<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding FillPercent, StringFormat='{}{0:P0}'}"/>
											</StackPanel>
											<StackPanel Orientation="Horizontal" Spacing="16">
												<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding MinimumStock, StringFormat='Min: {0}'}"/>
												<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding MaximumStock, StringFormat='Max: {0}'}"/>
												<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding UnitCost, StringFormat='${0}/unit'}"/>
											</StackPanel>
										</StackPanel>

										<StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                    HorizontalAlignment="Right" Margin="16,0,0,0">
											<TextBlock FontSize="24" FontWeight="Bold"
                                                Text="{Binding Quantity}" HorizontalAlignment="Right"/>
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="units" HorizontalAlignment="Right"/>
										</StackPanel>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

			<!-- RECEIPT HISTORY -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Receipt History" Margin="0,0,0,16"/>

					<TextBlock IsVisible="{Binding !History.Count}"
                        Text="No receipts recorded yet." Foreground="{DynamicResource BrushTextSecondary}"/>

					<Grid ColumnDefinitions="*,100,80,100,120" Margin="14,0,14,8">
						<TextBlock Grid.Column="0" Text="ITEM" FontSize="11"
                            FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="1" Text="SUPPLIER" FontSize="11"
                            FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="2" Text="QTY" FontSize="11"
                            FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="3" Text="COST" FontSize="11"
                            FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="4" Text="RECEIVED" FontSize="11"
                            FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
					</Grid>

					<ItemsControl ItemsSource="{Binding History}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,3" Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,100,80,100,120">
										<TextBlock Grid.Column="0" FontWeight="SemiBold"
                                            Text="{Binding ItemName}" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                            Text="{Binding Supplier}" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="2" FontSize="14" FontWeight="Bold"
                                            Text="{Binding Quantity}" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="3" Foreground="{DynamicResource BrushDanger}"
                                            Text="{Binding TotalCost, StringFormat='${0:N0}'}"
                                            VerticalAlignment="Center"/>
										<TextBlock Grid.Column="4" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                            Text="{Binding ReceivedAt}" VerticalAlignment="Center"/>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>