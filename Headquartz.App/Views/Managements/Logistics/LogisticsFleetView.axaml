<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.LogisticsFleetView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- Header -->
			<StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Fleet Management"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Driver assignments, vehicle maintenance, fuel tracking, and compliance checks."/>
			</StackPanel>	

			
			<!-- MAINTENANCE BANNER -->
			<Border IsVisible="{Binding MaintenanceVehicles}"
                    Background="{DynamicResource BrushWarning}" CornerRadius="12" Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="🚛" FontSize="22" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock
                            Text="{Binding MaintenanceVehicles, StringFormat='{}{0} VEHICLE(S) NEED SERVICING'}"
                            FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrushWarning}"/>
						<TextBlock Text="Vehicles in poor condition reduce delivery capacity and increase failure risk."
                            Foreground="{DynamicResource BrushWarning}"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- ACTIONS -->
			<WrapPanel ItemSpacing="10">
				<Button Padding="14" Margin="0,5" Background="{DynamicResource BrushAccentSecondary}" CornerRadius="8"
                    Command="{Binding ServiceAllCommand}"
                    Content="🔧  Service All Vehicles"/>
				<Button Padding="14" Margin="0,5" Background="{DynamicResource BrushAccentPrimary}" CornerRadius="8"
                    Command="{Binding AddVehicleCommand}"
                    Content="＋  Add Vehicle ($12,000)"/>
			</WrapPanel>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- FLEET LIST -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Fleet" Margin="0,0,0,16"/>

					<TextBlock IsVisible="{Binding !Fleet.Count}"
                        Text="No vehicles in fleet." Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding Fleet}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,6" Padding="18" Background="{DynamicResource BrushBgNested}" CornerRadius="10">
									<StackPanel Spacing="12">

										<!-- Header -->
										<Grid ColumnDefinitions="*,Auto,Auto">

											<StackPanel Grid.Column="0">
												<StackPanel Orientation="Horizontal" Spacing="8">
													<TextBlock FontWeight="Bold" FontSize="16"
                                                        Text="{Binding Name}" VerticalAlignment="Center"/>
													<Border Padding="8,3" CornerRadius="5"
                                                            Background="{DynamicResource BrushBgInput}" VerticalAlignment="Center">
														<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                            Text="{Binding Type}"/>
													</Border>
													<Border Padding="8,3" CornerRadius="5"
                                                            Background="{DynamicResource BrushAlertInfoBg}" VerticalAlignment="Center">
														<TextBlock FontSize="11" FontWeight="Bold"
                                                            Foreground="{DynamicResource BrushAccentSecondary}"
                                                            Text="{Binding Status}"/>
													</Border>
												</StackPanel>
												<StackPanel Orientation="Horizontal" Spacing="16">
													<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                        Text="{Binding ActiveDeliveries, StringFormat='Active deliveries: {0}'}"/>
													<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                        Text="{Binding LastServiced, StringFormat='Last serviced: {0}'}"/>
												</StackPanel>
											</StackPanel>

											<Button Grid.Column="1"
                                                Margin="8,0" Padding="12,7"
                                                Background="{DynamicResource BrushBorderStrong}" CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].DataContext.ServiceVehicleCommand}"
                                                CommandParameter="{Binding}"
                                                Content="{Binding MaintenanceCost, StringFormat='🔧 Service (${0:N0})'}"/>

											<Button Grid.Column="2"
                                                Padding="10,7"
                                                Background="{DynamicResource BrushBadgeDangerBg}" CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].DataContext.RetireVehicleCommand}"
                                                CommandParameter="{Binding}"
                                                Content="🗑 Retire"/>

										</Grid>

										<!-- Condition bar -->
										<StackPanel Spacing="4">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="Condition" FontSize="11"
                                                    Foreground="{DynamicResource BrushTextSecondary}" Width="70"
                                                    VerticalAlignment="Center"/>
												<ProgressBar Value="{Binding Condition}" Maximum="100"
                                                    Height="10" Width="300" Foreground="{DynamicResource BrushSuccess}"
                                                    VerticalAlignment="Center"/>
												<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding Condition, StringFormat='{}{0}%'}"
                                                    VerticalAlignment="Center"/>
											</StackPanel>
										</StackPanel>

									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>