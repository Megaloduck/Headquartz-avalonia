<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.LogisticsShipmentsView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<TextBlock FontSize="34" FontWeight="Bold" Text="Shipments"/>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="10" Padding="20" Background="#202633" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="#9CA3AF" Text="{Binding Title}"/>
								<TextBlock FontSize="26" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- ACTIONS + FILTER ROW -->
			<Grid ColumnDefinitions="Auto,*">

				<Button
                    Grid.Column="0"
                    Padding="14,9"
                    Background="#0E7490"
                    CornerRadius="8"
                    Command="{Binding ExpediteAllCommand}"
                    Content="⚡  Expedite All (−$800/order)"/>

				<ItemsControl Grid.Column="1" ItemsSource="{Binding Filters}" Margin="16,0,0,0">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Horizontal" Spacing="8"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Button
                                Padding="14,8"
                                CornerRadius="8"
                                Background="#202633"
                                Command="{Binding $parent[ItemsControl].DataContext.SetFilterCommand}"
                                CommandParameter="{Binding}"
                                Content="{Binding}"/>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

			</Grid>

			<!-- SHIPMENTS TABLE -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>

					<!-- Header -->
					<Grid ColumnDefinitions="*,120,110,120,Auto" Margin="14,0,14,8">
						<TextBlock Grid.Column="0" Text="CLIENT / PRODUCT" FontSize="11" FontWeight="Bold" Foreground="#6B7280"/>
						<TextBlock Grid.Column="1" Text="VALUE"            FontSize="11" FontWeight="Bold" Foreground="#6B7280"/>
						<TextBlock Grid.Column="2" Text="STATUS"           FontSize="11" FontWeight="Bold" Foreground="#6B7280"/>
						<TextBlock Grid.Column="3" Text="DEADLINE"         FontSize="11" FontWeight="Bold" Foreground="#6B7280"/>
						<TextBlock Grid.Column="4" Text="ACTION"           FontSize="11" FontWeight="Bold" Foreground="#6B7280"/>
					</Grid>

					<TextBlock
                        IsVisible="{Binding !Shipments.Count}"
                        Text="No shipments match this filter."
                        Foreground="#6B7280"
                        Margin="14,8"/>

					<ItemsControl ItemsSource="{Binding Shipments}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,3" Padding="14,12" Background="#2B3242" CornerRadius="8">
									<Grid ColumnDefinitions="*,120,110,120,Auto">

										<StackPanel Grid.Column="0">
											<TextBlock FontWeight="SemiBold" Text="{Binding ClientName}"/>
											<TextBlock FontSize="12" Foreground="#6B7280" Text="{Binding ProductName}"/>
										</StackPanel>

										<TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Revenue, StringFormat='${0:N0}'}"
                                            Foreground="#06B6D4"
                                            VerticalAlignment="Center"/>

										<Border
                                            Grid.Column="2"
                                            Padding="8,3"
                                            CornerRadius="6"
                                            Background="#1F2937"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
											<TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="#9CA3AF"
                                                Text="{Binding Status}"/>
										</Border>

										<StackPanel Grid.Column="3" VerticalAlignment="Center">
											<TextBlock FontSize="11" Text="{Binding Deadline}" Foreground="#6B7280"/>
											<TextBlock
                                                FontSize="11" FontWeight="Bold"
                                                Text="⚠ OVERDUE"
                                                Foreground="#EF4444"
                                                IsVisible="{Binding IsOverdue}"/>
										</StackPanel>

										<Button
                                            Grid.Column="4"
                                            Padding="10,6"
                                            FontSize="11"
                                            Background="#0E7490"
                                            CornerRadius="6"
                                            VerticalAlignment="Center"
                                            Command="{Binding $parent[ItemsControl].DataContext.ExpediteShipmentCommand}"
                                            CommandParameter="{Binding}"
                                            Content="⚡ Expedite"/>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>