<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.LogisticsRoutesView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- Header -->
			<StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Route Planner"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Path optimization, delivery sequencing, vehicle allocation, and fuel efficiency."/>	
			</StackPanel>		

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- ACTIONS -->
			<WrapPanel ItemSpacing="10">
				<Button Padding="14" Margin="0,5" Background="{DynamicResource BrushAccentSecondary}" CornerRadius="8"
                    Command="{Binding OptimizeAllRoutesCommand}"
                    Content="🗺  Optimize All Routes ($5,000)"/>
				<Button Padding="14" Margin="0,5" Background="{DynamicResource BrushAccentPrimary}" CornerRadius="8"
                    Command="{Binding AddRouteCommand}"
                    Content="＋  Add Route ($8,000)"/>
			</WrapPanel>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- ROUTES LIST -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Delivery Routes" Margin="0,0,0,16"/>

					<TextBlock IsVisible="{Binding !Routes.Count}"
                        Text="No routes configured." Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding Routes}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,6" Padding="18" Background="{DynamicResource BrushBgNested}" CornerRadius="10">
									<StackPanel Spacing="12">

										<!-- Header -->
										<Grid ColumnDefinitions="*,Auto,Auto,Auto">

											<StackPanel Grid.Column="0">
												<StackPanel Orientation="Horizontal" Spacing="8">
													<TextBlock FontWeight="Bold" FontSize="16"
                                                        Text="{Binding Name}" VerticalAlignment="Center"/>
													<Border Padding="8,3" CornerRadius="5"
                                                            Background="{DynamicResource BrushBgInput}" VerticalAlignment="Center">
														<TextBlock FontSize="11" FontWeight="Bold"
                                                            Text="{Binding Status}" Foreground="{DynamicResource BrushTextSecondary}"/>
													</Border>
												</StackPanel>
												<StackPanel Orientation="Horizontal" Spacing="8">
													<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                        Text="{Binding Origin}"/>
													<TextBlock FontSize="12" Foreground="{DynamicResource BrushBorderStrong}"
                                                        Text="→"/>
													<TextBlock FontSize="12" Foreground="{DynamicResource BrushAccentSecondary}"
                                                        Text="{Binding Destination}"/>
													<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextMuted}"
                                                        Text="{Binding EstimatedTime, StringFormat='· {0}'}"/>
												</StackPanel>
											</StackPanel>

											<Button Grid.Column="1"
                                                Margin="8,0" Padding="10,6"
                                                Background="{DynamicResource BrushAccentSecondary}" CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].DataContext.OptimizeRouteCommand}"
                                                CommandParameter="{Binding}"
                                                Content="⚡ Optimize ($1.5k)"/>

											<Button Grid.Column="2"
                                                Margin="4,0" Padding="10,6"
                                                Background="{DynamicResource BrushBorderStrong}" CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].DataContext.SuspendRouteCommand}"
                                                CommandParameter="{Binding}"
                                                Content="⛔ Suspend"/>

										</Grid>

										<!-- Stats -->
										<Grid ColumnDefinitions="*,*,*,*">

											<StackPanel Grid.Column="0" Spacing="4">
												<TextBlock Text="Efficiency" FontSize="11"
                                                    Foreground="{DynamicResource BrushTextSecondary}"/>
												<ProgressBar Value="{Binding Efficiency}" Maximum="100"
                                                    Height="7" Foreground="{DynamicResource BrushAccentSecondary}"/>
												<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding Efficiency, StringFormat='{}{0}%'}"/>
											</StackPanel>

											<StackPanel Grid.Column="1" Spacing="4" Margin="16,0,0,0">
												<TextBlock Text="Active Shipments" FontSize="11"
                                                    Foreground="{DynamicResource BrushTextSecondary}"/>
												<TextBlock FontSize="18" FontWeight="Bold"
                                                    Text="{Binding ActiveShipments}"/>
											</StackPanel>

											<StackPanel Grid.Column="2" Spacing="4" Margin="16,0,0,0">
												<TextBlock Text="Cost/Shipment" FontSize="11"
                                                    Foreground="{DynamicResource BrushTextSecondary}"/>
												<TextBlock FontSize="18" FontWeight="Bold"
                                                    Foreground="{DynamicResource BrushDanger}"
                                                    Text="{Binding CostPerShipment, StringFormat='${0:N0}'}"/>
											</StackPanel>

											<StackPanel Grid.Column="3" Spacing="4" Margin="16,0,0,0">
												<TextBlock Text="Est. Time" FontSize="11"
                                                    Foreground="{DynamicResource BrushTextSecondary}"/>
												<TextBlock FontSize="18" FontWeight="Bold"
                                                    Text="{Binding EstimatedTime}"/>
											</StackPanel>

										</Grid>

									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>