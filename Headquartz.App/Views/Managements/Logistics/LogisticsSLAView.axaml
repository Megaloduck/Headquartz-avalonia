<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.LogisticsSLAView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<TextBlock FontSize="34" FontWeight="Bold" Text="SLA Management"/>
			<TextBlock FontSize="13" Foreground="#6B7280"
                Text="Monitor service level agreements and take action before breaches occur."/>

			<!-- BREACH BANNER -->
			<Border IsVisible="{Binding Breached}"
                    Background="#7F1D1D" CornerRadius="12" Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="⚠" FontSize="22" Foreground="#FCA5A5" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock
                            Text="{Binding Breached, StringFormat='{}{0} SLA BREACH(ES) — PENALTIES ACTIVE'}"
                            FontSize="16" FontWeight="Bold" Foreground="#FCA5A5"/>
						<TextBlock
                            Text="{Binding TotalPenalties, StringFormat='Total penalties accrued: ${0:N0}'}"
                            Foreground="#FCA5A5"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- AT RISK BANNER -->
			<Border IsVisible="{Binding AtRisk}"
                    Background="#78350F" CornerRadius="12" Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="⏱" FontSize="22" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock
                            Text="{Binding AtRisk, StringFormat='{}{0} ORDER(S) AT RISK — DEADLINE IN 5 TICKS'}"
                            FontSize="16" FontWeight="Bold" Foreground="#FDE68A"/>
						<TextBlock Text="Expedite these orders immediately to avoid SLA breach."
                            Foreground="#FDE68A"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- KPIs -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="180" Margin="8" Padding="18" Background="#202633" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="#9CA3AF" Text="{Binding Title}"/>
								<TextBlock FontSize="26" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- ACTIONS -->
			<WrapPanel>
				<Button Padding="14" Margin="10" Background="#EF4444" CornerRadius="8"
                    Command="{Binding PayPenaltiesCommand}"
                    Content="💳  Pay All Penalties"/>
			</WrapPanel>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="#2B3242" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- SLA TABLE -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="SLA Status" Margin="0,0,0,16"/>

					<TextBlock IsVisible="{Binding !SLAs.Count}"
                        Text="No active SLAs. All orders delivered or no deadlines set."
                        Foreground="#6B7280"/>

					<ItemsControl ItemsSource="{Binding SLAs}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="16" Background="#2B3242" CornerRadius="8">
									<Grid ColumnDefinitions="*,100,100,100,Auto">

										<!-- Client + product -->
										<StackPanel Grid.Column="0">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock FontWeight="Bold" FontSize="14"
                                                    Text="{Binding ClientName}"
                                                    VerticalAlignment="Center"/>
												<Border IsVisible="{Binding IsBreach}"
                                                        Padding="6,2" Background="#7F1D1D"
                                                        CornerRadius="4" VerticalAlignment="Center">
													<TextBlock Text="BREACH" FontSize="9"
                                                        FontWeight="Bold" Foreground="#FCA5A5"/>
												</Border>
												<Border IsVisible="{Binding IsAtRisk}"
                                                        Padding="6,2" Background="#78350F"
                                                        CornerRadius="4" VerticalAlignment="Center">
													<TextBlock Text="AT RISK" FontSize="9"
                                                        FontWeight="Bold" Foreground="#FDE68A"/>
												</Border>
											</StackPanel>
											<TextBlock FontSize="12" Foreground="#6B7280"
                                                Text="{Binding ProductName}"/>
										</StackPanel>

										<!-- Deadline -->
										<StackPanel Grid.Column="1" VerticalAlignment="Center">
											<TextBlock FontSize="11" Foreground="#6B7280" Text="Deadline"/>
											<TextBlock FontSize="12" Text="{Binding Deadline}"
                                                Foreground="#9CA3AF"/>
										</StackPanel>

										<!-- Ticks left -->
										<StackPanel Grid.Column="2" VerticalAlignment="Center">
											<TextBlock FontSize="11" Foreground="#6B7280" Text="Ticks Left"/>
											<TextBlock FontSize="14" FontWeight="Bold"
                                                Text="{Binding TicksRemaining}"
                                                Foreground="#06B6D4"/>
										</StackPanel>

										<!-- Penalty -->
										<StackPanel Grid.Column="3" VerticalAlignment="Center">
											<TextBlock FontSize="11" Foreground="#6B7280" Text="Penalty"/>
											<TextBlock FontSize="13" FontWeight="Bold"
                                                Text="{Binding Penalty, StringFormat='${0:N0}'}"
                                                Foreground="#EF4444"/>
										</StackPanel>

										<!-- Expedite -->
										<Button Grid.Column="4"
                                            Padding="12,7" Background="#0E7490" CornerRadius="6"
                                            VerticalAlignment="Center"
                                            Command="{Binding $parent[ItemsControl].DataContext.ExpediteOrderCommand}"
                                            CommandParameter="{Binding}"
                                            Content="⚡ Expedite ($800)"/>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>