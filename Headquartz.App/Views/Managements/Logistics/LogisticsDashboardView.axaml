<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.LogisticsDashboardView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Logistics Dashboard"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Logistics department overview, delivery performance, carrier status, and cost overview."/>
			</StackPanel>

			<!-- OVERDUE BANNER -->
			<Border IsVisible="{Binding HasOverdue}" Background="{DynamicResource BrushAlertCriticalBg}" CornerRadius="12" Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="🚚" FontSize="22" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock
                            Text="{Binding OverdueShipments, StringFormat={}{0} SHIPMENT(S) PAST DEADLINE}"
                            FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrushBadgeDangerFg}"/>
						<TextBlock Text="These deliveries are damaging reputation every tick." Foreground="{DynamicResource BrushBadgeDangerFg}"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- DEPT HEALTH -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel Spacing="10">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Department Health"/>
					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Efficiency" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Width="80"/>
						<ProgressBar Value="{Binding DeptEfficiency}" Maximum="100" Height="10" Width="260" Foreground="{DynamicResource BrushAccentSecondary}" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding DeptEfficiency, StringFormat={}{0}%}" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"/>
					</StackPanel>
					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Stress" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Width="80"/>
						<ProgressBar Value="{Binding DeptStress}" Maximum="100" Height="10" Width="260" Foreground="{DynamicResource BrushDanger}" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding DeptStress, StringFormat={}{0}%}" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- ACTIONS -->
			<WrapPanel ItemSpacing="10">
				<Button Padding="14" Margin="0,5" Command="{Binding ExpediteShipmentsCommand}" Content="⚡  Expedite Shipments (−$800/order)"/>
				<Button Padding="14" Margin="0,5" Command="{Binding OptimizeRoutesCommand}"    Content="🗺  Optimize Routes (−20% Stress)"/>
			</WrapPanel>

			<!-- SHIPMENTS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Active Shipments" Margin="0,0,0,16"/>
					<TextBlock IsVisible="{Binding !Shipments.Count}" Text="No active shipments." Foreground="{DynamicResource BrushTextSecondary}"/>
					<ItemsControl ItemsSource="{Binding Shipments}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="14" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,120,100,110">
										<StackPanel Grid.Column="0">
											<TextBlock FontWeight="SemiBold" Text="{Binding ClientName}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding ProductName}"/>
										</StackPanel>
										<TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Revenue, StringFormat='${0:N0}'}"
                                            Foreground="{DynamicResource BrushAccentSecondary}"
                                            VerticalAlignment="Center"/>
										<TextBlock
                                            Grid.Column="2"
                                            Text="{Binding Status}"
                                            FontSize="12"
                                            Foreground="{DynamicResource BrushTextSecondary}"
                                            VerticalAlignment="Center"/>
										<StackPanel Grid.Column="3" VerticalAlignment="Center">
											<TextBlock FontSize="11" Text="{Binding Deadline}" Foreground="{DynamicResource BrushTextSecondary}"/>
											<TextBlock FontSize="11" FontWeight="Bold" Text="OVERDUE"
                                                Foreground="{DynamicResource BrushDanger}" IsVisible="{Binding IsOverdue}"/>
										</StackPanel>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

			<!-- EVENTS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Logistics Alerts" Margin="0,0,0,12"/>
					<TextBlock IsVisible="{Binding !Events.Count}" Text="No active alerts." Foreground="{DynamicResource BrushTextSecondary}"/>
					<ItemsControl ItemsSource="{Binding Events}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,6" Padding="14" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<StackPanel>
										<TextBlock FontSize="15" FontWeight="Bold" Text="{Binding Title}"/>
										<TextBlock Margin="0,4" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Description}" TextWrapping="Wrap"/>
										<StackPanel Orientation="Horizontal" Spacing="16" Margin="0,6,0,0">
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushAccentSecondary}"
                                                Text="{Binding Severity, StringFormat='Severity: {0}'}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding RemainingTicks, StringFormat='Ticks left: {0}'}"/>
										</StackPanel>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>
