<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.LogisticsDashboardView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<TextBlock FontSize="34" FontWeight="Bold" Text="Logistics"/>

			<!-- OVERDUE BANNER -->
			<Border IsVisible="{Binding HasOverdue}" Background="#7F1D1D" CornerRadius="12" Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="🚚" FontSize="22" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock
                            Text="{Binding OverdueShipments, StringFormat={}{0} SHIPMENT(S) PAST DEADLINE}"
                            FontSize="16" FontWeight="Bold" Foreground="#FCA5A5"/>
						<TextBlock Text="These deliveries are damaging reputation every tick." Foreground="#FCA5A5"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- KPIs -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="220" Margin="10" Padding="20" Background="#202633" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="#9CA3AF" Text="{Binding Title}"/>
								<TextBlock FontSize="28" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- DEPT HEALTH -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel Spacing="10">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Department Health"/>
					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Efficiency" FontSize="12" Foreground="#9CA3AF" Width="80"/>
						<ProgressBar Value="{Binding DeptEfficiency}" Maximum="100" Height="10" Width="260" Foreground="#06B6D4" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding DeptEfficiency, StringFormat={}{0}%}" FontSize="12" Foreground="#9CA3AF"/>
					</StackPanel>
					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Stress" FontSize="12" Foreground="#9CA3AF" Width="80"/>
						<ProgressBar Value="{Binding DeptStress}" Maximum="100" Height="10" Width="260" Foreground="#EF4444" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding DeptStress, StringFormat={}{0}%}" FontSize="12" Foreground="#9CA3AF"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- ACTIONS -->
			<WrapPanel>
				<Button Padding="14" Margin="10" Command="{Binding ExpediteShipmentsCommand}" Content="⚡  Expedite Shipments (−$800/order)"/>
				<Button Padding="14" Margin="10" Command="{Binding OptimizeRoutesCommand}"    Content="🗺  Optimize Routes (−20% Stress)"/>
			</WrapPanel>

			<!-- SHIPMENTS -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Active Shipments" Margin="0,0,0,16"/>
					<TextBlock IsVisible="{Binding !Shipments.Count}" Text="No active shipments." Foreground="#6B7280"/>
					<ItemsControl ItemsSource="{Binding Shipments}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="14" Background="#2B3242" CornerRadius="8">
									<Grid ColumnDefinitions="*,120,100,110">
										<StackPanel Grid.Column="0">
											<TextBlock FontWeight="SemiBold" Text="{Binding ClientName}"/>
											<TextBlock FontSize="12" Foreground="#6B7280" Text="{Binding ProductName}"/>
										</StackPanel>
										<TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Revenue, StringFormat='${0:N0}'}"
                                            Foreground="#06B6D4"
                                            VerticalAlignment="Center"/>
										<TextBlock
                                            Grid.Column="2"
                                            Text="{Binding Status}"
                                            FontSize="12"
                                            Foreground="#9CA3AF"
                                            VerticalAlignment="Center"/>
										<StackPanel Grid.Column="3" VerticalAlignment="Center">
											<TextBlock FontSize="11" Text="{Binding Deadline}" Foreground="#6B7280"/>
											<TextBlock FontSize="11" FontWeight="Bold" Text="OVERDUE"
                                                Foreground="#EF4444" IsVisible="{Binding IsOverdue}"/>
										</StackPanel>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

			<!-- EVENTS -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Logistics Alerts" Margin="0,0,0,12"/>
					<TextBlock IsVisible="{Binding !Events.Count}" Text="No active alerts." Foreground="#6B7280"/>
					<ItemsControl ItemsSource="{Binding Events}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,6" Padding="14" Background="#2B3242" CornerRadius="8">
									<StackPanel>
										<TextBlock FontSize="15" FontWeight="Bold" Text="{Binding Title}"/>
										<TextBlock Margin="0,4" Foreground="#9CA3AF" Text="{Binding Description}" TextWrapping="Wrap"/>
										<StackPanel Orientation="Horizontal" Spacing="16" Margin="0,6,0,0">
											<TextBlock FontSize="12" Foreground="#06B6D4"
                                                Text="{Binding Severity, StringFormat='Severity: {0}'}"/>
											<TextBlock FontSize="12" Foreground="#6B7280"
                                                Text="{Binding RemainingTicks, StringFormat='Ticks left: {0}'}"/>
										</StackPanel>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>
