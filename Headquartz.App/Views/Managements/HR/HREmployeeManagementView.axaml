<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.HREmployeeManagementView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<TextBlock FontSize="34" FontWeight="Bold" Text="Employee Management"/>

			<!-- SUMMARY ROW -->
			<WrapPanel>
				<Border Width="200" Margin="10" Padding="20" Background="#202633" CornerRadius="12">
					<StackPanel>
						<TextBlock FontSize="13" Foreground="#9CA3AF" Text="Total Employees"/>
						<TextBlock FontSize="28" FontWeight="Bold" Text="{Binding TotalEmployees}"/>
					</StackPanel>
				</Border>
				<Border Width="200" Margin="10" Padding="20" Background="#202633" CornerRadius="12">
					<StackPanel>
						<TextBlock FontSize="13" Foreground="#9CA3AF" Text="At-Risk Employees"/>
						<TextBlock FontSize="28" FontWeight="Bold" Text="{Binding AtRiskCount}"/>
					</StackPanel>
				</Border>
				<Border Width="200" Margin="10" Padding="20" Background="#202633" CornerRadius="12">
					<StackPanel>
						<TextBlock FontSize="13" Foreground="#9CA3AF" Text="Monthly Payroll"/>
						<TextBlock FontSize="28" FontWeight="Bold" Text="{Binding TotalPayroll, StringFormat='${0:N0}'}"/>
					</StackPanel>
				</Border>
			</WrapPanel>

			<!-- FILTER -->
			<StackPanel Orientation="Horizontal" Spacing="12">
				<TextBlock Text="Filter by Department:" VerticalAlignment="Center" Foreground="#9CA3AF"/>
				<ComboBox
                    ItemsSource="{Binding DepartmentFilters}"
                    SelectedItem="{Binding FilterDepartment}"
                    MinWidth="180"/>
			</StackPanel>

			<!-- EMPLOYEE LIST -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Employees" Margin="0,0,0,16"/>

					<TextBlock
                        IsVisible="{Binding !Employees.Count}"
                        Text="No employees found."
                        Foreground="#6B7280"/>

					<ItemsControl ItemsSource="{Binding Employees}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border
                                    Margin="0,5" Padding="16"
                                    Background="#2B3242"
                                    CornerRadius="8">
									<StackPanel Spacing="10">

										<!-- Name row -->
										<Grid ColumnDefinitions="*,Auto,Auto">
											<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
												<TextBlock
                                                    FontSize="15"
                                                    FontWeight="Bold"
                                                    Text="{Binding Name}"
                                                    VerticalAlignment="Center"/>
												<Border
                                                    IsVisible="{Binding IsLowMorale}"
                                                    Background="#7F1D1D"
                                                    CornerRadius="6"
                                                    Padding="6,2"
                                                    VerticalAlignment="Center">
													<TextBlock
                                                        Text="AT RISK"
                                                        FontSize="10"
                                                        FontWeight="Bold"
                                                        Foreground="#FCA5A5"/>
												</Border>
												<Border
                                                    IsVisible="{Binding IsAssigned}"
                                                    Background="#1E3A5F"
                                                    CornerRadius="6"
                                                    Padding="6,2"
                                                    VerticalAlignment="Center">
													<TextBlock
                                                        Text="ON TASK"
                                                        FontSize="10"
                                                        FontWeight="Bold"
                                                        Foreground="#93C5FD"/>
												</Border>
											</StackPanel>

											<!-- Boost morale button -->
											<Button
                                                Grid.Column="1"
                                                Margin="8,0"
                                                Padding="10,6"
                                                FontSize="12"
                                                Background="#1F2937"
                                                CornerRadius="6"
                                                Command="{Binding $parent[ItemsControl].DataContext.BoostMoraleCommand}"
                                                CommandParameter="{Binding}"
                                                Content="💊 Boost (−$500)"/>

											<!-- Fire button -->
											<Button
                                                Grid.Column="2"
                                                Padding="10,6"
                                                FontSize="12"
                                                Background="#450A0A"
                                                CornerRadius="6"
                                                Command="{Binding $parent[ItemsControl].DataContext.FireEmployeeCommand}"
                                                CommandParameter="{Binding}"
                                                Content="🔥 Fire"/>
										</Grid>

										<!-- Dept + Role + Salary -->
										<StackPanel Orientation="Horizontal" Spacing="20">
											<TextBlock FontSize="12" Foreground="#6B7280"
                                                Text="{Binding Department}"/>
											<TextBlock FontSize="12" Foreground="#6B7280"
                                                Text="{Binding Role}"/>
											<TextBlock FontSize="12" Foreground="#6B7280"
                                                Text="{Binding Salary, StringFormat='${0:N0}/mo'}"/>
										</StackPanel>

										<!-- Morale bar -->
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="Morale" FontSize="11" Foreground="#9CA3AF" Width="70"/>
											<ProgressBar
                                                Value="{Binding Morale}"
                                                Maximum="100"
                                                Height="7"
                                                Width="200"
                                                Foreground="#8B5CF6"
                                                VerticalAlignment="Center"/>
											<TextBlock
                                                FontSize="11"
                                                Foreground="#9CA3AF"
                                                Text="{Binding MoraleStatus}"
                                                VerticalAlignment="Center"/>
										</StackPanel>

										<!-- Productivity bar -->
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="Productivity" FontSize="11" Foreground="#9CA3AF" Width="70"/>
											<ProgressBar
                                                Value="{Binding Productivity}"
                                                Maximum="100"
                                                Height="7"
                                                Width="200"
                                                Foreground="#10B981"
                                                VerticalAlignment="Center"/>
											<TextBlock
                                                FontSize="11"
                                                Foreground="#6B7280"
                                                Text="{Binding Productivity, StringFormat={}{0}%}"
                                                VerticalAlignment="Center"/>
										</StackPanel>

									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>