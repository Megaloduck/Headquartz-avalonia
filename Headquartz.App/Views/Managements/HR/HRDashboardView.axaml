<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.HRDashboardView">

	<ScrollViewer>

		<StackPanel
            Margin="30"
            Spacing="20">

			<TextBlock
                FontSize="34"
                FontWeight="Bold"
                Text="Human Resources"/>

			<!-- KPI ROW -->

			<ItemsControl
                ItemsSource="{Binding Kpis}">

				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>

					<DataTemplate>

						<Border
                            Width="220"
                            Margin="10"
                            Padding="20"
                            Background="#202633"
                            CornerRadius="12">

							<StackPanel>

								<TextBlock
                                    FontSize="18"
                                    Text="{Binding Title}"/>

								<TextBlock
                                    FontSize="30"
                                    FontWeight="Bold"
                                    Text="{Binding Value}"/>

							</StackPanel>

						</Border>

					</DataTemplate>

				</ItemsControl.ItemTemplate>

			</ItemsControl>

			<!-- ACTIONS -->

			<WrapPanel>

				<Button
                    Padding="14"
                    Margin="10"
                    Command="{Binding HireEmployeeCommand}"
                    Content="Hire Employee"/>

				<Button
                    Padding="14"
                    Margin="10"
                    Command="{Binding StartTrainingCommand}"
                    Content="Start Training"/>

			</WrapPanel>

			<!-- TASKS -->

			<Border
                Padding="20"
                Background="#202633"
                CornerRadius="12">

				<StackPanel>

					<TextBlock
                        FontSize="24"
                        FontWeight="Bold"
                        Text="Pending Tasks"/>
					<Border
    Padding="20"
    Background="#202633"
    CornerRadius="12">

						<StackPanel>

							<TextBlock
								FontSize="24"
								FontWeight="Bold"
								Text="Department Events"/>

							<ItemsControl
								Margin="0,20,0,0"
								ItemsSource="{Binding Events}">

								<ItemsControl.ItemTemplate>

									<DataTemplate>

										<Border
											Margin="0,8"
											Padding="14"
											Background="#2B3242"
											CornerRadius="8">

											<StackPanel>

												<TextBlock
													FontSize="18"
													FontWeight="Bold"
													Text="{Binding Title}"/>

												<TextBlock
													Margin="0,6,0,0"
													Text="{Binding Description}"/>

												<TextBlock
													Margin="0,6,0,0"
													FontWeight="Bold"
													Text="{Binding Severity}"/>

												<TextBlock
													Margin="0,4,0,0"
													Text="{Binding RemainingTicks,
                                               StringFormat='Ticks Left: {0}'}"/>

											</StackPanel>

										</Border>

									</DataTemplate>

								</ItemsControl.ItemTemplate>

							</ItemsControl>

						</StackPanel>

					</Border>

					<ItemsControl
                        Margin="0,20,0,0"
                        ItemsSource="{Binding PendingTasks}">

						<ItemsControl.ItemTemplate>

							<DataTemplate>

								<Border
                                    Margin="0,5"
                                    Padding="10"
                                    Background="#2B3242"
                                    CornerRadius="8">

									<TextBlock
                                        Text="{Binding}"/>

								</Border>

							</DataTemplate>

						</ItemsControl.ItemTemplate>

					</ItemsControl>

				</StackPanel>

			</Border>

			<!-- EMPLOYEES -->

			<Border
                Padding="20"
                Background="#202633"
                CornerRadius="12">

				<StackPanel>

					<TextBlock
                        FontSize="24"
                        FontWeight="Bold"
                        Text="Employees"/>

					<ItemsControl
                        Margin="0,20,0,0"
                        ItemsSource="{Binding Employees}">

						<ItemsControl.ItemTemplate>

							<DataTemplate>

								<Border
                                    Margin="0,5"
                                    Padding="10"
                                    Background="#2B3242"
                                    CornerRadius="8">

									<TextBlock
                                        Text="{Binding}"/>

								</Border>

							</DataTemplate>

						</ItemsControl.ItemTemplate>

					</ItemsControl>

				</StackPanel>

			</Border>

		</StackPanel>

	</ScrollViewer>

</UserControl>
