<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.HRDevelopmentView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Development"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Training programs, course assignments, and skill development tracking."/>
			</StackPanel>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- STATUS MESSAGE -->
			<Border
                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Padding="16,12" Background="{DynamicResource BrushBgNested}" CornerRadius="10">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- TRAINING PROGRAMS -->
			<TextBlock FontSize="22" FontWeight="Bold" Text="Training Programs" Margin="0,4,0,0"/>

			<Grid ColumnDefinitions="*,16,*">

				<!-- Morale Workshop -->
				<Border Grid.Column="0" Padding="22" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="14">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="🎉" FontSize="28"/>
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="Bold" Text="Morale Workshop"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$2,000"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Team-building and wellness sessions to restore staff wellbeing."/>
						<Border Padding="10,6" Background="{DynamicResource BrushAlertInfoBg}" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="{DynamicResource BrushBadgeInfoFg}" Text="All employees: +15 Morale"/>
						</Border>
						<Button
                            HorizontalAlignment="Stretch" Padding="12,10"
                            Background="{DynamicResource BrushAccentPrimary}" CornerRadius="8"
                            Command="{Binding RunMoraleWorkshopCommand}"
                            Content="Run Workshop"/>
					</StackPanel>
				</Border>

				<!-- Productivity Training -->
				<Border Grid.Column="2" Padding="22" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="14">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="📈" FontSize="28"/>
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="Bold" Text="Productivity Training"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$3,000"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Skills development and workflow optimisation for the entire workforce."/>
						<Border Padding="10,6" Background="{DynamicResource BrushBadgeSuccessBg}" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="{DynamicResource BrushBadgeSuccessFg}" Text="All employees: +10 Productivity"/>
						</Border>
						<Button
                            HorizontalAlignment="Stretch" Padding="12,10"
                            Background="{DynamicResource BrushSuccess}" CornerRadius="8"
                            Command="{Binding RunProductivityTrainingCommand}"
                            Content="Run Training"/>
					</StackPanel>
				</Border>

			</Grid>

			<Grid ColumnDefinitions="*,16,*">

				<!-- Stress Management -->
				<Border Grid.Column="0" Padding="22" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="14">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="🧘" FontSize="28"/>
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="Bold" Text="Stress Management"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$1,500"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Mindfulness and workload balance sessions. Best value for burnout recovery."/>
						<Border Padding="10,6" Background="{DynamicResource BrushDeptHR}" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="{DynamicResource BrushDeptHR}" Text="All employees: +8 Morale, +5 Productivity"/>
						</Border>
						<Button
                            HorizontalAlignment="Stretch" Padding="12,10"
                            Background="{DynamicResource BrushDeptHR}" CornerRadius="8"
                            Command="{Binding RunStressManagementCommand}"
                            Content="Run Session"/>
					</StackPanel>
				</Border>

				<!-- Leadership Program -->
				<Border Grid.Column="2" Padding="22" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="14">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="🏆" FontSize="28"/>
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="Bold" Text="Leadership Program"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$5,000"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Advanced leadership for supervisors and managers. Larger boost for senior staff."/>
						<Border Padding="10,6" Background="{DynamicResource BrushAlertWarningBg}" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="{DynamicResource BrushWarning}" Text="Leaders: +12 / Others: +5 Morale &amp; Productivity"/>
						</Border>
						<Button
                            HorizontalAlignment="Stretch" Padding="12,10"
                            Background="{DynamicResource BrushWarning}" CornerRadius="8"
                            Command="{Binding RunLeadershipProgramCommand}"
                            Content="Run Program"/>
					</StackPanel>
				</Border>

			</Grid>

			<!-- TRAINING LOG -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="20" FontWeight="Bold" Text="Training Log" Margin="0,0,0,12"/>
					<TextBlock IsVisible="{Binding !Log.Count}" Text="No training sessions run yet." Foreground="{DynamicResource BrushTextSecondary}"/>
					<ItemsControl ItemsSource="{Binding Log}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,3" Padding="12,8" Background="{DynamicResource BrushBgNested}" CornerRadius="6">
									<TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"/>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>