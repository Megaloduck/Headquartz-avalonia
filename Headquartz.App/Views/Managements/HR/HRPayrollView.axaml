<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.HRPayrollView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Payroll"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Process payroll, incentives, tax calculations, and salary adjustments."/>
			</StackPanel>

			<!-- PAYROLL AT RISK BANNER -->
			<Border
                IsVisible="{Binding IsPayrollCritical}"
                Background="{DynamicResource BrushAlertWarningBg}"
                CornerRadius="12"
                Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="💸" FontSize="22" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock
                            Text="PAYROLL CANNOT BE COVERED"
                            FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrushWarning}"/>
						<TextBlock
                            Text="Insufficient cash. Payroll failure will crash morale company-wide."
                            Foreground="{DynamicResource BrushWarning}"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- PAYROLL COVERAGE BAR -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel Spacing="10">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Payroll Coverage"/>
					<StackPanel Orientation="Horizontal" Spacing="12">
						<TextBlock Text="Cash" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Width="60" VerticalAlignment="Center"/>
						<ProgressBar
                            Value="{Binding CompanyCash}"
                            Maximum="{Binding TotalPayroll}"
                            Height="14"
                            Width="300"
                            Foreground="{DynamicResource BrushSuccess}"
                            VerticalAlignment="Center"/>
						<TextBlock
                            FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Text="{Binding CompanyCash, StringFormat='${0:N0}'}"
                            VerticalAlignment="Center"/>
					</StackPanel>
					<StackPanel Orientation="Horizontal" Spacing="12">
						<TextBlock Text="Payroll" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Width="60" VerticalAlignment="Center"/>
						<ProgressBar
                            Value="{Binding TotalPayroll}"
                            Maximum="{Binding TotalPayroll}"
                            Height="14"
                            Width="300"
                            Foreground="{DynamicResource BrushDanger}"
                            VerticalAlignment="Center"/>
						<TextBlock
                            FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Text="{Binding TotalPayroll, StringFormat='${0:N0}'}"
                            VerticalAlignment="Center"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- EMPLOYEE SALARY LIST -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Salary Breakdown" Margin="0,0,0,16"/>

					<TextBlock
                        IsVisible="{Binding !Employees.Count}"
                        Text="No employees on payroll."
                        Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding Employees}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,4" Padding="14" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,120,120,100">

										<!-- Name + dept -->
										<StackPanel Grid.Column="0">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Name}"/>
												<Border
                                                    IsVisible="{Binding IsLowMorale}"
                                                    Background="{DynamicResource BrushAlertCriticalBg}"
                                                    CornerRadius="4"
                                                    Padding="5,1">
													<TextBlock
                                                        Text="AT RISK"
                                                        FontSize="9"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource BrushBadgeDangerFg}"/>
												</Border>
											</StackPanel>
											<TextBlock
                                                FontSize="12"
                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Department}"/>
										</StackPanel>

										<!-- Role -->
										<TextBlock
                                            Grid.Column="1"
                                            FontSize="12"
                                            Foreground="{DynamicResource BrushTextSecondary}"
                                            Text="{Binding Role}"
                                            VerticalAlignment="Center"/>

										<!-- Morale -->
										<StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="3">
											<ProgressBar
                                                Value="{Binding Morale}"
                                                Maximum="100"
                                                Height="5"
                                                Width="80"
                                                Foreground="{DynamicResource BrushDeptHR}"/>
											<TextBlock
                                                FontSize="10"
                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding MoraleStatus}"/>
										</StackPanel>

										<!-- Salary -->
										<TextBlock
                                            Grid.Column="3"
                                            FontSize="15"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource BrushSuccess}"
                                            Text="{Binding Salary, StringFormat='${0:N0}'}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"/>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>