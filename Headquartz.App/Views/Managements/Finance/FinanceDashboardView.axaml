<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.FinanceDashboardView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Finance Dashboard"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Finance department overview, budget vs actual, and pending invoices."/>
			</StackPanel>

			<!-- CRISIS BANNER -->
			<Border
                IsVisible="{Binding IsCashCritical}"
                Background="{DynamicResource BrushAlertCriticalBg}"
                CornerRadius="12"
                Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="⚠" FontSize="22" Foreground="{DynamicResource BrushBadgeDangerFg}" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock Text="CASH CRISIS ACTIVE" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrushBadgeDangerFg}"/>
						<TextBlock Text="Company cash is below zero. Immediate action required." Foreground="{DynamicResource BrushBadgeDangerFg}"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- PAYROLL AT RISK BANNER -->
			<Border
                IsVisible="{Binding IsPayrollAtRisk}"
                Background="{DynamicResource BrushAlertWarningBg}"
                CornerRadius="12"
                Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="💸" FontSize="22" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock Text="PAYROLL AT RISK" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrushWarning}"/>
						<TextBlock
                            Text="{Binding NextPayroll, StringFormat='Next payroll of ${0:N0} may not be covered.'}"
                            Foreground="{DynamicResource BrushWarning}"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- ACTIONS -->
			<WrapPanel ItemSpacing="10">
				<Button Padding="14" Margin="0,5" Command="{Binding TakeLoanCommand}"    Content="💳  Take Loan (+$25,000)"/>
				<Button Padding="14" Margin="0,5" Command="{Binding CutBudgetsCommand}"  Content="✂   Cut All Budgets (−10%)"/>
				<Button Padding="14" Margin="0,5" Command="{Binding FreezeBonusesCommand}" Content="🧊  Freeze Bonuses"/>
			</WrapPanel>

			<!-- DEPARTMENT BUDGETS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Department Budgets" Margin="0,0,0,16"/>

					<ItemsControl ItemsSource="{Binding DepartmentBudgets}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="14" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,100,80,100">

										<TextBlock
                                            Grid.Column="0"
                                            FontWeight="SemiBold"
                                            Text="{Binding DepartmentName}"
                                            VerticalAlignment="Center"/>

										<TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Budget, StringFormat='${0:N0}'}"
                                            Foreground="{DynamicResource BrushTextSecondary}"
                                            VerticalAlignment="Center"/>

										<StackPanel Grid.Column="2" VerticalAlignment="Center">
											<TextBlock
                                                Text="{Binding Efficiency, StringFormat='⚙ {0}%'}"
                                                FontSize="12"
                                                Foreground="{DynamicResource BrushTextSecondary}"/>
										</StackPanel>

										<TextBlock
                                            Grid.Column="3"
                                            Text="{Binding StatusText}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{DynamicResource BrushTextSecondary}"/>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

			<!-- DEPARTMENT EVENTS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Finance Alerts" Margin="0,0,0,12"/>

					<TextBlock
                        IsVisible="{Binding !Events.Count}"
                        Text="No active alerts."
                        Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding Events}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,6" Padding="14" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<StackPanel>
										<TextBlock FontSize="15" FontWeight="Bold" Text="{Binding Title}"/>
										<TextBlock Margin="0,4,0,0" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Description}" TextWrapping="Wrap"/>
										<StackPanel Orientation="Horizontal" Spacing="16" Margin="0,6,0,0">
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushDanger}"
                                                Text="{Binding Severity, StringFormat='Severity: {0}'}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding RemainingTicks, StringFormat='Ticks left: {0}'}"/>
										</StackPanel>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>

</UserControl>
