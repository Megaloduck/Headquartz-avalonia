<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.FinanceAuditsView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Audits"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Run periodic audits to identify financial and operational risks."/>
			</StackPanel>
	
			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- RUN AUDIT -->
			<Border Padding="24" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel Spacing="14">
					<TextBlock FontSize="20" FontWeight="Bold" Text="Run Company Audit"/>
					<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                        Text="An audit scans all departments for financial irregularities, operational risks, and compliance issues. Cost: $2,000."/>

					<StackPanel Orientation="Horizontal" Spacing="12">
						<Button Padding="18,12" Background="{DynamicResource BrushAccentPrimary}" CornerRadius="8"
                            Command="{Binding RunAuditCommand}"
                            Content="🔍  Run Full Audit ($2,000)"/>
						<Border Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8"
                                VerticalAlignment="Center">
							<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                Text="{Binding LastAuditTick, StringFormat='Last audit: Tick {0}'}"/>
						</Border>
					</StackPanel>

					<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
						<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
					</Border>
				</StackPanel>
			</Border>

			<!-- FINDINGS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Audit Findings" Margin="0,0,0,16"/>

					<TextBlock IsVisible="{Binding !Findings.Count}"
                        Text="No findings yet. Run an audit first."
                        Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding Findings}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="16" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,100,Auto">

										<StackPanel Grid.Column="0" Spacing="4">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock FontWeight="Bold" FontSize="14" Text="{Binding Issue}"/>
												<Border IsVisible="{Binding IsResolved}"
                                                        Padding="6,2" Background="{DynamicResource BrushBadgeSuccessBg}" CornerRadius="4">
													<TextBlock Text="RESOLVED" FontSize="9"
                                                        FontWeight="Bold" Foreground="{DynamicResource BrushBadgeSuccessFg}"/>
												</Border>
											</StackPanel>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Department, StringFormat='Department: {0}'}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Recommendation}" TextWrapping="Wrap"/>
										</StackPanel>

										<Border Grid.Column="1" Padding="8,3" CornerRadius="6"
                                                Background="{DynamicResource BrushBgInput}" VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
											<TextBlock FontSize="11" FontWeight="Bold"
                                                Text="{Binding Severity}" Foreground="{DynamicResource BrushTextSecondary}"/>
										</Border>

										<Button Grid.Column="2"
                                            IsVisible="{Binding !IsResolved}"
                                            Padding="10,6" Background="{DynamicResource BrushBorderStrong}" CornerRadius="6"
                                            VerticalAlignment="Center"
                                            Command="{Binding $parent[ItemsControl].DataContext.ResolveFindingCommand}"
                                            CommandParameter="{Binding}"
                                            Content="✓ Resolve"/>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

			<!-- 30-TICK CASH PROJECTION -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="30-Tick Cash Projection" Margin="0,0,0,16"/>

					<!-- Header -->
					<Border Padding="12,8" Background="{DynamicResource BrushBorderStrong}" CornerRadius="6" Margin="0,0,0,4">
						<Grid ColumnDefinitions="60,120,*,100,100">
							<TextBlock Grid.Column="0" Text="Tick"       FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
							<TextBlock Grid.Column="1" Text="World Time" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
							<TextBlock Grid.Column="2" Text="Cash Balance" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
							<TextBlock Grid.Column="3" Text="Revenue"    FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
							<TextBlock Grid.Column="4" Text="Expenses"   FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						</Grid>
					</Border>

					<ItemsControl ItemsSource="{Binding Projection}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border
									Margin="0,2"
									Padding="12,10"
									CornerRadius="6"
									Background="{DynamicResource BrushBgNested}">
									<Grid ColumnDefinitions="60,120,*,100,100">

										<!-- Tick -->
										<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
											<TextBlock
												FontSize="12"
												Foreground="{DynamicResource BrushTextSecondary}"
												Text="{Binding Tick}"
												VerticalAlignment="Center"/>
											<!-- Payroll indicator -->
											<Border
												IsVisible="{Binding IsPayrollTick}"
												Background="{DynamicResource BrushAlertInfoBg}"
												CornerRadius="4"
												Padding="4,1"
												VerticalAlignment="Center">
												<TextBlock
													Text="PAY"
													FontSize="8"
													FontWeight="Bold"
													Foreground="{DynamicResource BrushBadgeInfoFg}"/>
											</Border>
										</StackPanel>

										<!-- World Time -->
										<TextBlock
												Grid.Column="1"
												FontSize="12"
												Foreground="{DynamicResource BrushTextSecondary}"
												Text="{Binding WorldTime}"
												VerticalAlignment="Center"/>

										<!-- Projected Cash -->
										<Panel Grid.Column="2" VerticalAlignment="Center">
											<TextBlock
												FontSize="13"
												FontWeight="Bold"
												Foreground="{DynamicResource BrushDanger}"
												IsVisible="{Binding IsNegative}"
												Text="{Binding CashDisplay}"/>
											<TextBlock
												FontSize="13"
												FontWeight="Bold"
												Foreground="{DynamicResource BrushTextSecondary}"
												IsVisible="{Binding !IsNegative}"
												Text="{Binding CashDisplay}"/>
										</Panel>

										<!-- Revenue -->
										<TextBlock
												Grid.Column="3"
												FontSize="12"
												Foreground="{DynamicResource BrushSuccess}"
												Text="{Binding Revenue, StringFormat='+${0:N0}'}"
												VerticalAlignment="Center"/>

										<!-- Expenses -->
										<TextBlock
												Grid.Column="4"
												FontSize="12"
												Foreground="{DynamicResource BrushDanger}"
												Text="{Binding Expenses, StringFormat='-${0:N0}'}"
												VerticalAlignment="Center"/>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>	