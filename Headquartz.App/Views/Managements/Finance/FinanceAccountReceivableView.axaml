<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.FinanceAccountReceivableView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<TextBlock FontSize="34" FontWeight="Bold" Text="Account Receivable"/>
			<TextBlock FontSize="13" Foreground="#6B7280"
                Text="Track money owed to the company. Collected revenue, pending orders, and overdue payments."/>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="10" Padding="20" Background="#202633" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="#9CA3AF" Text="{Binding Title}"/>
								<TextBlock FontSize="24" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- SUMMARY BARS -->
			<Border Padding="24" Background="#202633" CornerRadius="12">
				<StackPanel Spacing="14">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Revenue Pipeline"/>

					<!-- Collected bar -->
					<StackPanel Spacing="6">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<TextBlock Text="Collected" FontSize="12" Foreground="#9CA3AF" Width="90"/>
							<TextBlock
                                Text="{Binding CollectedRevenue, StringFormat='${0:N0}'}"
                                FontSize="12" Foreground="#10B981" FontWeight="Bold"/>
						</StackPanel>
						<ProgressBar
                            Value="{Binding CollectedRevenue}"
                            Maximum="{Binding TotalAR}"
                            Height="12" Foreground="#10B981" CornerRadius="4"/>
					</StackPanel>

					<!-- Pending bar -->
					<StackPanel Spacing="6">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<TextBlock Text="Pending" FontSize="12" Foreground="#9CA3AF" Width="90"/>
							<TextBlock
                                Text="{Binding PendingRevenue, StringFormat='${0:N0}'}"
                                FontSize="12" Foreground="#F59E0B" FontWeight="Bold"/>
						</StackPanel>
						<ProgressBar
                            Value="{Binding PendingRevenue}"
                            Maximum="{Binding TotalAR}"
                            Height="12" Foreground="#F59E0B" CornerRadius="4"/>
					</StackPanel>

				</StackPanel>
			</Border>

			<!-- AR PIPELINE TABLE -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="AR Pipeline" Margin="0,0,0,16"/>

					<!-- Header -->
					<Grid ColumnDefinitions="*,110,130,120,80" Margin="14,0,14,8">
						<TextBlock Grid.Column="0" Text="CLIENT / PRODUCT"  FontSize="11" FontWeight="Bold" Foreground="#6B7280"/>
						<TextBlock Grid.Column="1" Text="VALUE"             FontSize="11" FontWeight="Bold" Foreground="#6B7280"/>
						<TextBlock Grid.Column="2" Text="STATUS"            FontSize="11" FontWeight="Bold" Foreground="#6B7280"/>
						<TextBlock Grid.Column="3" Text="DEADLINE"          FontSize="11" FontWeight="Bold" Foreground="#6B7280"/>
						<TextBlock Grid.Column="4" Text="AGE (ticks)"       FontSize="11" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Right"/>
					</Grid>

					<TextBlock
                        IsVisible="{Binding !Pipeline.Count}"
                        Text="No AR entries."
                        Foreground="#6B7280" Margin="14,8"/>

					<ItemsControl ItemsSource="{Binding Pipeline}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,3" Padding="14,12" Background="#2B3242" CornerRadius="8">
									<Grid ColumnDefinitions="*,110,130,120,80">

										<StackPanel Grid.Column="0">
											<TextBlock FontWeight="SemiBold" Text="{Binding ClientName}"/>
											<TextBlock FontSize="12" Foreground="#6B7280" Text="{Binding ProductName}"/>
										</StackPanel>

										<TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Value, StringFormat='${0:N0}'}"
                                            Foreground="#10B981"
                                            VerticalAlignment="Center"/>

										<Border
                                            Grid.Column="2"
                                            Padding="8,3"
                                            CornerRadius="6"
                                            Background="#1F2937"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
											<TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="#9CA3AF"
                                                Text="{Binding Status}"/>
										</Border>

										<StackPanel Grid.Column="3" VerticalAlignment="Center">
											<TextBlock FontSize="11" Text="{Binding Deadline}" Foreground="#6B7280"/>
											<TextBlock
                                                FontSize="11" FontWeight="Bold"
                                                Text="⚠ OVERDUE"
                                                Foreground="#EF4444"
                                                IsVisible="{Binding IsOverdue}"/>
										</StackPanel>

										<TextBlock
                                            Grid.Column="4"
                                            Text="{Binding TicksInPipe}"
                                            FontSize="13"
                                            Foreground="#6B7280"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"/>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>	