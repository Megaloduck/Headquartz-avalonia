<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.FinanceAccountReceivableView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Account Receivable"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Income tracking, invoice management, revenue recognition, and payment collections."/>
			</StackPanel>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- SUMMARY BARS -->
			<Border Padding="24" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel Spacing="14">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Revenue Pipeline"/>

					<!-- Collected bar -->
					<StackPanel Spacing="6">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<TextBlock Text="Collected" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Width="90"/>
							<TextBlock
                                Text="{Binding CollectedRevenue, StringFormat='${0:N0}'}"
                                FontSize="12" Foreground="{DynamicResource BrushSuccess}" FontWeight="Bold"/>
						</StackPanel>
						<ProgressBar
                            Value="{Binding CollectedRevenue}"
                            Maximum="{Binding TotalAR}"
                            Height="12" Foreground="{DynamicResource BrushSuccess}" CornerRadius="4"/>
					</StackPanel>

					<!-- Pending bar -->
					<StackPanel Spacing="6">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<TextBlock Text="Pending" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Width="90"/>
							<TextBlock
                                Text="{Binding PendingRevenue, StringFormat='${0:N0}'}"
                                FontSize="12" Foreground="{DynamicResource BrushWarning}" FontWeight="Bold"/>
						</StackPanel>
						<ProgressBar
                            Value="{Binding PendingRevenue}"
                            Maximum="{Binding TotalAR}"
                            Height="12" Foreground="{DynamicResource BrushWarning}" CornerRadius="4"/>
					</StackPanel>

				</StackPanel>
			</Border>

			<!-- AR PIPELINE TABLE -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="AR Pipeline" Margin="0,0,0,16"/>

					<!-- Header -->
					<Grid ColumnDefinitions="*,110,130,120,80" Margin="14,0,14,8">
						<TextBlock Grid.Column="0" Text="CLIENT / PRODUCT"  FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="1" Text="VALUE"             FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="2" Text="STATUS"            FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="3" Text="DEADLINE"          FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="4" Text="AGE (ticks)"       FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}" HorizontalAlignment="Right"/>
					</Grid>

					<TextBlock
                        IsVisible="{Binding !Pipeline.Count}"
                        Text="No AR entries."
                        Foreground="{DynamicResource BrushTextSecondary}" Margin="14,8"/>

					<ItemsControl ItemsSource="{Binding Pipeline}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,3" Padding="14,12" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,110,130,120,80">

										<StackPanel Grid.Column="0">
											<TextBlock FontWeight="SemiBold" Text="{Binding ClientName}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding ProductName}"/>
										</StackPanel>

										<TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Value, StringFormat='${0:N0}'}"
                                            Foreground="{DynamicResource BrushSuccess}"
                                            VerticalAlignment="Center"/>

										<Border
                                            Grid.Column="2"
                                            Padding="8,3"
                                            CornerRadius="6"
                                            Background="{DynamicResource BrushBgInput}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
											<TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Status}"/>
										</Border>

										<StackPanel Grid.Column="3" VerticalAlignment="Center">
											<TextBlock FontSize="11" Text="{Binding Deadline}" Foreground="{DynamicResource BrushTextSecondary}"/>
											<TextBlock
                                                FontSize="11" FontWeight="Bold"
                                                Text="⚠ OVERDUE"
                                                Foreground="{DynamicResource BrushDanger}"
                                                IsVisible="{Binding IsOverdue}"/>
										</StackPanel>

										<TextBlock
                                            Grid.Column="4"
                                            Text="{Binding TicksInPipe}"
                                            FontSize="13"
                                            Foreground="{DynamicResource BrushTextSecondary}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"/>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>	