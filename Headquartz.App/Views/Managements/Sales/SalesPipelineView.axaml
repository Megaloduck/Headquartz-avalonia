<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.SalesPipelineView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Pipeline Management"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Visual deal stages, probability of closing, weighted forecast, and deal aging analysis.."/>
			</StackPanel>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- PIPELINE STAGE FLOW -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel Spacing="10">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Order Flow"/>

					<StackPanel Orientation="Horizontal" Spacing="0">

						<Border Padding="16,10" Background="{DynamicResource BrushAlertInfoBg}" CornerRadius="8" Margin="0,0,4,0">
							<StackPanel HorizontalAlignment="Center">
								<TextBlock Text="📋 Pending" FontSize="12" FontWeight="Bold"
                                    Foreground="{DynamicResource BrushBadgeInfoFg}" HorizontalAlignment="Center"/>
								<TextBlock Text="{Binding PendingOrders}" FontSize="22"
                                    FontWeight="Bold" HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>

						<TextBlock Text="→" FontSize="18" Foreground="{DynamicResource BrushBorderStrong}"
                            VerticalAlignment="Center" Margin="4,0"/>

						<Border Padding="16,10" Background="{DynamicResource BrushBgBase}" CornerRadius="8" Margin="0,0,4,0">
							<StackPanel HorizontalAlignment="Center">
								<TextBlock Text="🏭 Production" FontSize="12" FontWeight="Bold"
                                    Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
								<TextBlock Text="{Binding InProductionOrders}" FontSize="22"
                                    FontWeight="Bold" HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>

						<TextBlock Text="→" FontSize="18" Foreground="{DynamicResource BrushBorderStrong}"
                            VerticalAlignment="Center" Margin="4,0"/>

						<Border Padding="16,10" Background="{DynamicResource BrushBadgeSuccessBg}" CornerRadius="8" Margin="0,0,4,0">
							<StackPanel HorizontalAlignment="Center">
								<TextBlock Text="📦 Ready" FontSize="12" FontWeight="Bold"
                                    Foreground="{DynamicResource BrushBadgeSuccessFg}" HorizontalAlignment="Center"/>
								<TextBlock Text="{Binding ReadyOrders}" FontSize="22"
                                    FontWeight="Bold" HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>

						<TextBlock Text="→" FontSize="18" Foreground="{DynamicResource BrushBorderStrong}"
                            VerticalAlignment="Center" Margin="4,0"/>

						<Border Padding="16,10" Background="{DynamicResource BrushAlertInfoBg}" CornerRadius="8" Margin="0,0,4,0">
							<StackPanel HorizontalAlignment="Center">
								<TextBlock Text="🚚 Shipping" FontSize="12" FontWeight="Bold"
                                    Foreground="{DynamicResource BrushAccentSecondary}" HorizontalAlignment="Center"/>
								<TextBlock Text="{Binding ShippingOrders}" FontSize="22"
                                    FontWeight="Bold" HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>

						<TextBlock Text="→" FontSize="18" Foreground="{DynamicResource BrushBorderStrong}"
                            VerticalAlignment="Center" Margin="4,0"/>

						<Border Padding="16,10" Background="{DynamicResource BrushBadgeSuccessBg}" CornerRadius="8">
							<StackPanel HorizontalAlignment="Center">
								<TextBlock Text="✅ Delivered" FontSize="12" FontWeight="Bold"
                                    Foreground="{DynamicResource BrushBadgeSuccessFg}" HorizontalAlignment="Center"/>
								<TextBlock Text="{Binding DeliveredOrders}" FontSize="22"
                                    FontWeight="Bold" HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>

					</StackPanel>
				</StackPanel>
			</Border>

			<!-- PIPELINE TABLE -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Active Pipeline" Margin="0,0,0,16"/>

					<Grid ColumnDefinitions="*,120,130,120,110" Margin="14,0,14,8">
						<TextBlock Grid.Column="0" Text="CLIENT / PRODUCT" FontSize="11"
                            FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="1" Text="REVENUE" FontSize="11"
                            FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="2" Text="STAGE" FontSize="11"
                            FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="3" Text="DEADLINE" FontSize="11"
                            FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="4" Text="QTY" FontSize="11"
                            FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}" HorizontalAlignment="Right"/>
					</Grid>

					<TextBlock IsVisible="{Binding !PipelineOrders.Count}"
                        Text="No active orders in pipeline." Foreground="{DynamicResource BrushTextSecondary}" Margin="14,8"/>

					<ItemsControl ItemsSource="{Binding PipelineOrders}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,3" Padding="14,12" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,120,130,120,110">

										<StackPanel Grid.Column="0">
											<TextBlock FontWeight="SemiBold" Text="{Binding ClientName}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding ProductName}"/>
										</StackPanel>

										<TextBlock Grid.Column="1"
                                            Text="{Binding Revenue, StringFormat='${0:N0}'}"
                                            Foreground="{DynamicResource BrushSuccess}" VerticalAlignment="Center"/>

										<Border Grid.Column="2" Padding="8,3" CornerRadius="6"
                                                Background="{DynamicResource BrushBgInput}" VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
											<TextBlock FontSize="11" FontWeight="SemiBold"
                                                Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Status}"/>
										</Border>

										<StackPanel Grid.Column="3" VerticalAlignment="Center">
											<TextBlock FontSize="11" Text="{Binding Deadline}"
                                                Foreground="{DynamicResource BrushTextSecondary}"/>
											<TextBlock FontSize="11" FontWeight="Bold"
                                                Text="⚠ OVERDUE" Foreground="{DynamicResource BrushDanger}"
                                                IsVisible="{Binding IsOverdue}"/>
										</StackPanel>

										<TextBlock Grid.Column="4" Text="{Binding Quantity}"
                                            FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"/>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>