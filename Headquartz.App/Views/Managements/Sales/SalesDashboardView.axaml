<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.SalesDashboardView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
			<StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Sales Dashboard"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Sales department overview, revenue tracking, conversion rates, and monthly target progress."/>
			</StackPanel>	

			<!-- OVERDUE ORDERS BANNER -->
			<Border
                IsVisible="{Binding OverdueOrders}"
                Background="{DynamicResource BrushAlertCriticalBg}"
                CornerRadius="12"
                Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="📦" FontSize="22" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock
                            Text="{Binding OverdueOrders, StringFormat={}{0} ORDER(S) PAST DEADLINE}"	
                            FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrushBadgeDangerFg}"/>
						<TextBlock
                            Text="These orders will be cancelled and will damage reputation."
                            Foreground="{DynamicResource BrushBadgeDangerFg}"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- ACTIONS -->
			<WrapPanel ItemSpacing="10">
				<Button Padding="14" Margin="0,5" Command="{Binding GenerateLeadCommand}"       Content="🎯  Generate Lead"/>
				<Button Padding="14" Margin="0,5" Command="{Binding RunDiscountCampaignCommand}" Content="📣  Run Discount Campaign (+5 Rep)"/>
			</WrapPanel>

			<!-- ACTIVE ORDERS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Active Orders" Margin="0,0,0,16"/>

					<TextBlock
                        IsVisible="{Binding !Orders.Count}"
                        Text="No active orders."
                        Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding Orders}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border
                                    Margin="0,5"
                                    Padding="14"
                                    CornerRadius="8"
                                    Background="{DynamicResource BrushBgNested}">

									<Grid ColumnDefinitions="*,120,100,110">

										<!-- Client + product -->
										<StackPanel Grid.Column="0">
											<TextBlock FontWeight="SemiBold" Text="{Binding ClientName}"/>
											<TextBlock
                                                FontSize="12"
                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding ProductName}"/>
										</StackPanel>

										<!-- Revenue -->
										<TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Revenue, StringFormat='${0:N0}'}"
                                            Foreground="{DynamicResource BrushSuccess}"
                                            VerticalAlignment="Center"/>

										<!-- Status -->
										<TextBlock
                                            Grid.Column="2"
                                            Text="{Binding Status}"
                                            FontSize="12"
                                            Foreground="{DynamicResource BrushTextSecondary}"
                                            VerticalAlignment="Center"/>

										<!-- Deadline -->
										<StackPanel Grid.Column="3" VerticalAlignment="Center">
											<TextBlock
                                                FontSize="11"
                                                Text="{Binding Deadline}"
                                                Foreground="{DynamicResource BrushTextSecondary}"/>
											<TextBlock
                                                FontSize="11"
                                                FontWeight="Bold"
                                                Text="OVERDUE"
                                                Foreground="{DynamicResource BrushDanger}"
                                                IsVisible="{Binding IsOverdue}"/>
										</StackPanel>

									</Grid>

								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

			<!-- SALES EVENTS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Sales Alerts" Margin="0,0,0,12"/>

					<TextBlock
                        IsVisible="{Binding !Events.Count}"
                        Text="No active alerts."
                        Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding Events}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,6" Padding="14" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<StackPanel>
										<TextBlock FontSize="15" FontWeight="Bold" Text="{Binding Title}"/>
										<TextBlock Margin="0,4" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Description}" TextWrapping="Wrap"/>
										<StackPanel Orientation="Horizontal" Spacing="16">
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushInfo}"
                                                Text="{Binding Severity, StringFormat='Severity: {0}'}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding RemainingTicks, StringFormat='Ticks left: {0}'}"/>
										</StackPanel>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>

</UserControl>
