<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.SalesLeadsView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Leads"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Lead capture, scoring, qualification status, source tracking, and distribution to sales reps."/>
			</StackPanel>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- PIPELINE STAGE BANNER -->
			<Border Padding="16,12" Background="{DynamicResource BrushBgCard}" CornerRadius="10">
				<StackPanel Orientation="Horizontal" Spacing="0">

					<Border Padding="12,8" CornerRadius="8" Background="{DynamicResource BrushAlertInfoBg}" Margin="0,0,4,0">
						<StackPanel HorizontalAlignment="Center">
							<TextBlock Text="🎯 New" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushBadgeInfoFg}" HorizontalAlignment="Center"/>
							<TextBlock Text="{Binding NewLeads}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
						</StackPanel>
					</Border>
					<TextBlock Text="→" FontSize="18" Foreground="{DynamicResource BrushBorderStrong}" VerticalAlignment="Center" Margin="4,0"/>
					<Border Padding="12,8" CornerRadius="8" Background="{DynamicResource BrushBgBase}" Margin="0,0,4,0">
						<StackPanel HorizontalAlignment="Center">
							<TextBlock Text="📞 Contacted" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
							<TextBlock Text="{Binding ContactedLeads}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
						</StackPanel>
					</Border>
					<TextBlock Text="→" FontSize="18" Foreground="{DynamicResource BrushBorderStrong}" VerticalAlignment="Center" Margin="4,0"/>
					<Border Padding="12,8" CornerRadius="8" Background="{DynamicResource BrushAlertWarningBg}" Margin="0,0,4,0">
						<StackPanel HorizontalAlignment="Center">
							<TextBlock Text="🤝 Negotiating" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushBadgeDangerFg}" HorizontalAlignment="Center"/>
							<TextBlock Text="{Binding NegotiatingLeads}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
						</StackPanel>
					</Border>
					<TextBlock Text="→" FontSize="18" Foreground="{DynamicResource BrushBorderStrong}" VerticalAlignment="Center" Margin="4,0"/>
					<Border Padding="12,8" CornerRadius="8" Background="{DynamicResource BrushBadgeSuccessBg}">
						<StackPanel HorizontalAlignment="Center">
							<TextBlock Text="✅ Won" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushBadgeSuccessFg}" HorizontalAlignment="Center"/>
							<TextBlock Text="{Binding WonLeads}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
						</StackPanel>
					</Border>

				</StackPanel>
			</Border>

			<!-- ACTIONS -->
			<WrapPanel ItemSpacing="10">
				<Button Padding="14" Margin="0,5" Background="{DynamicResource BrushAccentPrimary}" CornerRadius="8"
                    Command="{Binding GenerateLeadCommand}"
                    Content="＋  Generate New Lead"/>
			</WrapPanel>

			<!-- ACTIVE LEADS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Active Pipeline" Margin="0,0,0,16"/>

					<TextBlock
                        IsVisible="{Binding !Leads.Count}"
                        Text="No active leads. Generate a lead or wait for inbound enquiries."
                        Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding Leads}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="16" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,120,130,120,Auto">

										<!-- Company + Product -->
										<StackPanel Grid.Column="0">
											<TextBlock FontWeight="SemiBold" FontSize="14"
                                                Text="{Binding CompanyName}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding ProductInterest}"/>
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextMuted}"
                                                Text="{Binding CreatedAt, StringFormat='Since {0}'}"/>
										</StackPanel>

										<!-- Value -->
										<TextBlock
                                            Grid.Column="1"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource BrushSuccess}"
                                            Text="{Binding EstimatedValue, StringFormat='${0:N0}'}"
                                            VerticalAlignment="Center"/>

										<!-- Stage badge -->
										<Border
                                            Grid.Column="2"
                                            Padding="12,5"
                                            CornerRadius="8"
                                            Background="{DynamicResource BrushBorderStrong}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
											<TextBlock
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Stage}"/>
										</Border>

										<!-- Advance button -->
										<Button
                                            Grid.Column="3"
                                            Padding="10,7"
                                            Background="{DynamicResource BrushAlertInfoBg}"
                                            CornerRadius="7"
                                            VerticalAlignment="Center"
                                            Command="{Binding $parent[ItemsControl].DataContext.AdvanceStageCommand}"
                                            CommandParameter="{Binding}"
                                            Content="Advance →"/>

										<!-- Mark lost -->
										<Button
                                            Grid.Column="4"
                                            Padding="10,7"
                                            Background="{DynamicResource BrushBadgeDangerBg}"
                                            CornerRadius="7"
                                            VerticalAlignment="Center"
                                            Margin="8,0,0,0"
                                            Command="{Binding $parent[ItemsControl].DataContext.MarkLostCommand}"
                                            CommandParameter="{Binding}"
                                            Content="✕"/>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>