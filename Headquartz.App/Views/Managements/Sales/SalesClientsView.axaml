<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.SalesClientsView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<TextBlock FontSize="34" FontWeight="Bold" Text="Client Management"/>
			<TextBlock FontSize="13" Foreground="#6B7280"
                Text="Track client relationships, satisfaction scores, and revenue contribution."/>

			<!-- AT RISK BANNER -->
			<Border IsVisible="{Binding AtRiskClients}"
                    Background="#7F1D1D" CornerRadius="12" Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="⚠" FontSize="22" Foreground="#FCA5A5" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock
                            Text="{Binding AtRiskClients, StringFormat='{}{0} CLIENT(S) AT RISK'}"
                            FontSize="16" FontWeight="Bold" Foreground="#FCA5A5"/>
						<TextBlock Text="Low satisfaction scores may result in churn and lost revenue."
                            Foreground="#FCA5A5"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- KPIs -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="10" Padding="20" Background="#202633" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="#9CA3AF" Text="{Binding Title}"/>
								<TextBlock FontSize="26" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- SEARCH + ADD -->
			<Grid ColumnDefinitions="*,Auto">
				<TextBox Grid.Column="0"
                    Text="{Binding SearchText}"
                    Watermark="Search clients..."
                    Padding="12,9"
                    Background="#202633"
                    BorderBrush="#374151"
                    BorderThickness="1"
                    CornerRadius="8"/>
				<Button Grid.Column="1" Margin="10,0,0,0"
                    Padding="16,9" Background="#6366F1" CornerRadius="8"
                    Command="{Binding AddClientCommand}"
                    Content="＋  Add Client"/>
			</Grid>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="#2B3242" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13"/>
			</Border>

			<!-- CLIENT LIST -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Client Portfolio" Margin="0,0,0,16"/>

					<TextBlock IsVisible="{Binding !Clients.Count}"
                        Text="No clients found." Foreground="#6B7280"/>

					<ItemsControl ItemsSource="{Binding Clients}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="16" Background="#2B3242" CornerRadius="8">
									<Grid ColumnDefinitions="*,120,120,100,Auto,Auto">

										<!-- Name + industry -->
										<StackPanel Grid.Column="0">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock FontWeight="Bold" FontSize="14"
                                                    Text="{Binding Name}" VerticalAlignment="Center"/>
												<Border IsVisible="{Binding Status}"
                                                        Padding="6,2" Background="#7F1D1D"
                                                        CornerRadius="4" VerticalAlignment="Center">
													<TextBlock Text="{Binding Status}" FontSize="9"
                                                        FontWeight="Bold" Foreground="#FCA5A5"/>
												</Border>
											</StackPanel>
											<TextBlock FontSize="12" Foreground="#6B7280"
                                                Text="{Binding Industry}"/>
										</StackPanel>

										<!-- Revenue -->
										<TextBlock Grid.Column="1"
                                            Text="{Binding TotalRevenue, StringFormat='${0:N0}'}"
                                            Foreground="#10B981" VerticalAlignment="Center"/>

										<!-- Orders -->
										<TextBlock Grid.Column="2"
                                            Text="{Binding TotalOrders, StringFormat='{}{0} orders'}"
                                            Foreground="#9CA3AF" VerticalAlignment="Center"
                                            FontSize="12"/>

										<!-- Satisfaction -->
										<StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="3">
											<TextBlock FontSize="11" Foreground="#6B7280" Text="Satisfaction"/>
											<ProgressBar Value="{Binding SatisfactionScore}"
                                                Maximum="100" Height="6" Width="80"
                                                Foreground="#6366F1"/>
										</StackPanel>

										<!-- Contact -->
										<Button Grid.Column="4"
                                            Margin="8,0" Padding="10,6"
                                            Background="#1E3A5F" CornerRadius="6"
                                            VerticalAlignment="Center"
                                            Command="{Binding $parent[ItemsControl].DataContext.ContactClientCommand}"
                                            CommandParameter="{Binding}"
                                            Content="📞 Contact"/>

										<!-- At Risk -->
										<Button Grid.Column="5"
                                            Padding="10,6"
                                            Background="#450A0A" CornerRadius="6"
                                            VerticalAlignment="Center"
                                            Command="{Binding $parent[ItemsControl].DataContext.MarkAtRiskCommand}"
                                            CommandParameter="{Binding}"
                                            Content="⚠ Risk"/>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>