<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.SalesOrdersView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Orders"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Order processing, order tracking, returns management, order history."/>
			</StackPanel>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- FILTER TABS -->
			<StackPanel Orientation="Horizontal" Spacing="8">
				<ItemsControl ItemsSource="{Binding Filters}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Horizontal" Spacing="8"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Button
                                Padding="14,8"
                                CornerRadius="8"
                                Background="{DynamicResource BrushBgCard}"
                                Command="{Binding $parent[ItemsControl].DataContext.SetFilterCommand}"
                                CommandParameter="{Binding}"
                                Content="{Binding}"/>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>

			<!-- ORDERS TABLE -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>

					<!-- Header -->
					<Grid ColumnDefinitions="*,120,110,120,110" Margin="14,0,14,8">
						<TextBlock Grid.Column="0" Text="CLIENT / PRODUCT"  FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="1" Text="REVENUE"           FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="2" Text="STATUS"            FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="3" Text="DEADLINE"          FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
						<TextBlock Grid.Column="4" Text="QTY"               FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}" HorizontalAlignment="Right"/>
					</Grid>

					<TextBlock
                        IsVisible="{Binding !Orders.Count}"
                        Text="No orders match this filter."
                        Foreground="{DynamicResource BrushTextSecondary}"
                        Margin="14,8"/>

					<ItemsControl ItemsSource="{Binding Orders}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,3" Padding="14,12" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,120,110,120,110">

										<StackPanel Grid.Column="0">
											<TextBlock FontWeight="SemiBold" Text="{Binding ClientName}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding ProductName}"/>
										</StackPanel>

										<TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Revenue, StringFormat='${0:N0}'}"
                                            Foreground="{DynamicResource BrushSuccess}"
                                            VerticalAlignment="Center"/>

										<Border
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Padding="8,3"
                                            CornerRadius="6"
                                            Background="{DynamicResource BrushBgInput}">
											<TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Text="{Binding Status}"
                                                Foreground="{DynamicResource BrushTextSecondary}"/>
										</Border>

										<StackPanel Grid.Column="3" VerticalAlignment="Center">
											<TextBlock FontSize="11" Text="{Binding Deadline}" Foreground="{DynamicResource BrushTextSecondary}"/>
											<TextBlock
                                                FontSize="11" FontWeight="Bold"
                                                Text="⚠ OVERDUE"
                                                Foreground="{DynamicResource BrushDanger}"
                                                IsVisible="{Binding IsOverdue}"/>
										</StackPanel>

										<TextBlock
                                            Grid.Column="4"
                                            Text="{Binding Quantity}"
                                            FontSize="14"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource BrushTextSecondary}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"/>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>