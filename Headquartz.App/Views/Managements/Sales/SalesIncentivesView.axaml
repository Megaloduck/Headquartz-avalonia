<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.SalesIncentivesView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Performance Incentives"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Reward performance milestones, track target progress, commission calculations."/>
			</StackPanel>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- INCENTIVE PROGRAMS -->
			<TextBlock FontSize="22" FontWeight="Bold" Text="Incentive Programs"/>

			<Grid ColumnDefinitions="*,16,*,16,*">

				<!-- Sales Bonus -->
				<Border Grid.Column="0" Padding="22" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="12">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="💰" FontSize="28"/>
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="Bold" Text="Sales Bonus"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$5,000"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Reward the entire sales team with a performance bonus."/>
						<Border Padding="10,6" Background="{DynamicResource BrushBadgeSuccessBg}" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="{DynamicResource BrushBadgeSuccessFg}"
                                Text="Team: +20 Morale, +10 Productivity, +3 Rep"/>
						</Border>
						<Button HorizontalAlignment="Stretch" Padding="12,10"
                            Background="{DynamicResource BrushSuccess}" CornerRadius="8"
                            Command="{Binding RunSalesBonusCommand}"
                            Content="Pay Bonus"/>
					</StackPanel>
				</Border>

				<!-- Discount Drive -->
				<Border Grid.Column="2" Padding="22" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="12">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="📣" FontSize="28"/>
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="Bold" Text="Discount Drive"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="Free"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Launch a discount campaign to attract more orders and boost reputation."/>
						<Border Padding="10,6" Background="{DynamicResource BrushAlertInfoBg}" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="{DynamicResource BrushBadgeInfoFg}"
                                Text="Company: +5 Reputation"/>
						</Border>
						<Button HorizontalAlignment="Stretch" Padding="12,10"
                            Background="{DynamicResource BrushInfo}" CornerRadius="8"
                            Command="{Binding RunDiscountDriveCommand}"
                            Content="Launch Drive"/>
					</StackPanel>
				</Border>

				<!-- Commission Program -->
				<Border Grid.Column="4" Padding="22" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="12">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="🏆" FontSize="28"/>
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="Bold" Text="Commission Program"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$3,000"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Activate performance-based commissions to maximize team output."/>
						<Border Padding="10,6" Background="{DynamicResource BrushDeptHR}" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="{DynamicResource BrushDeptHR}"
                                Text="Sales team: +15 Productivity"/>
						</Border>
						<Button HorizontalAlignment="Stretch" Padding="12,10"
                            Background="{DynamicResource BrushDeptHR}" CornerRadius="8"
                            Command="{Binding RunCommissionProgramCommand}"
                            Content="Activate"/>
					</StackPanel>
				</Border>

			</Grid>

			<!-- MILESTONE TIERS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Milestone Tiers" Margin="0,0,0,16"/>

					<ItemsControl ItemsSource="{Binding Tiers}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="16" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="40,*,200,100">

										<TextBlock Grid.Column="0" Text="{Binding Emoji}"
                                            FontSize="24" VerticalAlignment="Center"/>

										<StackPanel Grid.Column="1" VerticalAlignment="Center">
											<TextBlock FontWeight="Bold" FontSize="14"
                                                Text="{Binding Name}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Requirement}"/>
										</StackPanel>

										<TextBlock Grid.Column="2" FontSize="12"
                                            Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Reward}"
                                            VerticalAlignment="Center" TextWrapping="Wrap"/>

										<Border Grid.Column="3" Padding="10,4" CornerRadius="6"
                                                VerticalAlignment="Center" HorizontalAlignment="Right">
											<Border.Background>
												<SolidColorBrush Color="{DynamicResource ColorBadgeSuccessBg}"/>
											</Border.Background>
											<TextBlock FontSize="11" FontWeight="Bold"
                                                Foreground="{DynamicResource BrushBadgeSuccessFg}"
                                                Text="✓ UNLOCKED"
                                                IsVisible="{Binding IsUnlocked}"/>
										</Border>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>