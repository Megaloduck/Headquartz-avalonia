<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.SalesIncentivesView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<TextBlock FontSize="34" FontWeight="Bold" Text="Performance Incentives"/>
			<TextBlock FontSize="13" Foreground="#6B7280"
                Text="Motivate your sales team and reward performance milestones."/>

			<!-- KPIs -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="10" Padding="20" Background="#202633" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="#9CA3AF" Text="{Binding Title}"/>
								<TextBlock FontSize="26" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="#2B3242" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- INCENTIVE PROGRAMS -->
			<TextBlock FontSize="22" FontWeight="Bold" Text="Incentive Programs"/>

			<Grid ColumnDefinitions="*,16,*,16,*">

				<!-- Sales Bonus -->
				<Border Grid.Column="0" Padding="22" Background="#202633" CornerRadius="12">
					<StackPanel Spacing="12">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="💰" FontSize="28"/>
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="Bold" Text="Sales Bonus"/>
								<TextBlock FontSize="12" Foreground="#6B7280" Text="$5,000"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="#9CA3AF" TextWrapping="Wrap"
                            Text="Reward the entire sales team with a performance bonus."/>
						<Border Padding="10,6" Background="#14532D" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="#86EFAC"
                                Text="Team: +20 Morale, +10 Productivity, +3 Rep"/>
						</Border>
						<Button HorizontalAlignment="Stretch" Padding="12,10"
                            Background="#10B981" CornerRadius="8"
                            Command="{Binding RunSalesBonusCommand}"
                            Content="Pay Bonus"/>
					</StackPanel>
				</Border>

				<!-- Discount Drive -->
				<Border Grid.Column="2" Padding="22" Background="#202633" CornerRadius="12">
					<StackPanel Spacing="12">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="📣" FontSize="28"/>
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="Bold" Text="Discount Drive"/>
								<TextBlock FontSize="12" Foreground="#6B7280" Text="Free"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="#9CA3AF" TextWrapping="Wrap"
                            Text="Launch a discount campaign to attract more orders and boost reputation."/>
						<Border Padding="10,6" Background="#1E3A5F" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="#93C5FD"
                                Text="Company: +5 Reputation"/>
						</Border>
						<Button HorizontalAlignment="Stretch" Padding="12,10"
                            Background="#3B82F6" CornerRadius="8"
                            Command="{Binding RunDiscountDriveCommand}"
                            Content="Launch Drive"/>
					</StackPanel>
				</Border>

				<!-- Commission Program -->
				<Border Grid.Column="4" Padding="22" Background="#202633" CornerRadius="12">
					<StackPanel Spacing="12">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="🏆" FontSize="28"/>
							<StackPanel>
								<TextBlock FontSize="16" FontWeight="Bold" Text="Commission Program"/>
								<TextBlock FontSize="12" Foreground="#6B7280" Text="$3,000"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="#9CA3AF" TextWrapping="Wrap"
                            Text="Activate performance-based commissions to maximize team output."/>
						<Border Padding="10,6" Background="#3B0764" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="#C4B5FD"
                                Text="Sales team: +15 Productivity"/>
						</Border>
						<Button HorizontalAlignment="Stretch" Padding="12,10"
                            Background="#8B5CF6" CornerRadius="8"
                            Command="{Binding RunCommissionProgramCommand}"
                            Content="Activate"/>
					</StackPanel>
				</Border>

			</Grid>

			<!-- MILESTONE TIERS -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Milestone Tiers" Margin="0,0,0,16"/>

					<ItemsControl ItemsSource="{Binding Tiers}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="16" Background="#2B3242" CornerRadius="8">
									<Grid ColumnDefinitions="40,*,200,100">

										<TextBlock Grid.Column="0" Text="{Binding Emoji}"
                                            FontSize="24" VerticalAlignment="Center"/>

										<StackPanel Grid.Column="1" VerticalAlignment="Center">
											<TextBlock FontWeight="Bold" FontSize="14"
                                                Text="{Binding Name}"/>
											<TextBlock FontSize="12" Foreground="#6B7280"
                                                Text="{Binding Requirement}"/>
										</StackPanel>

										<TextBlock Grid.Column="2" FontSize="12"
                                            Foreground="#9CA3AF" Text="{Binding Reward}"
                                            VerticalAlignment="Center" TextWrapping="Wrap"/>

										<Border Grid.Column="3" Padding="10,4" CornerRadius="6"
                                                VerticalAlignment="Center" HorizontalAlignment="Right">
											<Border.Background>
												<SolidColorBrush Color="#14532D"/>
											</Border.Background>
											<TextBlock FontSize="11" FontWeight="Bold"
                                                Foreground="#86EFAC"
                                                Text="✓ UNLOCKED"
                                                IsVisible="{Binding IsUnlocked}"/>
										</Border>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>