<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.ProductionLinesView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
			<StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Line Management"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Assembly line balancing, throughput monitoring, and real-time bottleneck detection."/>
			</StackPanel>	

			<!-- OFFLINE BANNER -->
			<Border IsVisible="{Binding OfflineLines}"
                    Background="{DynamicResource BrushWarning}" CornerRadius="12" Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="🏭" FontSize="22" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock
                            Text="{Binding OfflineLines, StringFormat='{}{0} LINE(S) OFFLINE'}"
                            FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrushWarning}"/>
						<TextBlock Text="Offline lines are not contributing to production output."
                            Foreground="{DynamicResource BrushWarning}"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- ACTIONS -->
			<WrapPanel ItemSpacing="10">
				<Button Padding="14" Margin="0,5" Background="{DynamicResource BrushAccentPrimary}" CornerRadius="8"
                    Command="{Binding AddLineCommand}"
                    Content="＋  Add Production Line ($15,000)"/>
			</WrapPanel>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- LINES LIST -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Production Lines" Margin="0,0,0,16"/>

					<TextBlock IsVisible="{Binding !Lines.Count}"
                        Text="No production lines configured." Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding Lines}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,6" Padding="18" Background="{DynamicResource BrushBgNested}" CornerRadius="10">
									<StackPanel Spacing="12">

										<!-- Header -->
										<Grid ColumnDefinitions="*,Auto,Auto,Auto">

											<StackPanel Grid.Column="0">
												<StackPanel Orientation="Horizontal" Spacing="8">
													<TextBlock FontWeight="Bold" FontSize="16"
                                                        Text="{Binding Name}" VerticalAlignment="Center"/>
													<Border Padding="8,3" CornerRadius="6"
                                                            Background="{DynamicResource BrushBgInput}" VerticalAlignment="Center">
														<TextBlock FontSize="11" FontWeight="Bold"
                                                            Text="{Binding Status}" Foreground="{DynamicResource BrushTextSecondary}"/>
													</Border>
												</StackPanel>
												<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding Product, StringFormat='Product: {0}'}"/>
											</StackPanel>

											<Button Grid.Column="1"
                                                Margin="8,0" Padding="10,6"
                                                Background="{DynamicResource BrushSuccess}" CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].DataContext.ActivateLineCommand}"
                                                CommandParameter="{Binding}"
                                                Content="▶ Activate"/>

											<Button Grid.Column="2"
                                                Margin="4,0" Padding="10,6"
                                                Background="{DynamicResource BrushAccentPrimary}" CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].DataContext.BoostLineCommand}"
                                                CommandParameter="{Binding}"
                                                Content="⚡ Boost ($2k)"/>

											<Button Grid.Column="3"
                                                Padding="10,6"
                                                Background="{DynamicResource BrushBadgeDangerBg}" CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].DataContext.ShutdownLineCommand}"
                                                CommandParameter="{Binding}"
                                                Content="⛔ Shutdown"/>

										</Grid>

										<!-- Stats -->
										<Grid ColumnDefinitions="*,*,*,*">

											<StackPanel Grid.Column="0" Spacing="4">
												<TextBlock Text="Efficiency" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"/>
												<ProgressBar Value="{Binding Efficiency}" Maximum="100"
                                                    Height="7" Foreground="{DynamicResource BrushSuccess}"/>
												<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding Efficiency, StringFormat='{}{0}%'}"/>
											</StackPanel>

											<StackPanel Grid.Column="1" Spacing="4" Margin="16,0,0,0">
												<TextBlock Text="Stress" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"/>
												<ProgressBar Value="{Binding StressLevel}" Maximum="100"
                                                    Height="7" Foreground="{DynamicResource BrushDanger}"/>
												<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding StressLevel, StringFormat='{}{0}%'}"/>
											</StackPanel>

											<StackPanel Grid.Column="2" Spacing="4" Margin="16,0,0,0">
												<TextBlock Text="Workers" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"/>
												<TextBlock FontSize="18" FontWeight="Bold"
                                                    Text="{Binding AssignedWorkers}"/>
											</StackPanel>

											<StackPanel Grid.Column="3" Spacing="4" Margin="16,0,0,0">
												<TextBlock Text="Output/Tick" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"/>
												<TextBlock FontSize="18" FontWeight="Bold"
                                                    Text="{Binding OutputPerTick}"/>
											</StackPanel>

										</Grid>

									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>