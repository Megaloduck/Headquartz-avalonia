<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.ProductionMaintenanceView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
			<StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Maintenance"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Equipment maintenance, downtime tracking, performance monitoring, and calibration."/>
			</StackPanel>	

			<!-- CRITICAL BANNER -->
			<Border IsVisible="{Binding IsCritical}" Background="{DynamicResource BrushWarning}" CornerRadius="12" Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="🔧" FontSize="22" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock Text="CRITICAL STRESS — IMMEDIATE MAINTENANCE REQUIRED"
                            FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushWarning}"/>
						<TextBlock
                            Text="{Binding DeptStress, StringFormat='Stress at {0}%. Production efficiency severely degraded.'}"
                            Foreground="{DynamicResource BrushWarning}"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- HEALTH BARS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel Spacing="12">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Production Line Health"/>
					<StackPanel Orientation="Horizontal" Spacing="10">
						<TextBlock Text="Efficiency" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Width="80" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding DeptEfficiency}" Maximum="100" Height="12" Width="300"
                            Foreground="{DynamicResource BrushSuccess}" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding DeptEfficiency, StringFormat='{}{0}%'}"
                            FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center"/>
					</StackPanel>
					<StackPanel Orientation="Horizontal" Spacing="10">
						<TextBlock Text="Stress" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Width="80" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding DeptStress}" Maximum="100" Height="12" Width="300"
                            Foreground="{DynamicResource BrushDanger}" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding DeptStress, StringFormat='{}{0}%'}"
                            FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- MAINTENANCE OPTIONS -->
			<Border Padding="24" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel Spacing="16">
					<TextBlock FontSize="20" FontWeight="Bold" Text="Maintenance Options"/>

					<Grid ColumnDefinitions="*,20,*,20,*">

						<!-- Light Maintenance -->
						<Border Grid.Column="0" Padding="20" Background="{DynamicResource BrushBgNested}" CornerRadius="10">
							<StackPanel Spacing="12">
								<TextBlock Text="🔩 Light" FontSize="18" FontWeight="Bold"/>
								<TextBlock Text="Quick tune-up. Best for regular upkeep."
                                    FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"/>
								<StackPanel Spacing="4">
									<TextBlock Text="− 15% Stress" FontSize="12" Foreground="{DynamicResource BrushSuccess}"/>
									<TextBlock Text="+ 3% Efficiency" FontSize="12" Foreground="{DynamicResource BrushSuccess}"/>
									<TextBlock Text="Cost: $1,000" FontSize="12" Foreground="{DynamicResource BrushDeptWarehouse}"/>
								</StackPanel>
								<Button
                                    HorizontalAlignment="Stretch"
                                    Padding="12,9"
                                    Background="{DynamicResource BrushBorderStrong}"
                                    CornerRadius="8"
                                    Command="{Binding LightMaintenanceCommand}"
                                    Content="Schedule"/>
							</StackPanel>
						</Border>

						<!-- Emergency Repair -->
						<Border Grid.Column="2" Padding="20" Background="{DynamicResource BrushBgNested}" CornerRadius="10">
							<StackPanel Spacing="12">
								<TextBlock Text="⚡ Emergency" FontSize="18" FontWeight="Bold"/>
								<TextBlock Text="Rapid repair for active failures."
                                    FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"/>
								<StackPanel Spacing="4">
									<TextBlock Text="− 25% Stress" FontSize="12" Foreground="{DynamicResource BrushSuccess}"/>
									<TextBlock Text="+ 5% Efficiency" FontSize="12" Foreground="{DynamicResource BrushSuccess}"/>
									<TextBlock Text="Resolves 1 event" FontSize="12" Foreground="{DynamicResource BrushInfo}"/>
									<TextBlock Text="Cost: $2,500" FontSize="12" Foreground="{DynamicResource BrushDeptWarehouse}"/>
								</StackPanel>
								<Button
                                    HorizontalAlignment="Stretch"
                                    Padding="12,9"
                                    Background="{DynamicResource BrushBorderStrong}"
                                    CornerRadius="8"
                                    Command="{Binding EmergencyRepairCommand}"
                                    Content="Schedule"/>
							</StackPanel>
						</Border>

						<!-- Full Overhaul -->
						<Border Grid.Column="4" Padding="20" Background="{DynamicResource BrushBgNested}" CornerRadius="10">
							<StackPanel Spacing="12">
								<TextBlock Text="🏭 Full Overhaul" FontSize="18" FontWeight="Bold"/>
								<TextBlock Text="Complete line overhaul. Takes 4 ticks."
                                    FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"/>
								<StackPanel Spacing="4">
									<TextBlock Text="− 40% Stress" FontSize="12" Foreground="{DynamicResource BrushSuccess}"/>
									<TextBlock Text="+ 10% Efficiency" FontSize="12" Foreground="{DynamicResource BrushSuccess}"/>
									<TextBlock Text="Cost: $5,000" FontSize="12" Foreground="{DynamicResource BrushDeptWarehouse}"/>
								</StackPanel>
								<Button
                                    HorizontalAlignment="Stretch"
                                    Padding="12,9"
                                    Background="{DynamicResource BrushBorderStrong}"
                                    CornerRadius="8"
                                    Command="{Binding FullOverhaulCommand}"
                                    Content="Schedule"/>
							</StackPanel>
						</Border>

					</Grid>

					<Border
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
						<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
					</Border>
				</StackPanel>
			</Border>

			<!-- MAINTENANCE LOG -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="20" FontWeight="Bold" Text="Maintenance Log" Margin="0,0,0,12"/>
					<TextBlock IsVisible="{Binding !Log.Count}" Text="No maintenance performed yet." Foreground="{DynamicResource BrushTextSecondary}"/>
					<ItemsControl ItemsSource="{Binding Log}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,4" Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="Auto,*,120">
										<Border
                                            Grid.Column="0"
                                            Padding="8,3"
                                            CornerRadius="5"
                                            Background="{DynamicResource BrushBorderStrong}"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Center">
											<TextBlock Text="{Binding Type}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"/>
										</Border>
										<TextBlock Grid.Column="1" FontSize="13" Text="{Binding Description}" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="2" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                            Text="{Binding Timestamp}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>