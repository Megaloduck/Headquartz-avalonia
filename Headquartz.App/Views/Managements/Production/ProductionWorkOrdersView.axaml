<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.ProductionWorkOrdersView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
			<StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Work Order"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Order creation, material requisition, production routing, and labor hour tracking."/>
			</StackPanel>	

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- ACTIONS + FILTER ROW -->
			<Grid ColumnDefinitions="Auto,*">

				<Button
                    Grid.Column="0"
                    Padding="14,9"
                    Background="{DynamicResource BrushAccentPrimary}"
                    CornerRadius="8"
                    Command="{Binding AddWorkOrderCommand}"
                    Content="＋  New Work Order"/>

				<ItemsControl Grid.Column="1" ItemsSource="{Binding Filters}" Margin="16,0,0,0">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Horizontal" Spacing="8"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Button
                                Padding="14,8"
                                CornerRadius="8"
                                Background="{DynamicResource BrushBgCard}"
                                Command="{Binding $parent[ItemsControl].DataContext.SetFilterCommand}"
                                CommandParameter="{Binding}"
                                Content="{Binding}"/>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

			</Grid>

			<!-- TASK LIST -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>

					<TextBlock
                        IsVisible="{Binding !Tasks.Count}"
                        Text="No work orders match this filter."
                        Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding Tasks}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="16" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<StackPanel Spacing="10">

										<!-- Title row -->
										<Grid ColumnDefinitions="*,90,90,Auto">

											<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
												<TextBlock
                                                    FontWeight="SemiBold"
                                                    FontSize="14"
                                                    Text="{Binding Name}"
                                                    VerticalAlignment="Center"/>
												<Border
                                                    IsVisible="{Binding IsBlocked}"
                                                    Background="{DynamicResource BrushBadgeDangerBg}"
                                                    CornerRadius="5"
                                                    Padding="6,2"
                                                    VerticalAlignment="Center">
													<TextBlock
                                                        Text="BLOCKED"
                                                        FontSize="10"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource BrushBadgeDangerFg}"/>
												</Border>
											</StackPanel>

											<Border
                                                Grid.Column="1"
                                                Padding="8,3"
                                                CornerRadius="6"
                                                Background="{DynamicResource BrushBgInput}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
												<TextBlock
                                                    FontSize="11"
                                                    Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding Priority, StringFormat='P: {0}'}"/>
											</Border>

											<TextBlock
                                                Grid.Column="2"
                                                FontSize="12"
                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Status}"
                                                VerticalAlignment="Center"/>

											<Button
                                                Grid.Column="3"
                                                Padding="10,5"
                                                FontSize="11"
                                                Background="{DynamicResource BrushBadgeDangerBg}"
                                                CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].DataContext.CancelTaskCommand}"
                                                CommandParameter="{Binding}"
                                                Content="✕ Cancel"/>
										</Grid>

										<!-- Progress bar -->
										<StackPanel Orientation="Horizontal" Spacing="10">
											<ProgressBar
                                                Value="{Binding Progress}"
                                                Maximum="1.0"
                                                Height="7"
                                                Width="300"
                                                Foreground="{DynamicResource BrushAccentPrimary}"
                                                VerticalAlignment="Center"/>
											<TextBlock
                                                FontSize="12"
                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Progress, StringFormat='{}{0:P0}'}"
                                                VerticalAlignment="Center"/>
										</StackPanel>

										<!-- Meta -->
										<StackPanel Orientation="Horizontal" Spacing="20">
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Workers, StringFormat='👷 {0} workers'}"/>
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding RemainingTicks, StringFormat='⏱ {0} ticks left'}"/>
										</StackPanel>

									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>