<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Headquartz.App.ProductionDashboardView">

		<ScrollViewer>
			<StackPanel Margin="30" Spacing="20">

				<!-- HEADER -->
				<StackPanel Spacing="4">
					<TextBlock FontSize="34" FontWeight="Bold" Text="Production Dasboard"/>
					<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Production department overview, operation scheduling, machine status, output rates, quality metrics."/>
				</StackPanel>	

				<!-- DEPT CRISIS BANNER -->
				<Border
					IsVisible="{Binding IsDeptCritical}"
					Background="{DynamicResource BrushWarning}"
					CornerRadius="12"
					Padding="20">
					<StackPanel Orientation="Horizontal" Spacing="12">
						<TextBlock Text="🏭" FontSize="22" VerticalAlignment="Center"/>
						<StackPanel>
							<TextBlock Text="PRODUCTION UNDER CRITICAL STRESS" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrushWarning}"/>
							<TextBlock
								Text="{Binding DeptStress, StringFormat='Stress level at {0}%. Output degraded. Maintenance required.'}"
								Foreground="{DynamicResource BrushWarning}"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

				<!-- DEPT HEALTH BARS -->
				<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="12">
						<TextBlock FontSize="18" FontWeight="Bold" Text="Department Health"/>

						<StackPanel Spacing="4">
							<StackPanel Orientation="Horizontal" Spacing="8">
								<TextBlock Text="Efficiency" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Width="80"/>
								<ProgressBar
									Value="{Binding DeptEfficiency}"
									Maximum="100"
									Height="10"
									Width="260"
									Foreground="{DynamicResource BrushSuccess}"
									VerticalAlignment="Center"/>
								<TextBlock
									Text="{Binding DeptEfficiency, StringFormat={}{0}%}"
									FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"/>
							</StackPanel>

							<StackPanel Orientation="Horizontal" Spacing="8">
								<TextBlock Text="Stress" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Width="80"/>
								<ProgressBar
									Value="{Binding DeptStress}"
									Maximum="100"
									Height="10"
									Width="260"
									Foreground="{DynamicResource BrushDanger}"
									VerticalAlignment="Center"/>
								<TextBlock
									Text="{Binding DeptStress, StringFormat={}{0}%}"
									FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"/>
							</StackPanel>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- ACTIONS -->
				<WrapPanel ItemSpacing="10">
					<Button Padding="14" Margin="0,5" Command="{Binding StartProductionRunCommand}" Content="▶  Start Production Run"/>
					<Button Padding="14" Margin="0,5" Command="{Binding ScheduleMaintenanceCommand}" Content="🔧  Schedule Maintenance (−20% Stress)"/>
				</WrapPanel>

				<!-- WORK ORDERS -->
				<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel>
						<TextBlock FontSize="22" FontWeight="Bold" Text="Work Orders" Margin="0,0,0,16"/>

						<TextBlock
							IsVisible="{Binding !WorkOrders.Count}"
							Text="No active work orders."
							Foreground="{DynamicResource BrushTextSecondary}"/>

						<ItemsControl ItemsSource="{Binding WorkOrders}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border Margin="0,5" Padding="14" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
										<StackPanel Spacing="8">

											<Grid ColumnDefinitions="*,Auto,Auto">
												<TextBlock
													Grid.Column="0"
													FontWeight="SemiBold"
													Text="{Binding Name}"/>
												<TextBlock
													Grid.Column="1"
													Margin="12,0"
													FontSize="11"
													Foreground="{DynamicResource BrushTextSecondary}"
													Text="{Binding Priority, StringFormat='[{0}]'}"
													VerticalAlignment="Center"/>
												<TextBlock
													Grid.Column="2"
													FontSize="12"
													Foreground="{DynamicResource BrushTextSecondary}"
													Text="{Binding Status}"
													VerticalAlignment="Center"/>
											</Grid>

											<!-- Progress bar -->
											<StackPanel Orientation="Horizontal" Spacing="8">
												<ProgressBar
													Value="{Binding Progress}"
													Maximum="1.0"
													Height="6"
													Width="320"
													Foreground="{DynamicResource BrushAccentPrimary}"
													VerticalAlignment="Center"/>
												<TextBlock
													FontSize="11"
													Foreground="{DynamicResource BrushTextSecondary}"
													Text="{Binding Progress, StringFormat={}{0:P0}}"
													VerticalAlignment="Center"/>
											</StackPanel>

											<StackPanel Orientation="Horizontal" Spacing="16">
												<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
													Text="{Binding Workers, StringFormat='👷 {0} workers'}"/>
												<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
													Text="{Binding RemainingTicks, StringFormat='⏱ {0} ticks left'}"/>
												<TextBlock FontSize="11" Foreground="{DynamicResource BrushDanger}"
													IsVisible="{Binding IsBlocked}"
													Text="⚠ BLOCKED — no workers available"/>
											</StackPanel>

										</StackPanel>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

					</StackPanel>
				</Border>

				<!-- PRODUCTION EVENTS -->
				<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel>
						<TextBlock FontSize="22" FontWeight="Bold" Text="Production Alerts" Margin="0,0,0,12"/>

						<TextBlock
							IsVisible="{Binding !Events.Count}"
							Text="No active alerts."
							Foreground="{DynamicResource BrushTextSecondary}"/>

						<ItemsControl ItemsSource="{Binding Events}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border Margin="0,6" Padding="14" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
										<StackPanel>
											<TextBlock FontSize="15" FontWeight="Bold" Text="{Binding Title}"/>
											<TextBlock Margin="0,4" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Description}" TextWrapping="Wrap"/>
											<StackPanel Orientation="Horizontal" Spacing="16">
												<TextBlock FontSize="12" Foreground="{DynamicResource BrushDeptWarehouse}"
													Text="{Binding Severity, StringFormat='Severity: {0}'}"/>
												<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
													Text="{Binding RemainingTicks, StringFormat='Ticks left: {0}'}"/>
											</StackPanel>
										</StackPanel>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
				</Border>

			</StackPanel>
		</ScrollViewer>

	</UserControl>
