<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.MarketingProductView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<TextBlock FontSize="34" FontWeight="Bold" Text="Product Research"/>
			<TextBlock FontSize="13" Foreground="#6B7280"
                Text="Develop new products from concept to market-ready. Each launch boosts reputation."/>

			<!-- KPIs -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="10" Padding="20" Background="#202633" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="#9CA3AF" Text="{Binding Title}"/>
								<TextBlock FontSize="26" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- PIPELINE FLOW -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel Spacing="10">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Development Pipeline"/>
					<StackPanel Orientation="Horizontal" Spacing="0">

						<Border Padding="16,10" Background="#1E3A5F" CornerRadius="8" Margin="0,0,4,0">
							<StackPanel HorizontalAlignment="Center">
								<TextBlock Text="💡 Concept" FontSize="12" FontWeight="Bold"
                                    Foreground="#93C5FD" HorizontalAlignment="Center"/>
								<TextBlock Text="{Binding ConceptCount}" FontSize="22"
                                    FontWeight="Bold" HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>

						<TextBlock Text="→" FontSize="18" Foreground="#374151"
                            VerticalAlignment="Center" Margin="4,0"/>

						<Border Padding="16,10" Background="#78350F" CornerRadius="8" Margin="0,0,4,0">
							<StackPanel HorizontalAlignment="Center">
								<TextBlock Text="🔬 Research" FontSize="12" FontWeight="Bold"
                                    Foreground="#FDE68A" HorizontalAlignment="Center"/>
								<TextBlock Text="{Binding InResearchCount}" FontSize="22"
                                    FontWeight="Bold" HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>

						<TextBlock Text="→" FontSize="18" Foreground="#374151"
                            VerticalAlignment="Center" Margin="4,0"/>

						<Border Padding="16,10" Background="#14532D" CornerRadius="8">
							<StackPanel HorizontalAlignment="Center">
								<TextBlock Text="✅ Ready" FontSize="12" FontWeight="Bold"
                                    Foreground="#86EFAC" HorizontalAlignment="Center"/>
								<TextBlock Text="{Binding ReadyCount}" FontSize="22"
                                    FontWeight="Bold" HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>

					</StackPanel>
				</StackPanel>
			</Border>

			<!-- ACTIONS -->
			<WrapPanel>
				<Button Padding="14" Margin="10" Background="#6366F1" CornerRadius="8"
                    Command="{Binding AddConceptCommand}"
                    Content="＋  New Product Concept"/>
			</WrapPanel>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="#2B3242" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- PIPELINE TABLE -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Product Pipeline" Margin="0,0,0,16"/>

					<TextBlock IsVisible="{Binding !Pipeline.Count}"
                        Text="No products in pipeline." Foreground="#6B7280"/>

					<ItemsControl ItemsSource="{Binding Pipeline}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="16" Background="#2B3242" CornerRadius="8">
									<Grid ColumnDefinitions="*,90,100,110,Auto">

										<StackPanel Grid.Column="0">
											<TextBlock FontWeight="Bold" FontSize="14"
                                                Text="{Binding Name}"/>
											<StackPanel Orientation="Horizontal" Spacing="12">
												<TextBlock FontSize="12" Foreground="#6B7280"
                                                    Text="{Binding Category}"/>
												<TextBlock FontSize="12" Foreground="#6B7280"
                                                    Text="{Binding TimeToMarket, StringFormat='{}{0} ticks'}"/>
											</StackPanel>
										</StackPanel>

										<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
											<TextBlock FontSize="11" Foreground="#6B7280" Text="Market Fit"/>
											<ProgressBar Value="{Binding MarketFit}" Maximum="100"
                                                Height="5" Width="70" Foreground="#F59E0B"/>
										</StackPanel>

										<TextBlock Grid.Column="2"
                                            Text="{Binding DevelopmentCost, StringFormat='${0:N0}'}"
                                            Foreground="#EF4444" VerticalAlignment="Center"/>

										<Border Grid.Column="3" Padding="8,3" CornerRadius="6"
                                                Background="#1F2937" VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
											<TextBlock FontSize="11" FontWeight="Bold"
                                                Text="{Binding Status}" Foreground="#9CA3AF"/>
										</Border>

										<StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6">
											<Button IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                Padding="10,6" Background="#6366F1" CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].DataContext.StartResearchCommand}"
                                                CommandParameter="{Binding}"
                                                Content="🔬 Research"/>
											<Button IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                Padding="10,6" Background="#10B981" CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].DataContext.AdvanceToReadyCommand}"
                                                CommandParameter="{Binding}"
                                                Content="✅ Complete"/>
										</StackPanel>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>	