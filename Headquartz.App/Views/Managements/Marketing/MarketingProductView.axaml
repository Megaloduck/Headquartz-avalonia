<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.MarketingProductView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
                <TextBlock FontSize="34" FontWeight="Bold" Text="Product Research"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}"	 Text="Product life cycle analysis, customer feedback loops, and feature prioritization."/>
            </StackPanel>	

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- PIPELINE FLOW -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel Spacing="10">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Development Pipeline"/>
					<StackPanel Orientation="Horizontal" Spacing="0">

						<Border Padding="16,10" Background="{DynamicResource BrushAlertInfoBg}" CornerRadius="8" Margin="0,0,4,0">
							<StackPanel HorizontalAlignment="Center">
								<TextBlock Text="💡 Concept" FontSize="12" FontWeight="Bold"
                                    Foreground="{DynamicResource BrushBadgeInfoFg}" HorizontalAlignment="Center"/>
								<TextBlock Text="{Binding ConceptCount}" FontSize="22"
                                    FontWeight="Bold" HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>

						<TextBlock Text="→" FontSize="18" Foreground="{DynamicResource BrushBorderStrong}"
                            VerticalAlignment="Center" Margin="4,0"/>

						<Border Padding="16,10" Background="{DynamicResource BrushAlertWarningBg}" CornerRadius="8" Margin="0,0,4,0">
							<StackPanel HorizontalAlignment="Center">
								<TextBlock Text="🔬 Research" FontSize="12" FontWeight="Bold"
                                    Foreground="{DynamicResource BrushWarning}" HorizontalAlignment="Center"/>
								<TextBlock Text="{Binding InResearchCount}" FontSize="22"
                                    FontWeight="Bold" HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>

						<TextBlock Text="→" FontSize="18" Foreground="{DynamicResource BrushBorderStrong}"
                            VerticalAlignment="Center" Margin="4,0"/>

						<Border Padding="16,10" Background="{DynamicResource BrushBadgeSuccessBg}" CornerRadius="8">
							<StackPanel HorizontalAlignment="Center">
								<TextBlock Text="✅ Ready" FontSize="12" FontWeight="Bold"
                                    Foreground="{DynamicResource BrushBadgeSuccessFg}" HorizontalAlignment="Center"/>
								<TextBlock Text="{Binding ReadyCount}" FontSize="22"
                                    FontWeight="Bold" HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>

					</StackPanel>
				</StackPanel>
			</Border>

			<!-- ACTIONS -->
			<WrapPanel ItemSpacing="10">
				<Button Padding="14" Margin="0,5	" Background="{DynamicResource BrushAccentPrimary}" CornerRadius="8"
                    Command="{Binding AddConceptCommand}"
                    Content="＋  New Product Concept"/>
			</WrapPanel>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- PIPELINE TABLE -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Product Pipeline" Margin="0,0,0,16"/>

					<TextBlock IsVisible="{Binding !Pipeline.Count}"
                        Text="No products in pipeline." Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding Pipeline}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="16" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,90,100,110,Auto">

										<StackPanel Grid.Column="0">
											<TextBlock FontWeight="Bold" FontSize="14"
                                                Text="{Binding Name}"/>
											<StackPanel Orientation="Horizontal" Spacing="12">
												<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding Category}"/>
												<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding TimeToMarket, StringFormat='{}{0} ticks'}"/>
											</StackPanel>
										</StackPanel>

										<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Text="Market Fit"/>
											<ProgressBar Value="{Binding MarketFit}" Maximum="100"
                                                Height="5" Width="70" Foreground="{DynamicResource BrushWarning}"/>
										</StackPanel>

										<TextBlock Grid.Column="2"
                                            Text="{Binding DevelopmentCost, StringFormat='${0:N0}'}"
                                            Foreground="{DynamicResource BrushDanger}" VerticalAlignment="Center"/>

										<Border Grid.Column="3" Padding="8,3" CornerRadius="6"
                                                Background="{DynamicResource BrushBgInput}" VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
											<TextBlock FontSize="11" FontWeight="Bold"
                                                Text="{Binding Status}" Foreground="{DynamicResource BrushTextSecondary}"/>
										</Border>

										<StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6">
											<Button IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                Padding="10,6" Background="{DynamicResource BrushAccentPrimary}" CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].DataContext.StartResearchCommand}"
                                                CommandParameter="{Binding}"
                                                Content="🔬 Research"/>
											<Button IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                Padding="10,6" Background="{DynamicResource BrushSuccess}" CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].DataContext.AdvanceToReadyCommand}"
                                                CommandParameter="{Binding}"
                                                Content="✅ Complete"/>
										</StackPanel>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>	