<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.MarketingCampaignsView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
                <TextBlock FontSize="34" FontWeight="Bold" Text="Campaign"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}"	 Text="Campaign planning, channel selection (event, social, ads), budget setting, and A/B testing."/>
            </StackPanel>	

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- CAMPAIGN TYPES -->
			<TextBlock FontSize="22" FontWeight="Bold" Text="Launch Campaign"/>

			<Grid ColumnDefinitions="*,12,*">

				<Border Grid.Column="0" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="10">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="📱" FontSize="26"/>
							<StackPanel>
								<TextBlock FontSize="15" FontWeight="Bold" Text="Social Media Blitz"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$3,000 · +5 Rep · 8 ticks"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Broad digital reach. Fast reputation boost across all audiences."/>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="{DynamicResource BrushWarning}" CornerRadius="8"
                            Command="{Binding LaunchSocialMediaCommand}"
                            Content="Launch"/>
					</StackPanel>
				</Border>

				<Border Grid.Column="2" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="10">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="📧" FontSize="26"/>
							<StackPanel>
								<TextBlock FontSize="15" FontWeight="Bold" Text="Email Campaign"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$1,500 · +3 Rep · 6 ticks"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Targeted outreach to existing clients. Cost-effective retention tool."/>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="{DynamicResource BrushInfo}" CornerRadius="8"
                            Command="{Binding LaunchEmailCampaignCommand}"
                            Content="Launch"/>
					</StackPanel>
				</Border>

			</Grid>

			<Grid ColumnDefinitions="*,12,*">

				<Border Grid.Column="0" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="10">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="📰" FontSize="26"/>
							<StackPanel>
								<TextBlock FontSize="15" FontWeight="Bold" Text="Brand Awareness Drive"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$5,000 · +8 Rep · 12 ticks"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="PR-focused campaign. Builds long-term brand equity and reputation."/>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="{DynamicResource BrushDeptHR}" CornerRadius="8"
                            Command="{Binding LaunchBrandAwarenessCommand}"
                            Content="Launch"/>
					</StackPanel>
				</Border>

				<Border Grid.Column="2" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="10">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="🎪" FontSize="26"/>
							<StackPanel>
								<TextBlock FontSize="15" FontWeight="Bold" Text="Product Launch Event"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$8,000 · +12 Rep · 10 ticks"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="High-impact launch event targeting industry leads and press."/>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="{DynamicResource BrushDanger}" CornerRadius="8"
                            Command="{Binding LaunchProductLaunchCommand}"
                            Content="Launch"/>
					</StackPanel>
				</Border>

			</Grid>

			<!-- ACTIVE CAMPAIGNS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Campaign Status" Margin="0,0,0,16"/>

					<TextBlock IsVisible="{Binding !Campaigns.Count}"
                        Text="No campaigns launched yet." Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding Campaigns}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="16" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,80,100,80,Auto">

										<StackPanel Grid.Column="0">
											<TextBlock FontWeight="Bold" FontSize="14"
                                                Text="{Binding Name}"/>
											<StackPanel Orientation="Horizontal" Spacing="12">
												<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding Type}"/>
												<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                    Text="{Binding Target}"/>
											</StackPanel>
										</StackPanel>

										<TextBlock Grid.Column="1"
                                            Text="{Binding Budget, StringFormat='${0:N0}'}"
                                            Foreground="{DynamicResource BrushWarning}" VerticalAlignment="Center"/>

										<Border Grid.Column="2" Padding="8,3" CornerRadius="6"
                                                Background="{DynamicResource BrushBgInput}" VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
											<TextBlock FontSize="11" FontWeight="Bold"
                                                Text="{Binding Status}" Foreground="{DynamicResource BrushTextSecondary}"/>
										</Border>

										<TextBlock Grid.Column="3" FontSize="12"
                                            Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center"
                                            Text="{Binding TicksRemaining, StringFormat='⏱ {0}t'}"/>

										<Button Grid.Column="4"
                                            IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                            Padding="10,6" Background="{DynamicResource BrushBadgeDangerBg}" CornerRadius="6"
                                            VerticalAlignment="Center"
                                            Command="{Binding $parent[ItemsControl].DataContext.CancelCampaignCommand}"
                                            CommandParameter="{Binding}"
                                            Content="✕ Cancel"/>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>