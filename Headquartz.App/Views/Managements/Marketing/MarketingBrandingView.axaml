<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.MarketingBrandingView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
                <TextBlock FontSize="34" FontWeight="Bold" Text="Branding"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}"	 Text="Brand guidelines, advertising materials, content calendar, and brand sentiment."/>
            </StackPanel>		

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- BRAND HEALTH BARS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel Spacing="12">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Brand Health"/>

					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Brand Score" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Width="100" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding BrandScore}" Maximum="100"
                            Height="12" Width="300" Foreground="{DynamicResource BrushAccentPrimary}" VerticalAlignment="Center"/>
						<TextBlock FontSize="13" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"
                            Text="{Binding BrandScore, StringFormat='{}{0}/100'}"
                            VerticalAlignment="Center"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Trust" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Width="100" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding TrustLevel}" Maximum="100"
                            Height="12" Width="300" Foreground="{DynamicResource BrushSuccess}" VerticalAlignment="Center"/>
						<TextBlock FontSize="13" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"
                            Text="{Binding TrustLevel, StringFormat='{}{0}/100'}"
                            VerticalAlignment="Center"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Visibility" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Width="100" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding VisibilityLevel}" Maximum="100"
                            Height="12" Width="300" Foreground="{DynamicResource BrushWarning}" VerticalAlignment="Center"/>
						<TextBlock FontSize="13" FontWeight="Bold" Foreground="{DynamicResource BrushTextSecondary}"
                            Text="{Binding VisibilityLevel, StringFormat='{}{0}/100'}"
                            VerticalAlignment="Center"/>
					</StackPanel>

				</StackPanel>
			</Border>

			<!-- BRANDING ACTIONS -->
			<Grid ColumnDefinitions="*,12,*">

				<Border Grid.Column="0" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="10">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="🎨" FontSize="26"/>
							<StackPanel>
								<TextBlock FontSize="15" FontWeight="Bold" Text="Full Rebranding"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$10,000"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Complete brand overhaul. Maximum impact on all brand metrics."/>
						<Border Padding="10,6" Background="{DynamicResource BrushBgBase}" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="{DynamicResource BrushAccentPrimaryHover}"
                                Text="+10 Rep · +20 Visibility · +5 Trust"/>
						</Border>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="{DynamicResource BrushAccentPrimary}" CornerRadius="8"
                            Command="{Binding RunRebrandingCommand}"
                            Content="Execute Rebranding"/>
					</StackPanel>
				</Border>

				<Border Grid.Column="2" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="10">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="✏️" FontSize="26"/>
							<StackPanel>
								<TextBlock FontSize="15" FontWeight="Bold" Text="Logo Refresh"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$2,000"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Modernize the visual identity. Light lift, quick win."/>
						<Border Padding="10,6" Background="{DynamicResource BrushBadgeSuccessBg}" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="{DynamicResource BrushBadgeSuccessFg}"
                                Text="+3 Rep · +8 Visibility"/>
						</Border>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="{DynamicResource BrushSuccess}" CornerRadius="8"
                            Command="{Binding RunLogoRefreshCommand}"
                            Content="Refresh Logo"/>
					</StackPanel>
				</Border>

			</Grid>

			<Grid ColumnDefinitions="*,12,*">

				<Border Grid.Column="0" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="10">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="🤝" FontSize="26"/>
							<StackPanel>
								<TextBlock FontSize="15" FontWeight="Bold" Text="Sponsorship Deal"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$5,000"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Partner with an industry event to boost trust and visibility."/>
						<Border Padding="10,6" Background="{DynamicResource BrushAlertWarningBg}" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="{DynamicResource BrushWarning}"
                                Text="+7 Rep · +10 Trust · +12 Visibility"/>
						</Border>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="{DynamicResource BrushWarning}" CornerRadius="8"
                            Command="{Binding RunSponsorshipDealCommand}"
                            Content="Secure Sponsorship"/>
					</StackPanel>
				</Border>

				<Border Grid.Column="2" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="10">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="📢" FontSize="26"/>
							<StackPanel>
								<TextBlock FontSize="15" FontWeight="Bold" Text="PR Statement"/>
								<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$1,500"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Issue a public statement. Resolves one active event and boosts trust."/>
						<Border Padding="10,6" Background="{DynamicResource BrushAlertInfoBg}" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="{DynamicResource BrushBadgeInfoFg}"
                                Text="+4 Rep · +8 Trust · 1 Event Resolved"/>
						</Border>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="{DynamicResource BrushInfo}" CornerRadius="8"
                            Command="{Binding RunPRStatementCommand}"
                            Content="Release Statement"/>
					</StackPanel>
				</Border>

			</Grid>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- ACTIVITY LOG -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Brand Activity Log" Margin="0,0,0,12"/>

					<TextBlock IsVisible="{Binding !ActivityLog.Count}"
                        Text="No brand activities yet." Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding ActivityLog}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,3" Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,200,100">
										<TextBlock Grid.Column="0" FontWeight="SemiBold"
                                            Text="{Binding Activity}" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="1" FontSize="12"
                                            Foreground="{DynamicResource BrushSuccess}" Text="{Binding Impact}"
                                            VerticalAlignment="Center"/>
										<TextBlock Grid.Column="2" FontSize="11"
                                            Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Timestamp}"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"/>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>