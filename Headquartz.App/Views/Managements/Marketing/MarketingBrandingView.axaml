<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.MarketingBrandingView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<TextBlock FontSize="34" FontWeight="Bold" Text="Branding"/>
			<TextBlock FontSize="13" Foreground="#6B7280"
                Text="Build brand equity through visibility, trust, and consistent market presence."/>

			<!-- KPIs -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="180" Margin="8" Padding="18" Background="#202633" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="#9CA3AF" Text="{Binding Title}"/>
								<TextBlock FontSize="26" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- BRAND HEALTH BARS -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel Spacing="12">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Brand Health"/>

					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Brand Score" FontSize="12" Foreground="#9CA3AF"
                            Width="100" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding BrandScore}" Maximum="100"
                            Height="12" Width="300" Foreground="#6366F1" VerticalAlignment="Center"/>
						<TextBlock FontSize="13" FontWeight="Bold" Foreground="#9CA3AF"
                            Text="{Binding BrandScore, StringFormat='{}{0}/100'}"
                            VerticalAlignment="Center"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Trust" FontSize="12" Foreground="#9CA3AF"
                            Width="100" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding TrustLevel}" Maximum="100"
                            Height="12" Width="300" Foreground="#10B981" VerticalAlignment="Center"/>
						<TextBlock FontSize="13" FontWeight="Bold" Foreground="#9CA3AF"
                            Text="{Binding TrustLevel, StringFormat='{}{0}/100'}"
                            VerticalAlignment="Center"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Visibility" FontSize="12" Foreground="#9CA3AF"
                            Width="100" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding VisibilityLevel}" Maximum="100"
                            Height="12" Width="300" Foreground="#F59E0B" VerticalAlignment="Center"/>
						<TextBlock FontSize="13" FontWeight="Bold" Foreground="#9CA3AF"
                            Text="{Binding VisibilityLevel, StringFormat='{}{0}/100'}"
                            VerticalAlignment="Center"/>
					</StackPanel>

				</StackPanel>
			</Border>

			<!-- BRANDING ACTIONS -->
			<Grid ColumnDefinitions="*,12,*">

				<Border Grid.Column="0" Padding="20" Background="#202633" CornerRadius="12">
					<StackPanel Spacing="10">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="🎨" FontSize="26"/>
							<StackPanel>
								<TextBlock FontSize="15" FontWeight="Bold" Text="Full Rebranding"/>
								<TextBlock FontSize="12" Foreground="#6B7280" Text="$10,000"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="#9CA3AF" TextWrapping="Wrap"
                            Text="Complete brand overhaul. Maximum impact on all brand metrics."/>
						<Border Padding="10,6" Background="#1E1B4B" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="#818CF8"
                                Text="+10 Rep · +20 Visibility · +5 Trust"/>
						</Border>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="#6366F1" CornerRadius="8"
                            Command="{Binding RunRebrandingCommand}"
                            Content="Execute Rebranding"/>
					</StackPanel>
				</Border>

				<Border Grid.Column="2" Padding="20" Background="#202633" CornerRadius="12">
					<StackPanel Spacing="10">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="✏️" FontSize="26"/>
							<StackPanel>
								<TextBlock FontSize="15" FontWeight="Bold" Text="Logo Refresh"/>
								<TextBlock FontSize="12" Foreground="#6B7280" Text="$2,000"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="#9CA3AF" TextWrapping="Wrap"
                            Text="Modernize the visual identity. Light lift, quick win."/>
						<Border Padding="10,6" Background="#14532D" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="#86EFAC"
                                Text="+3 Rep · +8 Visibility"/>
						</Border>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="#10B981" CornerRadius="8"
                            Command="{Binding RunLogoRefreshCommand}"
                            Content="Refresh Logo"/>
					</StackPanel>
				</Border>

			</Grid>

			<Grid ColumnDefinitions="*,12,*">

				<Border Grid.Column="0" Padding="20" Background="#202633" CornerRadius="12">
					<StackPanel Spacing="10">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="🤝" FontSize="26"/>
							<StackPanel>
								<TextBlock FontSize="15" FontWeight="Bold" Text="Sponsorship Deal"/>
								<TextBlock FontSize="12" Foreground="#6B7280" Text="$5,000"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="#9CA3AF" TextWrapping="Wrap"
                            Text="Partner with an industry event to boost trust and visibility."/>
						<Border Padding="10,6" Background="#78350F" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="#FDE68A"
                                Text="+7 Rep · +10 Trust · +12 Visibility"/>
						</Border>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="#F59E0B" CornerRadius="8"
                            Command="{Binding RunSponsorshipDealCommand}"
                            Content="Secure Sponsorship"/>
					</StackPanel>
				</Border>

				<Border Grid.Column="2" Padding="20" Background="#202633" CornerRadius="12">
					<StackPanel Spacing="10">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="📢" FontSize="26"/>
							<StackPanel>
								<TextBlock FontSize="15" FontWeight="Bold" Text="PR Statement"/>
								<TextBlock FontSize="12" Foreground="#6B7280" Text="$1,500"/>
							</StackPanel>
						</StackPanel>
						<TextBlock FontSize="13" Foreground="#9CA3AF" TextWrapping="Wrap"
                            Text="Issue a public statement. Resolves one active event and boosts trust."/>
						<Border Padding="10,6" Background="#1E3A5F" CornerRadius="6">
							<TextBlock FontSize="12" Foreground="#93C5FD"
                                Text="+4 Rep · +8 Trust · 1 Event Resolved"/>
						</Border>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="#3B82F6" CornerRadius="8"
                            Command="{Binding RunPRStatementCommand}"
                            Content="Release Statement"/>
					</StackPanel>
				</Border>

			</Grid>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="#2B3242" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- ACTIVITY LOG -->
			<Border Padding="20" Background="#202633" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Brand Activity Log" Margin="0,0,0,12"/>

					<TextBlock IsVisible="{Binding !ActivityLog.Count}"
                        Text="No brand activities yet." Foreground="#6B7280"/>

					<ItemsControl ItemsSource="{Binding ActivityLog}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,3" Padding="14,10" Background="#2B3242" CornerRadius="8">
									<Grid ColumnDefinitions="*,200,100">
										<TextBlock Grid.Column="0" FontWeight="SemiBold"
                                            Text="{Binding Activity}" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="1" FontSize="12"
                                            Foreground="#10B981" Text="{Binding Impact}"
                                            VerticalAlignment="Center"/>
										<TextBlock Grid.Column="2" FontSize="11"
                                            Foreground="#6B7280" Text="{Binding Timestamp}"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"/>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>