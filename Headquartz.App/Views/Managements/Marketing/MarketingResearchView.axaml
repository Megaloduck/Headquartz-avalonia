<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Headquartz.App.MarketingResearchView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
				<TextBlock FontSize="34" FontWeight="Bold" Text="Market Research"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="Market trends, customer surveys, competitor analysis, and opportunity identification."/>
			</StackPanel>	

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- MARKET HEALTH BARS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel Spacing="12">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Market Indicators"/>

					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Demand" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Width="120" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding MarketDemand}" Maximum="100"
                            Height="10" Width="280" Foreground="{DynamicResource BrushSuccess}" VerticalAlignment="Center"/>
						<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Text="{Binding MarketDemand, StringFormat='{}{0}/100'}"
                            VerticalAlignment="Center"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Competitor Threat" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Width="120" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding CompetitorThreat}" Maximum="100"
                            Height="10" Width="280" Foreground="{DynamicResource BrushDanger}" VerticalAlignment="Center"/>
						<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Text="{Binding CompetitorThreat, StringFormat='{}{0}/100'}"
                            VerticalAlignment="Center"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Brand Awareness" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Width="120" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding BrandAwareness}" Maximum="100"
                            Height="10" Width="280" Foreground="{DynamicResource BrushWarning}" VerticalAlignment="Center"/>
						<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Text="{Binding BrandAwareness, StringFormat='{}{0}/100'}"
                            VerticalAlignment="Center"/>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Satisfaction" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Width="120" VerticalAlignment="Center"/>
						<ProgressBar Value="{Binding CustomerSatisfaction}" Maximum="100"
                            Height="10" Width="280" Foreground="{DynamicResource BrushAccentPrimary}" VerticalAlignment="Center"/>
						<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                            Text="{Binding CustomerSatisfaction, StringFormat='{}{0}/100'}"
                            VerticalAlignment="Center"/>
					</StackPanel>

				</StackPanel>
			</Border>

			<!-- RESEARCH ACTIONS -->
			<Grid ColumnDefinitions="*,12,*,12,*">

				<Border Grid.Column="0" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="10">
						<TextBlock Text="📋" FontSize="28"/>
						<TextBlock FontSize="15" FontWeight="Bold" Text="Customer Survey"/>
						<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$2,000"/>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Measure satisfaction and gather feedback from your client base."/>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="{DynamicResource BrushAccentPrimary}" CornerRadius="8"
                            Command="{Binding RunCustomerSurveyCommand}"
                            Content="Run Survey"/>
					</StackPanel>
				</Border>

				<Border Grid.Column="2" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="10">
						<TextBlock Text="🔍" FontSize="28"/>
						<TextBlock FontSize="15" FontWeight="Bold" Text="Competitor Analysis"/>
						<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$3,000"/>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Assess competitor positioning and identify strategic threats."/>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="{DynamicResource BrushDanger}" CornerRadius="8"
                            Command="{Binding RunCompetitorAnalysisCommand}"
                            Content="Run Analysis"/>
					</StackPanel>
				</Border>

				<Border Grid.Column="4" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
					<StackPanel Spacing="10">
						<TextBlock Text="📈" FontSize="28"/>
						<TextBlock FontSize="15" FontWeight="Bold" Text="Demand Forecast"/>
						<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Text="$1,500"/>
						<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap"
                            Text="Project market demand based on current reputation and pipeline."/>
						<Button HorizontalAlignment="Stretch" Padding="12,9"
                            Background="{DynamicResource BrushSuccess}" CornerRadius="8"
                            Command="{Binding RunDemandForecastCommand}"
                            Content="Run Forecast"/>
					</StackPanel>
				</Border>

			</Grid>

			<!-- STATUS -->
			<Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
				<TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap"/>
			</Border>

			<!-- INSIGHTS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Research Insights" Margin="0,0,0,16"/>

					<TextBlock IsVisible="{Binding !Insights.Count}"
                        Text="No research conducted yet. Run a study to generate insights."
                        Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding Insights}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="16" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<StackPanel Spacing="6">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<Border Padding="7,2" Background="{DynamicResource BrushBgInput}" CornerRadius="4">
												<TextBlock FontSize="11" FontWeight="Bold"
                                                    Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Category}"/>
											</Border>
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextMuted}"
                                                Text="{Binding DiscoveredAt}" VerticalAlignment="Center"/>
										</StackPanel>
										<TextBlock FontWeight="SemiBold" FontSize="13"
                                            Text="{Binding Finding}"/>
										<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                            Text="{Binding Recommendation, StringFormat='💡 {0}'}"
                                            TextWrapping="Wrap"/>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>