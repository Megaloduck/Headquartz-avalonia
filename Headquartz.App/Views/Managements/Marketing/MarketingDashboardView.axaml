<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.MarketingDashboardView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- HEADER -->
            <StackPanel Spacing="4">
                <TextBlock FontSize="34" FontWeight="Bold" Text="Marketing Dashboard"/>
				<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}"	 Text="Campaign performance, engagement overview, budget utilization, and lead generate totals."/>
            </StackPanel>	

			<!-- DEPT STRESS BANNER -->
			<Border IsVisible="{Binding IsDeptCritical}" Background="{DynamicResource BrushAlertWarningBg}" CornerRadius="12" Padding="20">
				<StackPanel Orientation="Horizontal" Spacing="12">
					<TextBlock Text="📣" FontSize="22" VerticalAlignment="Center"/>
					<StackPanel>
						<TextBlock Text="MARKETING UNDER STRESS" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrushWarning}"/>
						<TextBlock
                            Text="{Binding DeptStress, StringFormat='Stress at {0}%. Campaign performance degraded.'}"
                            Foreground="{DynamicResource BrushWarning}"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- KPI ROW -->
			<ItemsControl ItemsSource="{Binding Kpis}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel ItemSpacing="10"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Width="200" Margin="0,5" Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
							<StackPanel>
								<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Title}"/>
								<TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Value}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>


			<!-- DEPT HEALTH -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel Spacing="10">
					<TextBlock FontSize="18" FontWeight="Bold" Text="Department Health"/>
					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Efficiency" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Width="80"/>
						<ProgressBar Value="{Binding DeptEfficiency}" Maximum="100" Height="10" Width="260" Foreground="{DynamicResource BrushWarning}" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding DeptEfficiency, StringFormat={}{0}%}" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"/>
					</StackPanel>
					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Stress" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Width="80"/>
						<ProgressBar Value="{Binding DeptStress}" Maximum="100" Height="10" Width="260" Foreground="{DynamicResource BrushDanger}" VerticalAlignment="Center"/>
						<TextBlock Text="{Binding DeptStress, StringFormat={}{0}%}" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- ACTIONS -->
			<WrapPanel>
				<Button Padding="14" Margin="10" Command="{Binding LaunchCampaignCommand}"  Content="🚀  Launch Campaign"/>
				<Button Padding="14" Margin="10" Command="{Binding BoostBrandCommand}"       Content="⭐  Boost Brand (−$5,000 / +3 Rep)"/>
				<Button Padding="14" Margin="10" Command="{Binding RunPRCampaignCommand}"    Content="🛡  PR Campaign (Resolve 1 Event)"/>
			</WrapPanel>

			<!-- ACTIVE CAMPAIGNS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Active Campaigns" Margin="0,0,0,16"/>
					<TextBlock IsVisible="{Binding !Campaigns.Count}" Text="No active campaigns." Foreground="{DynamicResource BrushTextSecondary}"/>
					<ItemsControl ItemsSource="{Binding Campaigns}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,5" Padding="14" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<StackPanel Spacing="8">
										<Grid ColumnDefinitions="*,Auto,Auto">
											<TextBlock Grid.Column="0" FontWeight="SemiBold" Text="{Binding Name}"/>
											<TextBlock Grid.Column="1" Margin="12,0" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Priority, StringFormat='[{0}]'}" VerticalAlignment="Center"/>
											<TextBlock Grid.Column="2" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Status}" VerticalAlignment="Center"/>
										</Grid>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<ProgressBar Value="{Binding Progress}" Maximum="1.0" Height="6"
                                                Width="320" Foreground="{DynamicResource BrushWarning}" VerticalAlignment="Center"/>
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Progress, StringFormat={}{0:P0}}" VerticalAlignment="Center"/>
										</StackPanel>
										<StackPanel Orientation="Horizontal" Spacing="16">
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Workers, StringFormat='👷 {0} staff'}"/>
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding RemainingTicks, StringFormat='⏱ {0} ticks left'}"/>
											<TextBlock FontSize="11" Foreground="{DynamicResource BrushDanger}"
                                                IsVisible="{Binding IsBlocked}" Text="⚠ BLOCKED"/>
										</StackPanel>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

			<!-- EVENTS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="22" FontWeight="Bold" Text="Marketing Alerts" Margin="0,0,0,12"/>
					<TextBlock IsVisible="{Binding !Events.Count}" Text="No active alerts." Foreground="{DynamicResource BrushTextSecondary}"/>
					<ItemsControl ItemsSource="{Binding Events}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,6" Padding="14" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<StackPanel>
										<TextBlock FontSize="15" FontWeight="Bold" Text="{Binding Title}"/>
										<TextBlock Margin="0,4" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding Description}" TextWrapping="Wrap"/>
										<StackPanel Orientation="Horizontal" Spacing="16" Margin="0,6,0,0">
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushWarning}"
                                                Text="{Binding Severity, StringFormat='Severity: {0}'}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding RemainingTicks, StringFormat='Ticks left: {0}'}"/>
										</StackPanel>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>
