<Window
    Name="RootWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Headquartz.App.ViewModels"
    mc:Ignorable="d"
    x:Class="Headquartz.App.Views.MainWindow"
    x:DataType="vm:ShellViewModel"
    Width="1600"
    Height="900"
    Title="Headquartz">

	<Grid>

		<!-- ================================================= -->
		<!-- MAIN SHELL (hidden until role is selected)        -->
		<!-- ================================================= -->

		<Grid
            ColumnDefinitions="260,*"
            IsVisible="{Binding RoleSelected}">

			<!-- SIDEBAR -->
			<Border
                Grid.Column="0"
                Background="#111827"
                BorderBrush="#1F2937"
                BorderThickness="0,0,1,0">

				<DockPanel>

					<!-- HEADER: Logo -->
					<Border
                        DockPanel.Dock="Top"
                        Padding="16,14"
                        BorderBrush="#1F2937"
                        BorderThickness="0,0,0,1">

						<StackPanel Orientation="Horizontal" Spacing="10">

							<Border
                                Width="32" Height="32"
                                CornerRadius="8"
                                Background="#6366F1">
								<TextBlock
                                    Text="H"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
							</Border>

							<TextBlock
                                Text="Headquartz"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="White"
                                VerticalAlignment="Center"/>

						</StackPanel>

					</Border>

					<!-- ROLE NAME ROW -->
					<Border
                        DockPanel.Dock="Top"
                        Padding="10,8"
                        Margin="8,8,8,4"
                        CornerRadius="8"
                        Background="#1F2937">

						<Grid ColumnDefinitions="*,Auto">

							<!-- Role name -->
							<StackPanel
                                Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="8">

								<Border
                                    Width="24" Height="24"
                                    CornerRadius="12"
                                    Background="#374151">
									<TextBlock
                                        Text="&#x1F464;"
                                        FontSize="12"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
								</Border>

								<TextBlock
                                    Text="{Binding RoleName}"
                                    FontSize="13"
                                    Foreground="#D1D5DB"
                                    VerticalAlignment="Center"/>

							</StackPanel>

							<!-- Back to role select -->
							<Button
                                Grid.Column="1"
                                Padding="6,4"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="6"
                                ToolTip.Tip="Switch Role"
                                Command="{Binding BackToRoleSelectCommand}">
								<TextBlock
                                    Text="&#x21BA;"
                                    FontSize="14"
                                    Foreground="#6B7280"/>
							</Button>

						</Grid>

					</Border>

					<!-- BOTTOM: Settings + Logout -->
					<StackPanel
                        DockPanel.Dock="Bottom"
                        Margin="8,0,8,8"
                        Spacing="2">

						<Border Height="1" Margin="0,6,0,6" Background="#1F2937"/>

						<Button
                            Padding="10,8"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="6">
							<StackPanel Orientation="Horizontal" Spacing="10">
								<TextBlock Text="&#9881;" FontSize="14" Foreground="#9CA3AF" VerticalAlignment="Center"/>
								<TextBlock Text="Settings" FontSize="13" Foreground="#9CA3AF" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>

						<Button
                            Padding="10,8"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="6">
							<StackPanel Orientation="Horizontal" Spacing="10">
								<TextBlock Text="&#x2192;" FontSize="14" Foreground="#9CA3AF" VerticalAlignment="Center"/>
								<TextBlock Text="Log out" FontSize="13" Foreground="#9CA3AF" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>

					</StackPanel>

					<!-- SCROLLABLE SECTIONS -->
					<ScrollViewer
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">

						<ItemsControl Margin="8,8,8,0" ItemsSource="{Binding SidebarSections}">

							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<StackPanel Margin="0,0,0,4">

										<!-- Section Header -->
										<TextBlock
                                            Text="{Binding Title}"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="#6B7280"
                                            Margin="10,10,10,4"/>

										<!-- Section Items -->
										<ItemsControl ItemsSource="{Binding Items}">
											<ItemsControl.ItemTemplate>
												<DataTemplate>

													<Button
                                                        Padding="10,7"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        CornerRadius="6"
                                                        Margin="0,1"
                                                        Command="{Binding #RootWindow.DataContext.NavigateCommand}"
                                                        CommandParameter="{Binding}">

														<Grid ColumnDefinitions="*,Auto">

															<StackPanel
                                                                Grid.Column="0"
                                                                Orientation="Horizontal"
                                                                Spacing="10">

																<Border
                                                                    Width="18" Height="18"
                                                                    CornerRadius="4"
                                                                    Background="#374151"
                                                                    VerticalAlignment="Center">
																	<TextBlock
                                                                        Text="&#x25A0;"
                                                                        FontSize="8"
                                                                        Foreground="#9CA3AF"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
																</Border>

																<TextBlock
                                                                    Text="{Binding Title}"
                                                                    FontSize="13"
                                                                    Foreground="#D1D5DB"
                                                                    VerticalAlignment="Center"/>

															</StackPanel>

															

														</Grid>

													</Button>

												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>

									</StackPanel>
								</DataTemplate>
							</ItemsControl.ItemTemplate>

						</ItemsControl>

					</ScrollViewer>

				</DockPanel>

			</Border>

			<!-- CONTENT AREA -->
			<ContentControl
                Grid.Column="1"
                Content="{Binding CurrentView}"/>

		</Grid>

		<!-- ================================================= -->
		<!-- SPLASH SCREEN — ROLE SELECTION                    -->
		<!-- ================================================= -->

		<Grid
            IsVisible="{Binding !RoleSelected}"
            Background="#0B0F1A">

			<!-- Background subtle gradient overlay -->
			<Rectangle
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Opacity="0.4">
				<Rectangle.Fill>
					<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
						<GradientStop Color="#0D1117" Offset="0"/>
						<GradientStop Color="#0B0F1A" Offset="0.5"/>
						<GradientStop Color="#060A14" Offset="1"/>
					</LinearGradientBrush>
				</Rectangle.Fill>
			</Rectangle>

			<!-- Glow accent top-left -->
			<Ellipse
                Width="600" Height="600"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="-200,-200,0,0"
                Opacity="0.06">
				<Ellipse.Fill>
					<RadialGradientBrush>
						<GradientStop Color="#6366F1" Offset="0"/>
						<GradientStop Color="Transparent" Offset="1"/>
					</RadialGradientBrush>
				</Ellipse.Fill>
			</Ellipse>

			<!-- Glow accent bottom-right -->
			<Ellipse
                Width="500" Height="500"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,-150,-150"
                Opacity="0.05">
				<Ellipse.Fill>
					<RadialGradientBrush>
						<GradientStop Color="#06B6D4" Offset="0"/>
						<GradientStop Color="Transparent" Offset="1"/>
					</RadialGradientBrush>
				</Ellipse.Fill>
			</Ellipse>

			<!-- Main content -->
			<StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="0">

				<!-- Logo row -->
				<StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="14"
                    Margin="0,0,0,16">

					<Border
                        Width="52" Height="52"
                        CornerRadius="14"
                        Background="#6366F1">
						<TextBlock
                            Text="H"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="White"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
					</Border>

					<TextBlock
                        Text="HEADQUARTZ"
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="White"
                        LetterSpacing="6"
                        VerticalAlignment="Center"/>

				</StackPanel>

				<!-- Subtitle -->
				<TextBlock
                    Text="Enterprise Resource Planning Simulator"
                    FontSize="14"
                    Foreground="#6B7280"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8"/>

				<!-- Divider -->
				<Border
                    Height="1"
                    Width="320"
                    Background="#1F2937"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,28"/>

				<!-- Prompt -->
				<TextBlock
                    Text="SELECT YOUR ROLE"
                    FontSize="11"
                    FontWeight="Bold"
                    Foreground="#4B5563"
                    HorizontalAlignment="Center"
                    LetterSpacing="4"
                    Margin="0,0,0,24"/>

				<!-- Role cards grid -->
				<ItemsControl ItemsSource="{Binding RoleCards}">

					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel
                                MaxWidth="960"
                                HorizontalAlignment="Center"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>

					<ItemsControl.ItemTemplate>
						<DataTemplate>

							<Button
                                Width="215"
                                Height="130"
                                Margin="8"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="12"
                                Command="{Binding #RootWindow.DataContext.SelectRoleCommand}"
                                CommandParameter="{Binding}">

								<Border
                                    CornerRadius="12"
                                    Background="#111827"
                                    BorderBrush="#1F2937"
                                    BorderThickness="1">

									<Grid RowDefinitions="4,*">

										<!-- Colored top accent bar -->
										<Border
                                            Grid.Row="0"
                                            CornerRadius="12,12,0,0"
                                            Background="{Binding AccentColor}"/>

										<!-- Card content -->
										<StackPanel
                                            Grid.Row="1"
                                            Margin="18,14,18,14"
                                            Spacing="6">

											<!-- Emoji + department -->
											<StackPanel
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">

												<TextBlock
                                                    Text="{Binding Emoji}"
                                                    FontSize="20"
                                                    VerticalAlignment="Center"/>

												<TextBlock
                                                    Text="{Binding Department}"
                                                    FontSize="10"
                                                    FontWeight="SemiBold"
                                                    Foreground="#6B7280"
                                                    VerticalAlignment="Center"/>

											</StackPanel>

											<!-- Role title -->
											<TextBlock
                                                Text="{Binding Title}"
                                                FontSize="15"
                                                FontWeight="Bold"
                                                Foreground="White"/>

											<!-- Description -->
											<TextBlock
                                                Text="{Binding Description}"
                                                FontSize="11"
                                                Foreground="#9CA3AF"
                                                TextWrapping="Wrap"/>

										</StackPanel>

									</Grid>

								</Border>

							</Button>

						</DataTemplate>
					</ItemsControl.ItemTemplate>

				</ItemsControl>

			</StackPanel>

		</Grid>

	</Grid>

</Window>
