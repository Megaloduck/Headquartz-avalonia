<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.DepartmentReportView">

	<ScrollViewer>
		<StackPanel Margin="30" Spacing="20">

			<!-- TITLE -->
			<StackPanel Orientation="Horizontal" Spacing="4">
				<TextBlock Text="{Binding DeptEmoji}" FontSize="32" VerticalAlignment="Center"/>
				<StackPanel>
					<TextBlock FontSize="34" FontWeight="Bold"
                        Text="{Binding DeptName, StringFormat='{}{0} Report'}"/>
					<TextBlock FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Text="{Binding StatusLabel}"/>
				</StackPanel>
			</StackPanel>

			<!-- DEPT HEALTH BARS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<Grid ColumnDefinitions="*,*,*">

					<StackPanel Grid.Column="0" Spacing="8">
						<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Text="EFFICIENCY"/>
						<StackPanel Orientation="Horizontal" Spacing="8">
							<ProgressBar Value="{Binding Efficiency}" Maximum="100"
                                Height="10" Width="120" Foreground="{DynamicResource BrushSuccess}" VerticalAlignment="Center"/>
							<TextBlock Text="{Binding Efficiency, StringFormat='{}{0}%'}"
                                FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
						</StackPanel>
					</StackPanel>

					<StackPanel Grid.Column="1" Spacing="8">
						<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Text="STRESS"/>
						<StackPanel Orientation="Horizontal" Spacing="8">
							<ProgressBar Value="{Binding StressLevel}" Maximum="100"
                                Height="10" Width="120" Foreground="{DynamicResource BrushDanger}" VerticalAlignment="Center"/>
							<TextBlock Text="{Binding StressLevel, StringFormat='{}{0}%'}"
                                FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
						</StackPanel>
					</StackPanel>

					<StackPanel Grid.Column="2" Spacing="8">
						<TextBlock FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" Text="STAFF"/>
						<TextBlock FontSize="22" FontWeight="Bold"
                            Text="{Binding StaffCount, StringFormat='👤 {0}'}"/>
					</StackPanel>

				</Grid>
			</Border>

			<!-- KEY METRICS GRID -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="20" FontWeight="Bold" Text="Key Metrics" Margin="0,0,0,16"/>

					<ItemsControl ItemsSource="{Binding Metrics}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<WrapPanel/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border
                                    Width="220" Margin="8"
                                    Padding="18,14"
                                    CornerRadius="10"
                                    Background="{DynamicResource BrushBgNested}">
									<StackPanel Spacing="4">

										<TextBlock
                                            FontSize="12"
                                            Foreground="{DynamicResource BrushTextSecondary}"
                                            Text="{Binding Label}"/>

										<TextBlock
                                            FontSize="24"
                                            FontWeight="Bold"
                                            Text="{Binding Value}"/>

										<StackPanel Orientation="Horizontal" Spacing="6">
											<!-- Alert dot -->
											<Border
                                                IsVisible="{Binding IsAlert}"
                                                Width="7" Height="7"
                                                CornerRadius="4"
                                                Background="{DynamicResource BrushDanger}"
                                                VerticalAlignment="Center"/>
											<TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding SubLabel}"/>
										</StackPanel>

									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

			<!-- RECENT EVENTS -->
			<Border Padding="20" Background="{DynamicResource BrushBgCard}" CornerRadius="12">
				<StackPanel>
					<TextBlock FontSize="20" FontWeight="Bold" Text="Event History" Margin="0,0,0,12"/>

					<TextBlock
                        IsVisible="{Binding !RecentEvents.Count}"
                        Text="No events recorded for this department."
                        Foreground="{DynamicResource BrushTextSecondary}"/>

					<ItemsControl ItemsSource="{Binding RecentEvents}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,4" Padding="14,10" Background="{DynamicResource BrushBgNested}" CornerRadius="8">
									<Grid ColumnDefinitions="*,100,80">
										<StackPanel Grid.Column="0">
											<TextBlock FontWeight="SemiBold" Text="{Binding Title}"/>
											<TextBlock FontSize="12" Foreground="{DynamicResource BrushTextSecondary}"
                                                Text="{Binding Description}" TextWrapping="Wrap"/>
										</StackPanel>
										<TextBlock
                                            Grid.Column="1"
                                            FontSize="12"
                                            Foreground="{DynamicResource BrushTextSecondary}"
                                            Text="{Binding Severity}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>
										<TextBlock
                                            Grid.Column="2"
                                            FontSize="11"
                                            Foreground="{DynamicResource BrushTextSecondary}"
                                            Text="{Binding RemainingTicks, StringFormat='{}{0} ticks'}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"/>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>