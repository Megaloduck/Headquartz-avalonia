<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Class="Headquartz.App.Views.SplashView">

	<Grid Background="#0B0F1A">

		<!-- Glow top-left -->
		<Ellipse Width="600" Height="600"
            HorizontalAlignment="Left" VerticalAlignment="Top"
            Margin="-200,-200,0,0" Opacity="0.07">
			<Ellipse.Fill>
				<RadialGradientBrush>
					<GradientStop Color="#6366F1" Offset="0"/>
					<GradientStop Color="Transparent" Offset="1"/>
				</RadialGradientBrush>
			</Ellipse.Fill>
		</Ellipse>

		<!-- Glow bottom-right -->
		<Ellipse Width="500" Height="500"
            HorizontalAlignment="Right" VerticalAlignment="Bottom"
            Margin="0,0,-150,-150" Opacity="0.05">
			<Ellipse.Fill>
				<RadialGradientBrush>
					<GradientStop Color="#06B6D4" Offset="0"/>
					<GradientStop Color="Transparent" Offset="1"/>
				</RadialGradientBrush>
			</Ellipse.Fill>
		</Ellipse>

		<!-- Center content -->
		<StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="0"
            Width="360">

			<!-- Logo -->
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                Spacing="14" Margin="0,0,0,20">
				<Border Width="56" Height="56" CornerRadius="16" Background="#6366F1">
					<TextBlock Text="H" FontSize="30" FontWeight="Bold" Foreground="White"
                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
				</Border>
				<TextBlock Text="HEADQUARTZ" FontSize="34" FontWeight="Bold"
                    Foreground="White" LetterSpacing="6" VerticalAlignment="Center"/>
			</StackPanel>

			<!-- Subtitle -->
			<TextBlock
                Text="Enterprise Resource Planning Simulator"
                FontSize="13"
                Foreground="#4B5563"
                HorizontalAlignment="Center"
                Margin="0,0,0,48"/>

			<!-- Loading message -->
			<TextBlock
                Text="{Binding LoadingMessage}"
                FontSize="13"
                Foreground="#6B7280"
                HorizontalAlignment="Center"
                Margin="0,0,0,12"/>

			<!-- Progress bar -->
			<ProgressBar
                Value="{Binding LoadingProgress}"
                Maximum="100"
                Height="3"
                Foreground="#6366F1"
                Background="#1F2937"
                CornerRadius="2"
                Margin="0,0,0,32"/>

			<!-- Version -->
			<TextBlock
                Text="{Binding GameVersion}"
                FontSize="11"
                Foreground="#374151"
                HorizontalAlignment="Center"/>

		</StackPanel>

	</Grid>

</UserControl>