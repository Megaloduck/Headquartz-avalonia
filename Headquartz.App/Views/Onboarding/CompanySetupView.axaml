<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.CompanySetupView"
             Background="{DynamicResource BrushBgBase}">

    <ScrollViewer>
        <Grid ColumnDefinitions="*,640,*" Margin="0,40,0,40">

            <!-- ── Main column ────────────────────────────── -->
            <StackPanel Grid.Column="1" Spacing="0">

                <!-- Header -->
                <StackPanel Spacing="6" Margin="0,0,0,36">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Padding="8,6"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding GoBackCommand}">
                            <TextBlock Text="← Back" FontSize="12" Foreground="{DynamicResource BrushBorderStrong}"/>
                        </Button>
                    </StackPanel>
                    <TextBlock
                        Text="Company Setup"
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="{DynamicResource BrushTextPrimary}"/>
                    <TextBlock
                        Text="Configure your company before the session begins"
                        FontSize="14"
                        Foreground="{DynamicResource BrushTextMuted}"/>
                </StackPanel>

                <!-- ── Step 1: Name ──────────────────────── -->
                <Border
                    Padding="24"
                    Background="{DynamicResource BrushBgSurface}"
                    BorderBrush="{DynamicResource BrushBgInput}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Margin="0,0,0,16">
                    <StackPanel Spacing="16">

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border
                                Width="32" Height="32"
                                CornerRadius="8"
                                Background="{DynamicResource BrushBgBase}">
                                <TextBlock
                                    Text="1"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource BrushAccentPrimaryHover}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock
                                Text="Company Name"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="{DynamicResource BrushTextPrimary}"
                                VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox
                                Grid.Column="0"
                                Text="{Binding CompanyName}"
                                PlaceholderText="Enter company name..."
                                FontSize="16"
                                Padding="14,12"
                                Background="{DynamicResource BrushBgInput}"
                                BorderBrush="{DynamicResource BrushBgInput}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Foreground="{DynamicResource BrushTextPrimary}"/>
                            <Button
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="14,12"
                                Background="{DynamicResource BrushBgInput}"
                                CornerRadius="10"
                                Command="{Binding RandomNameCommand}">
                                <TextBlock Text="🎲 Random" FontSize="13" Foreground="{DynamicResource BrushTextSecondary}"/>
                            </Button>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ── Step 2: Industry ──────────────────── -->
                <Border
                    Padding="24"
                    Background="{DynamicResource BrushBgSurface}"
                    BorderBrush="{DynamicResource BrushBgInput}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Margin="0,0,0,16">
                    <StackPanel Spacing="16">

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border
                                Width="32" Height="32"
                                CornerRadius="8"
                                Background="{DynamicResource BrushBgBase}">
                                <TextBlock
                                    Text="2"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource BrushAccentPrimaryHover}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock
                                Text="Industry"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="{DynamicResource BrushTextPrimary}"
                                VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Industries}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Width="120" Height="56"
                                        Margin="0,0,6,6"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding $parent[ItemsControl].DataContext.SelectIndustryCommand}"
                                        CommandParameter="{Binding}">
                                        <Border
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            CornerRadius="10"
                                            BorderThickness="1">
                                            <Border.Background>
                                                <SolidColorBrush Color="{DynamicResource ColorBgInput}"/>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="{DynamicResource ColorBgInput}"/>
                                            </Border.BorderBrush>
                                            <StackPanel
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Spacing="2">
                                                <TextBlock
                                                    Text="{Binding Emoji}"
                                                    FontSize="20"
                                                    HorizontalAlignment="Center"/>
                                                <TextBlock
                                                    Text="{Binding Label}"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource BrushTextSecondary}"
                                                    HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border
                            Padding="12,8"
                            Background="{DynamicResource BrushBgInput}"
                            CornerRadius="8">
                            <TextBlock
                                Text="{Binding IndustryDescription}"
                                FontSize="12"
                                Foreground="{DynamicResource BrushTextSecondary}"
                                TextWrapping="Wrap"/>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ── Step 3: Department Fit ─────────────── -->
                <Border
                    Padding="24"
                    Background="{DynamicResource BrushBgSurface}"
                    BorderBrush="{DynamicResource BrushBgInput}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Margin="0,0,0,16">
                    <StackPanel Spacing="12">

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border
                                Width="32" Height="32"
                                CornerRadius="8"
                                Background="{DynamicResource BrushBgBase}">
                                <TextBlock
                                    Text="3"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource BrushAccentPrimaryHover}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock
                                Text="Department Fit"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="{DynamicResource BrushTextPrimary}"
                                VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock
                            Text="How each department aligns with your chosen industry."
                            FontSize="12"
                            Foreground="{DynamicResource BrushTextMuted}"
                            TextWrapping="Wrap"
                            Margin="0,0,0,4"/>

                        <ItemsControl ItemsSource="{Binding DepartmentRelevancePreview}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Width="136"
                                        Margin="0,0,6,6"
                                        Padding="8,6"
                                        CornerRadius="8"
                                        Background="{DynamicResource BrushBgInput}">
                                        <StackPanel Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock
                                                    Text="{Binding Emoji}"
                                                    FontSize="10"
                                                    VerticalAlignment="Center"/>
                                                <TextBlock
                                                    Text="{Binding RelevanceLabel}"
                                                    FontSize="9"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource BrushTextPrimary}"
                                                    VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock
                                                Text="{Binding DepartmentName}"
                                                FontSize="11"
                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>

                <!-- ── Step 4: Difficulty ────────────────── -->
                <Border
                    Padding="24"
                    Background="{DynamicResource BrushBgSurface}"
                    BorderBrush="{DynamicResource BrushBgInput}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Margin="0,0,0,16">
                    <StackPanel Spacing="16">

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border
                                Width="32" Height="32"
                                CornerRadius="8"
                                Background="{DynamicResource BrushBgBase}">
                                <TextBlock
                                    Text="4"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource BrushAccentPrimaryHover}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock
                                Text="Difficulty"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="{DynamicResource BrushTextPrimary}"
                                VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Difficulties}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="8"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        HorizontalAlignment="Stretch"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding $parent[ItemsControl].DataContext.SelectDifficultyCommand}"
                                        CommandParameter="{Binding}">
                                        <Border
                                            Padding="16,12"
                                            CornerRadius="10"
                                            BorderThickness="1">
                                            <Border.Background>
                                                <SolidColorBrush Color="{DynamicResource ColorBgInput}"/>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="{DynamicResource ColorBgInput}"/>
                                            </Border.BorderBrush>
                                            <Grid ColumnDefinitions="24,*,Auto">
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Text="{Binding DotEmoji}"
                                                    FontSize="14"
                                                    VerticalAlignment="Center"/>
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Text="{Binding Label}"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource BrushTextPrimary}"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0"/>
                                                <TextBlock
                                                    Grid.Column="2"
                                                    Text="{Binding SubLabel}"
                                                    FontSize="12"
                                                    Foreground="{DynamicResource BrushBorderStrong}"
                                                    VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Difficulty description + capital -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock
                                Grid.Column="0"
                                Text="{Binding DifficultyDescription}"
                                FontSize="12"
                                Foreground="{DynamicResource BrushTextSecondary}"
                                TextWrapping="Wrap"
                                VerticalAlignment="Center"/>
                            <Border
                                Grid.Column="1"
                                Padding="16,10"
                                Background="{DynamicResource BrushBgInput}"
                                CornerRadius="8"
                                Margin="12,0,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock
                                        Text="STARTING CAPITAL"
                                        FontSize="9"
                                        Foreground="{DynamicResource BrushBorderStrong}"
                                        LetterSpacing="1"
                                        HorizontalAlignment="Center"/>
                                    <TextBlock
                                        Text="{Binding CapitalDisplay}"
                                        FontSize="22"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource BrushSuccess}"
                                        HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- Error -->
                <Border
                    IsVisible="{Binding HasError}"
                    Padding="14,10"
                    Background="{DynamicResource BrushBadgeDangerBg}"
                    BorderBrush="{DynamicResource BrushAlertCriticalBg}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,16">
                    <TextBlock
                        Text="{Binding ErrorMessage}"
                        FontSize="13"
                        Foreground="{DynamicResource BrushBadgeDangerFg}"/>
                </Border>

                <!-- Confirm -->
                <Button
                    HorizontalAlignment="Stretch"
                    Padding="0,16"
                    CornerRadius="12"
                    Command="{Binding ConfirmCommand}">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="{DynamicResource ColorAccentPrimary}" Offset="0"/>
                            <GradientStop Color="{DynamicResource ColorAccentPrimaryHover}" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <TextBlock
                        Text="Select Department →"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{DynamicResource BrushTextPrimary}"
                        HorizontalAlignment="Center"/>
                </Button>

            </StackPanel>

        </Grid>
    </ScrollViewer>

</UserControl>
