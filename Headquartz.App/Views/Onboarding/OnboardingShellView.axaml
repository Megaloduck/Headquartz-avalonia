<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Headquartz.App.OnboardingShellView">

    <!--
        The OnboardingShellView is a thin wrapper.
        It hosts a ContentControl whose DataContext is swapped
        by the OnboardingShellViewModel as the player progresses
        through Splash → Profile → MainMenu → Lobby → Setup → Dept.

        Views are resolved by the ViewLocator (same pattern as gameplay).
    -->
    <ContentControl Content="{Binding CurrentView}"/>

</UserControl>
